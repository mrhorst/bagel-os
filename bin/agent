#!/usr/bin/env ruby
# frozen_string_literal: true

# Bagel OS agent CLI — read-only JSON access to domain data for AI agents.
# Boots the Rails environment, then hands argv to Agents::Cli.
#
#   bin/agent help
#   bin/agent tasks:today
#   bin/agent price:product "house blend" --compact
#
# See docs/agents/agent-cli.md for the full command reference.

# Two transports, chosen by environment:
#   - Remote: if BAGEL_API_URL is set, talk to a running app over HTTPS. No
#     Rails boot, no DB, no checkout needed near the agent — just a token.
#   - Local: otherwise boot the app from this checkout and run in-process.
if ENV["BAGEL_API_URL"].to_s.strip.empty?
  require_relative "../config/environment"
  exit Agents::Cli.run(ARGV)
else
  require_relative "../lib/agents/remote_client"
  exit Agents::RemoteClient.run(ARGV)
end
