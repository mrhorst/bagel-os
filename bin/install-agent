#!/usr/bin/env sh
# Install the Bagel OS agent CLI by symlinking bin/agent onto your PATH, so you
# can run `agent ...` from anywhere instead of `./bin/agent` in the repo.
#
# Light by design: this only creates a symlink — no copying, no build step. The
# command still runs from this checkout (it boots the app from here), so the
# repo must stay in place and its gems installed (`bundle install`).
#
#   bin/install-agent                      # link into ~/.local/bin
#   BAGEL_AGENT_BIN_DIR=/usr/local/bin bin/install-agent
#   BAGEL_AGENT_FORCE=1 bin/install-agent  # overwrite a non-symlink at the target
#
# Uninstall: rm "<bin-dir>/agent"
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
repo_root=$(dirname -- "$script_dir")
source="$repo_root/bin/agent"
bin_dir=${BAGEL_AGENT_BIN_DIR:-$HOME/.local/bin}
target="$bin_dir/agent"

[ -f "$source" ] || { echo "error: $source not found — run this from the bagel-os checkout." >&2; exit 1; }

mkdir -p "$bin_dir"

# Don't silently clobber a real file someone else put there.
if [ -e "$target" ] && [ ! -L "$target" ] && [ "${BAGEL_AGENT_FORCE:-}" != "1" ]; then
  echo "error: $target exists and is not a symlink. Re-run with BAGEL_AGENT_FORCE=1 to replace it." >&2
  exit 1
fi

ln -sf "$source" "$target"
echo "Linked $target -> $source"

# Tell the user (or agent) whether the command is actually reachable yet.
case ":$PATH:" in
  *":$bin_dir:"*)
    echo "Ready. Run: agent login --email <you>"
    ;;
  *)
    echo
    echo "$bin_dir is not on your PATH. Add it, then re-open your shell:"
    echo "  echo 'export PATH=\"$bin_dir:\$PATH\"' >> ~/.profile"
    echo "Or run it directly for now: $target login --email <you>"
    ;;
esac
