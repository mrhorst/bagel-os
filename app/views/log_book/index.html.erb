<% content_for :title, "Log Book" %>

<% content_for :mobile_right_action do %>
  <div class="module-overflow" data-controller="popover">
    <button type="button"
            class="mobile-header-action"
            data-action="popover#toggle"
            data-popover-target="trigger"
            aria-label="Log Book menu"
            aria-haspopup="true"
            aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="4" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="10" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="16" cy="10" r="1.6" fill="currentColor"/>
      </svg>
    </button>
    <div class="popover-panel popover-panel-menu" hidden data-popover-target="panel" role="menu">
      <%= link_to "History", log_book_history_path, role: "menuitem", class: "popover-item" %>
      <% if current_user.admin? %>
        <%= link_to "Settings", log_book_settings_path, role: "menuitem", class: "popover-item" %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Page title — matches every sibling index (Inventory Counts, Users, …); on
    mobile the H1 is hidden by the layout (the sticky header is authoritative)
    and only the subtitle shows, consistent with those screens. %>
<div class="page-heading">
  <div>
    <h1>Log Book</h1>
    <p>Daily notes, counts, and follow-ups.</p>
  </div>
</div>

<%# ── Date pager + saved status ──────────────────────────────────────── %>
<header class="log-book-header">
  <nav class="log-book-date-nav" aria-label="Log Book date">
    <%= link_to log_book_path(date: @prev_date), class: "log-book-date-arrow", aria: { label: "Previous day" } do %>
      <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    <% end %>
    <span class="log-book-date-nav-label"><%= @operating_date.strftime("%a %b %-d, %Y") %></span>
    <% if @next_date %>
      <%= link_to log_book_path(date: @next_date), class: "log-book-date-arrow", aria: { label: "Next day" } do %>
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      <% end %>
    <% else %>
      <span class="log-book-date-arrow log-book-date-arrow-disabled" aria-disabled="true" aria-label="No next day">
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </span>
    <% end %>
  </nav>

  <% unless @operating_date == @today %>
    <div class="log-book-header-today">
      <%= link_to "Back to today", log_book_path, class: "button primary small" %>
    </div>
  <% end %>

  <%# Status strip — replaces the 3 KPI tiles. Lightweight, single row.
      The ⋯ overflow lives at the right end of this strip, next to "Saved …". %>
  <div class="log-book-status-strip" aria-label="Log book summary">
    <span class="log-book-status-followups">
      <% if @open_follow_up_count.positive? %>
        <%= link_to follow_ups_path do %>
          <strong class="tnum"><%= @open_follow_up_count %></strong>
          <%= "open follow-up".pluralize(@open_follow_up_count) %>
        <% end %>
      <% else %>
        <span class="muted">No open follow-ups</span>
      <% end %>
    </span>
    <span class="log-book-status-saved">
      <%= render "log_book/save_status", saved_at: (@entry.persisted? ? @entry.submitted_at : nil), error: nil %>
    </span>
  </div>
</header>

<%# Follow-ups now live in /follow-ups; the count link in the status strip
    above is the only entry point on this screen. %>
<% entry_panel = capture do %>
  <section class="block-panel">
    <header class="block-panel-header">
      <div>
        <h2><%= @editable ? "Today's entry" : "Daily entry" %></h2>
        <p>
          <% if @editable %>
            Saves automatically as you type.
          <% else %>
            Past operating days are read-only.
          <% end %>
        </p>
      </div>
    </header>

    <% if @sections.any? %>
      <% if @editable %>
        <%= form_with url: log_book_path, method: :patch, class: "stacked-form",
              data: { controller: "log-book-autosave",
                      log_book_autosave_debounce_value: 700,
                      log_book_autosave_storage_key_value: "log_book_draft_#{@operating_date.iso8601}",
                      action: "change->log-book-autosave#queue input->log-book-autosave#queue" } do %>
          <%= hidden_field_tag :operating_date, @operating_date.iso8601 %>

          <% @sections.each do |section| %>
            <%= render "log_book/section_card",
                  section: section,
                  response: @responses_by_section_id[section.id],
                  response_errors: @response_errors[section.id],
                  overrides: (@form_overrides && @form_overrides[section.id]) || {} %>
          <% end %>
        <% end %>
      <% else %>
        <div class="stack">
          <% @sections.each do |section| %>
            <% response = @responses_by_section_id[section.id] %>
            <article class="decision-card">
              <div class="decision-card-body">
                <h2><%= response&.section_title_snapshot || section.title %></h2>
                <p><%= response&.display_value || "No response recorded." %></p>
                <% if response&.flagged_for_follow_up? %>
                  <span class="badge badge-warning"><%= response.urgency.humanize %> follow-up</span>
                <% end %>
                <% if response&.last_submitted_by && response.last_submitted_at %>
                  <p class="muted small">
                    Last updated by <%= user_display_name(response.last_submitted_by) %>
                    · <%= response.last_submitted_at.strftime("%b %-d, %-l:%M %p") %>
                  </p>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="empty-state">
        <strong>No Log Sections yet.</strong>
        <span>An admin can create sections like General Log, Maintenance, and Bagels Left.</span>
      </p>
      <% if current_user.admin? %>
        <div class="form-footer">
          <%= link_to "Create first section", new_log_book_section_path, class: "button primary" %>
        </div>
      <% end %>
    <% end %>
  </section>
<% end %>

<%= entry_panel %>
