<% content_for :title, @modifier_group.name %>

<%# Send the mobile back-chevron up one level to the modifier library, rather
    than the layout's default jump to the Stock hub. %>
<% content_for :mobile_left_action do %>
  <%= link_to modifier_groups_path, class: "mobile-header-back", aria: { label: "Back to modifiers" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Modifiers</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1><%= @modifier_group.name %></h1>
    <p>
      <span class="badge <%= "badge-ok" if @modifier_group.ingredient? %>"><%= @modifier_group.ingredient? ? "Ingredient" : "Preparation" %></span>
      <span class="badge"><%= @modifier_group.selection_summary %></span>
    </p>
  </div>
  <div class="hero-actions">
    <%= link_to "All modifiers", modifier_groups_path, class: "button" %>
    <%= link_to "Edit", edit_modifier_group_path(@modifier_group), class: "button" %>
    <%= button_to "Delete", modifier_group_path(@modifier_group), method: :delete, class: "button",
          data: { turbo_confirm: "Delete #{@modifier_group.name}? It will be removed from #{pluralize(@modifier_group.recipes.size, "recipe")} and its options will be deleted." } %>
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Options</h2>
      <% if @modifier_group.ingredient? %>
        <p class="muted">The choices a guest picks from. Link each option to an inventory item where you can — that's what makes the choice count toward cost. Record the amount one pick uses (2 slices of tomato, 1 bagel); leave it blank when it isn't known. Mark the standard pick as the default.</p>
      <% else %>
        <p class="muted">The choices a guest picks from. A preparation choice only tells the kitchen how to make it, so options are just names — no inventory link or amount needed. Mark the standard pick as the default.</p>
      <% end %>
    </div>
  </div>

  <% if @options.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Option</th>
          <th>Amount</th>
          <th>Unit</th>
          <% if @modifier_group.ingredient? %>
            <th class="numeric">Est. cost</th>
          <% end %>
          <th>Default</th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @options.each do |option| %>
          <%# When an inline edit is rejected, the controller hands back the
              invalid instance so the row keeps the typed values and shows the
              error instead of reverting. %>
          <% row = (@editing_option if @editing_option&.id == option.id) || option %>
          <%# A rejected inline edit re-renders the page at the top (native
              submit, no place-preserving fragment on the 422); scroll this row
              back into view so its error is seen, same as the recipe rows. %>
          <% row_errored = @editing_option&.id == option.id %>
          <tr id="option-line-<%= option.id %>"<%= " data-controller=scroll-into-view" if row_errored %>>
            <td class="row-heading" data-label="Option">
              <%= option.display_name %>
              <% if option.inventory_item %><span class="badge badge-compact">Inventory</span><% end %>
            </td>
            <%# A blank amount is intentional ("never guessed") — show the app's
                "—" blank marker, matching the recipe ingredients table. %>
            <td data-label="Amount" class="tnum"><%= option.quantity.present? ? compact_decimal(option.quantity) : "—" %></td>
            <td data-label="Unit"><%= option.unit.presence || "—" %></td>
            <% if @modifier_group.ingredient? %>
              <% line_cost = @option_costs[option] %>
              <td data-label="Est. cost" class="numeric">
                <% if line_cost&.costed? %>
                  <span class="tnum"><%= money(line_cost.cost) %></span>
                <% else %>
                  <%# Never invent a number — say why the option can't be costed. %>
                  <span class="badge">Uncertain</span>
                  <p class="muted small"><%= line_cost&.reason %></p>
                <% end %>
              </td>
            <% end %>
            <td data-label="Default">
              <% if option.default_choice? %>
                <span class="badge badge-ok">Default</span>
              <% else %>
                <span class="muted">—</span>
              <% end %>
            </td>
            <%# The edit form hides behind a disclosure so a row reads as its
                values, not a wall of inputs — on a phone an always-open form
                doubled every card. A rejected edit re-opens it so the error
                and the typed values are visible, same as the task form. %>
            <td data-label="">
              <details class="form-disclosure"<%= " open".html_safe if row.errors.any? %>>
                <summary>Edit</summary>
                <%= render "modifier_groups/option_form",
                      modifier_group: @modifier_group, option: row, inventory_items: @inventory_items, submit_label: "Save" %>
              </details>
            </td>
            <td class="row-actions" data-label="">
              <%= button_to "Remove", modifier_group_option_path(@modifier_group, option), method: :delete, class: "button small",
                    data: { turbo_confirm: "Remove #{option.display_name} from #{@modifier_group.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No options yet. Add the first one below.</p>
  <% end %>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Used by</h2>
      <p class="muted">The recipes this choice is attached to. Attach it from a recipe's page.</p>
    </div>
  </div>
  <% recipes = @modifier_group.recipes.ordered %>
  <% if recipes.any? %>
    <ul class="substitute-list">
      <% recipes.each do |recipe| %>
        <li><span><%= link_to recipe.name, recipe_path(recipe) %></span></li>
      <% end %>
    </ul>
  <% else %>
    <p class="empty-state">Not attached to any recipes yet.</p>
  <% end %>
</section>

<%# When a rejected add re-renders the page, the native submit lands at the top
    and this form (with its error) sits below the fold — scroll it back into view
    so the error is seen, not silently missed. Same guard as the recipe forms. %>
<section class="panel narrow" id="add-option"
    <%= "data-controller=scroll-into-view" if @new_option&.errors&.any? %>>
  <h2>Add option</h2>
  <%= render "modifier_groups/option_form",
        modifier_group: @modifier_group, option: @new_option, inventory_items: @inventory_items, submit_label: "Add option", stacked: true %>
</section>
