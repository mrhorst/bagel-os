<% content_for :title, "New modifier" %>

<%# Send the mobile back-chevron up one level to the modifier library this form
    is reached from, not the layout's default hub. %>
<% content_for :mobile_left_action do %>
  <%= link_to modifier_groups_path, class: "mobile-header-back", aria: { label: "Back to modifiers" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Modifiers</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>New modifier</h1>
    <p>Name the choice and how many options a guest picks — you'll add the options from it next.</p>
  </div>
</section>

<article class="panel narrow">
  <%= render "form", modifier_group: @modifier_group %>
</article>
