<%= form_with model: modifier_group, class: "stacked-form" do |form| %>
  <% if modifier_group.errors.any? %>
    <div class="flash flash-alert">
      <strong><%= pluralize(modifier_group.errors.count, "error") %> kept this from saving:</strong>
      <ul><% modifier_group.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Modifier name" %>
    <p class="muted small">The choice as a guest sees it — "Meat", "Cheese", "Bread", "Egg style", "Sides".</p>
    <%= form.text_field :name, required: true, autocomplete: "off", placeholder: "Bread" %>
  </div>

  <div class="field">
    <%= form.label :kind, "Type" %>
    <p class="muted small">Ingredient choices link their options to inventory items and count toward cost. Preparation choices only tell the kitchen how to make it — like how an egg is cooked — and never affect cost.</p>
    <%= form.select :kind,
          options_for_select([ [ "Ingredient — options come from inventory and affect cost", "ingredient" ],
                               [ "Preparation — prep instruction only, no cost", "preparation" ] ], modifier_group.kind),
          {}, { class: "compact-select" } %>
  </div>

  <div class="form-grid">
    <div class="field">
      <%= form.label :min_select, "Picks at least" %>
      <p class="muted small">1 and 1 = pick one. 2 and 2 = pick two (a 2-2-2 style choice).</p>
      <%= form.number_field :min_select, min: "1", step: "1" %>
    </div>
    <div class="field">
      <%= form.label :max_select, "Picks at most" %>
      <%= form.number_field :max_select, min: "1", step: "1" %>
    </div>
  </div>

  <div class="form-footer">
    <%= link_to "Cancel", (modifier_group.persisted? ? modifier_group_path(modifier_group) : modifier_groups_path), class: "button" %>
    <%= form.submit (modifier_group.persisted? ? "Save changes" : "Create modifier"), class: "button primary" %>
  </div>
<% end %>
