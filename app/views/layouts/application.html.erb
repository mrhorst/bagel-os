<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_branding.app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_branding.short_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= app_branding.description %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-950 antialiased">
    <div class="app-shell">
      <aside class="app-sidebar">
        <div class="sidebar-brand">
          <%= link_to root_path, class: "brand-lockup" do %>
            <span class="brand-mark">IO</span>
            <span>
              <strong><%= app_branding.app_name %></strong>
              <small><%= app_branding.short_name %></small>
            </span>
          <% end %>
        </div>

        <nav class="sidebar-nav" aria-label="Primary navigation">
          <% app_nav_items.each do |item| %>
            <%= link_to item[:path], class: ["nav-link", ("active" if active_nav_item?(item))] do %>
              <%= nav_icon(item[:icon]) %>
              <span><%= item[:label] %></span>
            <% end %>
          <% end %>
        </nav>

        <div class="sidebar-footer">
          <strong>Generic workspace</strong>
          <span>No private restaurant data in tracked files.</span>
        </div>
      </aside>

      <div class="app-content">
        <header class="topbar">
          <div>
            <p class="topbar-kicker">Restaurant purchasing system</p>
            <p class="topbar-description"><%= app_branding.description %></p>
          </div>
        </header>

        <main class="app-main">
          <% if notice.present? %>
            <div class="flash flash-notice"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="flash flash-alert"><%= alert %></div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
