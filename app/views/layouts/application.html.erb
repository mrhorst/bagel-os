<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_branding.app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="<%= app_branding.short_name %>">
    <meta name="application-name" content="<%= app_branding.short_name %>">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#f2f3f7">
    <meta name="description" content="<%= app_branding.description %>">
    <meta name="turbo-prefetch" content="true">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300..700&family=Geist+Mono:wght@400..600&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("<%= pwa_service_worker_path(format: :js) %>", { scope: "/" });
        });
      }
    </script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag Rails.env.test? ? "application" : "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-surface text-ink antialiased" data-controller="pull-to-refresh">
    <% if environment_banner_label %>
      <div class="env-banner" role="status"><%= environment_banner_label %> · not production</div>
    <% end %>
    <div class="app-shell">
      <aside class="app-sidebar">
        <div class="sidebar-brand">
          <%= link_to root_path, class: "brand-lockup" do %>
            <span class="brand-mark">IO</span>
            <span>
              <strong><%= app_branding.app_name %></strong>
              <small><%= app_branding.short_name %></small>
            </span>
          <% end %>
        </div>

        <nav class="sidebar-nav" aria-label="Primary navigation">
          <% sidebar_nav_items.each do |item| %>
            <%= link_to item[:path], class: ["nav-link", ("active" if active_nav_item?(item))] do %>
              <%= nav_icon(item[:icon]) %>
              <span><%= item[:label] %></span>
            <% end %>
          <% end %>
        </nav>

        <% if current_user %>
          <%= link_to account_path, class: ["sidebar-account", ("active" if controller_name == "accounts")], aria: { label: "Account" } do %>
            <span class="sidebar-account-avatar" aria-hidden="true"><%= user_display_name(current_user).first.upcase %></span>
            <span class="sidebar-account-text">
              <strong><%= user_display_name(current_user) %></strong>
              <span>Account &amp; sign out</span>
            </span>
          <% end %>
        <% else %>
          <div class="sidebar-footer">
            <strong>Generic workspace</strong>
            <span>No private restaurant data in tracked files.</span>
          </div>
        <% end %>
      </aside>

      <div class="app-content">
        <header class="topbar">
          <div>
            <p class="topbar-description"><%= app_branding.description %></p>
          </div>
          <% if current_user %>
            <%= link_to account_path, class: "topbar-account", aria: { label: "Account" } do %>
              <span class="topbar-account-avatar" aria-hidden="true"><%= user_display_name(current_user).first.upcase %></span>
              <span class="topbar-account-name"><%= user_display_name(current_user) %></span>
            <% end %>
          <% end %>
        </header>

        <header class="mobile-screen-header">
          <div class="mobile-header-left">
            <% if content_for?(:mobile_left_action) %>
              <%= yield :mobile_left_action %>
            <% elsif current_user && on_module_page? && current_hub_def %>
              <%# Auto back-chevron to the module's parent hub. Gated on an
                  authenticated user: the logged-out sign-in and reset-password
                  pages live in the account module (sessions/passwords), so
                  without this they render a "Back to More" chevron that just
                  bounces back through the auth wall. %>
              <%= link_to send(current_hub_def[:path_helper]), class: "mobile-header-back", aria: { label: "Back to #{current_hub_def[:label]}" } do %>
                <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
                  <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                <span><%= current_hub_def[:label] %></span>
              <% end %>
            <% end %>
          </div>
          <h1 class="mobile-header-title"><%= mobile_screen_title %></h1>
          <div class="mobile-header-right">
            <%# Pages opt in to a right-side action via :mobile_right_action.
                The Account avatar lives only on the Dashboard — no need to
                expose profile/settings on every screen. %>
            <%= yield :mobile_right_action if content_for?(:mobile_right_action) %>
          </div>
        </header>

        <main class="app-main">
          <% if notice.present? %>
            <div class="flash flash-notice"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="flash flash-alert"><%= alert %></div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
    <% if content_for?(:mobile_fab) %>
      <%= yield :mobile_fab %>
    <% end %>
    <%= render "layouts/mobile_tabs" %>
  </body>
</html>
