<%# Bottom tab bar — visible only at <640px (kitchen / on-the-floor use). %>
<%
  candidate_tabs = [
    { label: "Home",   path: root_path,                  icon: "chart",     match_with: all_nav_items[0], module: nil },
    { label: "Tasks",  path: tasks_root_path,            icon: "check",     match_with: all_nav_items[2], module: "tasks" },
    { label: "Guides", path: order_guides_path,          icon: "clipboard", match_with: all_nav_items[3], module: "order_guides" },
    { label: "Review", path: normalization_reviews_path, icon: "alert",     match_with: all_nav_items[6], module: "normalization_reviews" },
    { label: "More",   path: products_path,              icon: "package",   match_with: all_nav_items[5], module: "products" }
  ]
  mobile_tabs = candidate_tabs.select { |tab| tab[:module].nil? || Current.user&.can_access?(tab[:module]) }
%>
<nav class="mobile-tabs" aria-label="Primary (mobile)">
  <% mobile_tabs.each do |tab| %>
    <%= link_to tab[:path], class: ["mobile-tab", ("active" if active_nav_item?(tab[:match_with]))] do %>
      <%= nav_icon(tab[:icon]) %>
      <span><%= tab[:label] %></span>
    <% end %>
  <% end %>
</nav>
