<%# Bottom tab bar — visible only at <640px (kitchen / on-the-floor use). %>
<%
  nav_by_label = all_nav_items.index_by { |item| item[:label] }
  candidate_tabs = [
    { label: "Home",     path: root_path,         icon: "chart",     match_with: nav_by_label["Dashboard"],    module: nil },
    { label: "Tasks",    path: tasks_root_path,   icon: "check",     match_with: nav_by_label["Tasks"],        module: "tasks" },
    { label: "Log Book", path: log_book_path,     icon: "book",      match_with: nav_by_label["Log Book"],     module: "log_book" },
    { label: "Guides",   path: order_guides_path, icon: "clipboard", match_with: nav_by_label["Order Guides"], module: "order_guides" },
    { label: "More",     path: products_path,     icon: "package",   match_with: nav_by_label["Products"],     module: "products" }
  ]
  mobile_tabs = candidate_tabs.select { |tab| tab[:module].nil? || Current.user&.can_access?(tab[:module]) }
%>
<nav class="mobile-tabs" aria-label="Primary (mobile)">
  <% mobile_tabs.each do |tab| %>
    <%= link_to tab[:path], class: ["mobile-tab", ("active" if active_nav_item?(tab[:match_with]))] do %>
      <%= nav_icon(tab[:icon]) %>
      <span><%= tab[:label] %></span>
    <% end %>
  <% end %>
</nav>
