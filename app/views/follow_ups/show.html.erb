<% content_for :title, @follow_up.title %>

<% content_for :mobile_left_action do %>
  <%# Honor the tab the user came from (carried as ?scope=) so Back returns them
      to the Open or Resolved list they were browsing, not always the Open tab.
      Absent/blank scope falls through to the default Open list. %>
  <%= link_to follow_ups_path(scope: params[:scope].presence), class: "mobile-header-back", aria: { label: "Back to Follow-ups" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Follow-ups</span>
  <% end %>
<% end %>

<article class="follow-up-detail">
  <header class="follow-up-detail-head">
    <span class="<%= follow_up_urgency_badge_class(@follow_up.urgency) %>"><%= @follow_up.urgency.humanize %></span>
    <h1><%= @follow_up.title %></h1>
    <p class="muted">
      Opened <%= @follow_up.opened_at.strftime("%B %-d, %Y · %-l:%M %p") %>
      <% if @follow_up.opened_by %>
        by <%= user_display_name(@follow_up.opened_by) %>
      <% end %>
    </p>
  </header>

  <% if @follow_up.description.present? %>
    <section class="follow-up-detail-section">
      <h2 class="follow-up-detail-section-title">Note</h2>
      <div><%= simple_format(@follow_up.description) %></div>
    </section>
  <% end %>

  <section class="follow-up-detail-section">
    <h2 class="follow-up-detail-section-title">Assignee</h2>
    <% if @follow_up.assigned_to %>
      <p class="follow-up-assignee">
        <span class="follow-up-assignee-avatar" aria-hidden="true"><%= user_display_name(@follow_up.assigned_to).first.upcase %></span>
        <strong><%= user_display_name(@follow_up.assigned_to) %></strong>
      </p>
    <% else %>
      <p class="muted small">Unassigned.</p>
    <% end %>

    <% unless @follow_up.resolved? %>
      <%= form_with url: assign_follow_up_path(@follow_up), method: :patch,
            class: "follow-up-assign-form",
            data: { controller: "auto-submit" } do %>
        <%= select_tag :assigned_to_id,
              options_from_collection_for_select(User.order(:email_address), :id, ->(u) { user_display_name(u) }, @follow_up.assigned_to_id),
              include_blank: "Unassigned",
              data: { action: "change->auto-submit#submit" },
              "aria-label": "Assign to" %>
        <noscript><%= submit_tag "Assign", class: "button small" %></noscript>
      <% end %>
    <% end %>
  </section>

  <% if @follow_up.origin.is_a?(LogBookResponse) %>
    <section class="follow-up-detail-section">
      <h2 class="follow-up-detail-section-title">Origin</h2>
      <p class="muted small">
        Flagged in the Log Book on
        <%= link_to @follow_up.origin.log_book_entry.operating_date.strftime("%B %-d, %Y"),
              log_book_path(date: @follow_up.origin.log_book_entry.operating_date) %>.
      </p>
    </section>
  <% end %>

  <section class="follow-up-detail-section">
    <h2 class="follow-up-detail-section-title">Notes</h2>

    <% if @follow_up.notes.any? %>
      <ol class="follow-up-thread">
        <% @follow_up.notes.each do |note| %>
          <li class="follow-up-note">
            <div class="follow-up-note-meta">
              <strong><%= note.author ? user_display_name(note.author) : "Unknown" %></strong>
              <span class="muted small"><%= note.created_at.strftime("%b %-d · %-l:%M %p") %></span>
            </div>
            <div class="follow-up-note-body"><%= simple_format(note.body) %></div>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="muted small">No notes yet.</p>
    <% end %>

    <% unless @follow_up.resolved? %>
      <%= form_with url: follow_up_notes_path(@follow_up), class: "follow-up-note-form" do |f| %>
        <div class="field">
          <%= label_tag "follow_up_note[body]", "Add a note" %>
          <%= text_area_tag "follow_up_note[body]", nil, rows: 2, required: true %>
        </div>
        <div class="follow-up-note-form-footer">
          <%= submit_tag "Post note", class: "button small" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <section class="follow-up-detail-section">
    <h2 class="follow-up-detail-section-title">Tasks spawned</h2>
    <% if @follow_up.task_links.any? %>
      <ul class="follow-up-task-links">
        <% @follow_up.task_links.includes(task: :task_list).each do |link| %>
          <li>
            <%# Link the spawned task to its definition so you can reach what you
                created — same destination every other task listing uses (_manage_row).
                Carry origin=follow_up so the edit page's back arrow + post-save
                redirect return here, not into the Settings management tree. %>
            <%= link_to edit_tasks_manage_task_path(link.task, origin: "follow_up", follow_up_id: @follow_up.id), class: "follow-up-task-link" do %>
              <strong><%= link.task.title %></strong>
              <span class="muted small">· <%= link.link_kind.humanize %> · in <%= link.task.task_list.name %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted small">No tasks spawned from this follow-up yet.</p>
    <% end %>

    <% unless @follow_up.resolved? %>
      <%# @spawn is set only when a spawn attempt failed validation: repopulate the
          form with what was typed and open the disclosure so the user doesn't lose it. %>
      <details class="follow-up-spawn"<%= " open".html_safe if @spawn_errors %>>
        <summary class="button small">Create task from this follow-up</summary>
        <%= form_with url: spawn_task_follow_up_path(@follow_up), method: :post, class: "stacked-form",
              data: { controller: "follow-up-spawn" } do %>
          <% if @spawn_errors %>
            <div class="form-errors" role="alert">
              <strong><%= pluralize(@spawn_errors.count, "error") %> kept this task from saving:</strong>
              <ul>
                <% @spawn_errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="field">
            <%= label_tag "spawn[title]", "Task title" %>
            <%= text_field_tag "spawn[title]", (@spawn && @spawn[:title].presence) || @follow_up.title, required: true %>
          </div>
          <div class="field">
            <%= label_tag "spawn[description]", "Instructions (optional)" %>
            <%= text_area_tag "spawn[description]", (@spawn && @spawn[:description]) || @follow_up.description, rows: 2 %>
          </div>
          <div class="field">
            <%= label_tag "spawn[link_kind]", "Kind" %>
            <%= select_tag "spawn[link_kind]",
                  options_for_select([
                    ["One-shot (in 'Follow-up tasks')",      "one_shot"],
                    ["Recurring (in a list of your choice)", "recurring"]
                  ], (@spawn && @spawn[:link_kind]) || "one_shot"),
                  data: { follow_up_spawn_target: "kind", action: "change->follow-up-spawn#sync" } %>
          </div>
          <div class="field" data-follow-up-spawn-target="oneShotField">
            <%= label_tag "spawn[one_time_on]", "Due date" %>
            <%= date_field_tag "spawn[one_time_on]", (@spawn && @spawn[:one_time_on].presence) || Date.current %>
          </div>
          <div class="field" hidden data-follow-up-spawn-target="recurringField">
            <%= label_tag "spawn[task_list_id]", "Task list" %>
            <%= select_tag "spawn[task_list_id]",
                  options_from_collection_for_select(TaskList.active.ordered, :id, :name, @spawn && @spawn[:task_list_id]) %>
          </div>
          <div class="field" hidden data-follow-up-spawn-target="recurringField">
            <%= label_tag "spawn[recurrence_type]", "How often?" %>
            <%= select_tag "spawn[recurrence_type]",
                  options_for_select([
                    ["Daily",   "daily"],
                    ["Weekly",  "weekly"],
                    ["Monthly", "monthly"]
                  ], (@spawn && @spawn[:recurrence_type]) || "daily"),
                  data: { follow_up_spawn_target: "recurrence", action: "change->follow-up-spawn#sync" } %>
          </div>
          <div class="field" hidden data-follow-up-spawn-target="weeklyField">
            <span class="field-label">Repeat on</span>
            <div class="weekday-checks">
              <% selected_weekdays = @spawn ? Array(@spawn[:weekdays]).map(&:to_i) : [ Date.current.wday ] %>
              <% %w[Sun Mon Tue Wed Thu Fri Sat].each_with_index do |day, idx| %>
                <label class="check">
                  <%= check_box_tag "spawn[weekdays][]", idx, selected_weekdays.include?(idx) %>
                  <span><%= day %></span>
                </label>
              <% end %>
            </div>
          </div>
          <div class="field">
            <%= label_tag "spawn[due_time]", "Due time" %>
            <%= time_field_tag "spawn[due_time]", (@spawn && @spawn[:due_time].presence) || "17:00" %>
          </div>
          <label class="check">
            <%= check_box_tag "spawn[auto_resolve]", "1", @spawn ? @spawn[:auto_resolve] == "1" : true %>
            <span>Resolve this follow-up after creating the task</span>
          </label>
          <div class="form-footer">
            <%= submit_tag "Create task", class: "button primary" %>
          </div>
        <% end %>
      </details>
    <% end %>
  </section>

  <% if @follow_up.resolved? %>
    <section class="follow-up-detail-section follow-up-detail-resolved">
      <h2 class="follow-up-detail-section-title">Resolved</h2>
      <p class="muted small">
        <%= @follow_up.resolved_at.strftime("%B %-d, %Y · %-l:%M %p") %>
        <% if @follow_up.resolved_by %>
          by <%= user_display_name(@follow_up.resolved_by) %>
        <% end %>
        <% if @follow_up.resolved_via.present? %>
          · <%= @follow_up.resolved_via.humanize %>
        <% end %>
      </p>
      <% if @follow_up.resolution_note.present? %>
        <div><%= simple_format(@follow_up.resolution_note) %></div>
      <% end %>
    </section>

    <div class="form-footer">
      <%# Reopening discards the resolution (outcome, who/when, and the note), so
          guard the tap like every other irreversible control and say what's lost. %>
      <%= button_to "Reopen", reopen_follow_up_path(@follow_up), method: :patch, class: "button small",
            form: { data: { turbo_confirm: reopen_confirm_message(@follow_up) } } %>
    </div>
  <% else %>
    <section class="follow-up-detail-section">
      <h2 class="follow-up-detail-section-title">Resolve</h2>
      <%= form_with url: resolve_follow_up_path(@follow_up), method: :patch, class: "stacked-form" do |f| %>
        <div class="field">
          <%= label_tag :resolved_via, "What happened?" %>
          <%= select_tag :resolved_via,
                options_for_select(FollowUp::RESOLUTION_KINDS.map { |k| [k.humanize, k] }, "action_taken") %>
        </div>
        <div class="field">
          <%= label_tag :resolution_note, "Note (optional)" %>
          <%= text_area_tag :resolution_note, nil, rows: 2 %>
        </div>
        <%= submit_tag "Mark resolved", class: "button primary" %>
      <% end %>
    </section>
  <% end %>
</article>
