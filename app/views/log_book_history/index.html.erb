<% content_for :title, "Log Book history" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Shift), skipping
    Log Book — so it would overshoot the parent and contradict the "Back to Log
    Book" button below. Send it up exactly one level, to Log Book. %>
<% content_for :mobile_left_action do %>
  <%= link_to log_book_path, class: "mobile-header-back", aria: { label: "Back to Log Book" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Log Book</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Log Book history</h1>
    <p class="muted">Past days. Open one to review the entries and any open follow-ups.</p>
  </div>
  <div class="actions">
    <%= link_to "Back to Log Book", log_book_path, class: "button small" %>
  </div>
</div>

<section class="block-panel">
  <% if @entries.any? %>
    <ul class="log-book-recent">
      <% @entries.each do |entry| %>
        <% open_flags  = entry.log_book_responses.count { |r| r.flagged_for_follow_up? && r.follow_up_resolved_at.blank? } %>
        <% urgent_open = entry.log_book_responses.count { |r| r.flagged_for_follow_up? && r.follow_up_resolved_at.blank? && r.urgency == "urgent" } %>
        <li class="log-book-recent-row <%= 'log-book-recent-row-flagged' if open_flags.positive? %>">
          <%= link_to log_book_path(date: entry.operating_date), class: "log-book-recent-link" do %>
            <span class="log-book-recent-date"><%= entry.operating_date.strftime("%a %b %-d, %Y") %></span>
            <span class="log-book-recent-signals">
              <% if open_flags.zero? %>
                <span class="muted small">No open flags</span>
              <% else %>
                <span class="badge badge-warning"><%= pluralize(open_flags, "follow-up") %></span>
                <% if urgent_open.positive? %>
                  <span class="badge badge-warning"><%= urgent_open %> urgent</span>
                <% end %>
              <% end %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="empty-state">No log book entries yet. Today's save will appear here tomorrow.</p>
  <% end %>
</section>
