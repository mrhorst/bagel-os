<% content_for :title, "New user" %>

<% content_for :mobile_left_action do %>
  <%= link_to admin_users_path, class: "mobile-header-back", aria: { label: "Back to users" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Users</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>New user</h1>
    <p>Create an account and pick the modules they should see.</p>
  </div>
</section>

<section class="panel narrow">
  <%= render "form", user: @user, submit_label: "Create user" %>
</section>
