<% content_for :title, "Users" %>

<section class="page-heading">
  <div>
    <h1>Users</h1>
    <p>Manage who can sign in and which modules each person can see.</p>
  </div>
  <div class="actions">
    <%= link_to "New user", new_admin_user_path, class: "button primary" %>
  </div>
</section>

<section class="panel">
  <table class="responsive-table">
    <thead>
      <tr>
        <th>Email</th>
        <th>Name</th>
        <th>Role</th>
        <th>Modules</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="row-heading" data-label="Email">
            <strong><%= user.email_address %></strong>
            <% if user.owner? %><span class="badge badge-ok">Owner</span><% end %>
          </td>
          <td data-label="Name"><%= user.name.presence || content_tag(:span, "—", class: "muted") %></td>
          <td data-label="Role">
            <span class="badge"><%= user.role.titleize %></span>
          </td>
          <td data-label="Modules">
            <% if user.admin? %>
              <%# "All (admin)" is present, load-bearing access — the widest a
                  user can have — so it renders at full ink like the concrete
                  module list below, not in the muted/small style this app
                  reserves for absence ("No access", an empty name "—"). The
                  role-derived qualifier stays parenthetical + muted so the
                  meaningful word "All" leads. %>
              All <span class="muted">(admin)</span>
            <% else %>
              <% mods = user.accessible_modules %>
              <%= mods.any? ? mods.map { |m| m.titleize }.join(", ") : content_tag(:span, "No access", class: "muted small") %>
            <% end %>
          </td>
          <td class="row-actions" data-label="">
            <%= link_to "Edit", edit_admin_user_path(user), class: "button small" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
