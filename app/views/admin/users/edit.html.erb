<% content_for :title, "Edit user" %>

<% content_for :mobile_left_action do %>
  <%= link_to admin_users_path, class: "mobile-header-back", aria: { label: "Back to users" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Users</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Edit user</h1>
    <p><%= @user.email_address %><% if @user.owner? %> · <span class="badge">Owner</span><% end %></p>
  </div>
  <div class="actions">
    <%= link_to "Back to users", admin_users_path, class: "button small" %>
  </div>
</section>

<section class="panel narrow">
  <%= render "form", user: @user, submit_label: "Save changes" %>
</section>

<% unless @user.owner? || @user == Current.user %>
  <section class="panel narrow">
    <h2>Delete user</h2>
    <p class="muted">Removes the account and revokes their access. Their past task completions are preserved.</p>
    <%= button_to "Delete user", admin_user_path(@user), method: :delete,
          class: "button",
          data: { turbo_confirm: "Delete #{@user.email_address}?" } %>
  </section>
<% end %>

<% if Current.user.owner? && !@user.owner? %>
  <section class="panel narrow panel-danger-zone">
    <h2>Transfer ownership</h2>
    <p>You are the current owner. Transferring makes this user the new owner and demotes you to admin. Only an owner can transfer ownership.</p>
    <%= button_to "Transfer ownership to #{@user.email_address}",
          transfer_ownership_admin_user_path(@user),
          method: :post,
          class: "button",
          data: { turbo_confirm: "Transfer ownership to #{@user.email_address}? You will no longer be the owner." } %>
  </section>
<% end %>
