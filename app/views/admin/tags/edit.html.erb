<% content_for :title, "Edit tag" %>

<% content_for :mobile_left_action do %>
  <%= link_to admin_tags_path, class: "mobile-header-back", aria: { label: "Back to tags" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Tags</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Edit tag</h1>
    <p><%= @tag.name %></p>
  </div>
  <div class="actions">
    <%= link_to "Back to tags", admin_tags_path, class: "button small" %>
  </div>
</section>

<section class="panel narrow">
  <%= render "form", tag: @tag %>
</section>

<section class="panel narrow panel-danger-zone">
  <h2>Delete tag</h2>
  <p class="muted">Removes this tag from the vocabulary and from every photo it's on. Captions and notes stay.</p>
  <%= button_to "Delete tag", admin_tag_path(@tag), method: :delete,
        class: "button",
        data: { turbo_confirm: "Delete #{@tag.name}? It will be removed from all photos." } %>
</section>
