<%= form_with model: tag, url: (tag.persisted? ? admin_tag_path(tag) : admin_tags_path), class: "stacked-form" do |form| %>
  <% if tag.errors.any? %>
    <div class="flash flash-alert">
      <strong><%= pluralize(tag.errors.count, "error") %> kept this from saving:</strong>
      <ul><% tag.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name, required: true, autocomplete: "off", placeholder: "Food" %>
  </div>

  <div class="field">
    <%= form.label :slug %>
    <p class="muted small">The exact value the AI tagger returns. Leave blank to derive it from the name.</p>
    <%= form.text_field :slug, autocomplete: "off", placeholder: "food" %>
  </div>

  <div class="field">
    <%= form.label :instruction, "Rule for the AI tagger" %>
    <p class="muted small">When should this tag apply? e.g. "Plated dishes, ingredients, and drinks — anything edible."</p>
    <%= form.text_area :instruction, rows: 3 %>
  </div>

  <div class="field-row">
    <div class="field">
      <%= form.label :position, "Order" %>
      <%= form.number_field :position %>
    </div>
    <label class="check">
      <%= form.check_box :active %>
      <span>Active</span>
    </label>
  </div>

  <div class="form-footer">
    <%= link_to "Cancel", admin_tags_path, class: "button" %>
    <%= form.submit (tag.persisted? ? "Save changes" : "Create tag"), class: "button primary" %>
  </div>
<% end %>
