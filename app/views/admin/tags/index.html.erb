<% content_for :title, "Marketing tags" %>

<%# Marketing tags isn't a registered nav module, so the mobile header's auto
    back-chevron never fires here — and on mobile this page is only reachable via
    "Manage tags" in the photo library. Without this override the screen renders
    no header back affordance at all (its own new/edit children point "Tags" back
    here, but the index would strand the user), so mirror the library chevron its
    siblings use to send the manager one level up to the library. %>
<% content_for :mobile_left_action do %>
  <%= link_to photo_assets_path, class: "mobile-header-back", aria: { label: "Back to library" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Library</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Marketing tags</h1>
    <p>The vocabulary your photos are filed under. Each rule tells the AI tagger when to suggest a tag.</p>
  </div>
  <div class="actions">
    <%= link_to "New tag", new_admin_tag_path, class: "button primary" %>
  </div>
</section>

<% if @tags.any? %>
  <section class="panel">
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Tag</th>
          <th>Slug</th>
          <th>Rule for the AI tagger</th>
          <th>Photos</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @tags.each do |tag| %>
          <tr>
            <td data-label="Tag"><%= tag.name %></td>
            <td data-label="Slug"><code><%= tag.slug %></code></td>
            <td data-label="Rule" class="muted"><%= tag.instruction.presence || "—" %></td>
            <td data-label="Photos" class="tnum"><%= @usage.fetch(tag.id, 0) %></td>
            <td data-label="Status">
              <span class="badge <%= "badge-ok" if tag.active? %>"><%= tag.active? ? "Active" : "Inactive" %></span>
            </td>
            <td data-label="">
              <%= link_to "Edit", edit_admin_tag_path(tag), class: "button small" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% else %>
  <article class="panel empty-state">
    <strong>No tags yet.</strong>
    <span>Add the first one to start filing photos.</span>
  </article>
<% end %>
