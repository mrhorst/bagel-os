<%= form_with model: collection, url: (collection.persisted? ? collection_path(collection) : collections_path), class: "stacked-form" do |form| %>
  <% if collection.errors.any? %>
    <div class="flash flash-alert">
      <strong><%= pluralize(collection.errors.count, "error") %> kept this from saving:</strong>
      <ul><% collection.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name, required: true, autocomplete: "off", placeholder: "Summer menu shoot" %>
  </div>

  <div class="field">
    <%= form.label :slug %>
    <p class="muted small">Used in the collection's web address. Leave blank to derive it from the name.</p>
    <%= form.text_field :slug, autocomplete: "off", placeholder: "summer-menu-shoot" %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 3, placeholder: "What this set is for — a campaign, a shoot, the photos cleared for Instagram." %>
  </div>

  <div class="field">
    <%= form.label :position, "Order" %>
    <%= form.number_field :position %>
  </div>

  <div class="form-footer">
    <%= link_to "Cancel", (collection.persisted? ? collection_path(collection) : collections_path), class: "button" %>
    <%= form.submit (collection.persisted? ? "Save changes" : "Create collection"), class: "button primary" %>
  </div>
<% end %>
