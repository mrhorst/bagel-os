<% content_for :title, "Collections" %>

<%# Collections live under the Marketing photo library but aren't a nav module,
    so the mobile header has no auto back-chevron. Mirror the in-content
    "Back to library" control as the standard top-left affordance. %>
<% content_for :mobile_left_action do %>
  <%= link_to photo_assets_path, class: "mobile-header-back", aria: { label: "Back to library" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Library</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Collections</h1>
    <p>Group photos into campaigns or albums — a seasonal shoot, an Instagram set, the new menu. A photo can live in several at once.</p>
  </div>
  <div class="hero-actions">
    <%= link_to "Back to library", photo_assets_path, class: "button" %>
    <%# On mobile the floating action button (bottom of this view) is the
        canonical "add" affordance, so this inline primary button is hidden
        there to avoid a duplicate "New collection" CTA; it stays on desktop,
        which has no FAB. Mirrors the Photo library sibling. %>
    <%= link_to "New collection", new_collection_path, class: "button primary hide-for-fab" %>
  </div>
</section>

<% if @collections.any? %>
  <ul class="collection-grid" aria-label="Collections">
    <% @collections.each do |collection| %>
      <li>
        <%= link_to collection_path(collection), class: "collection-card" do %>
          <div class="collection-cover">
            <% if (cover = collection.cover_asset) %>
              <%= photo_asset_image cover, { resize_to_fill: [ 480, 360 ] }, alt: collection.name, loading: "lazy" %>
            <% else %>
              <span class="collection-cover-empty" aria-hidden="true">📷</span>
            <% end %>
          </div>
          <div class="collection-card-meta">
            <span class="collection-card-name"><%= collection.name %></span>
            <span class="muted small tnum"><%= pluralize(@counts.fetch(collection.id, 0), "photo") %></span>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <article class="panel empty-state">
    <strong>No collections yet.</strong>
    <span>Create one to group a campaign or shoot — a seasonal set, an album, the new menu.</span>
  </article>
<% end %>

<%= mobile_fab_button new_collection_path, label: "New collection" %>
