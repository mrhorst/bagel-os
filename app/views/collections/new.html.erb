<% content_for :title, "New collection" %>

<%# No nav-module auto-chevron on collections pages; mirror the form's
    "Cancel" target as the mobile top-left back affordance. %>
<% content_for :mobile_left_action do %>
  <%= link_to collections_path, class: "mobile-header-back", aria: { label: "Back to collections" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Collections</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>New collection</h1>
    <p>Name a group of photos — you'll add photos to it from the library.</p>
  </div>
</section>

<article class="panel narrow">
  <%= render "form", collection: @collection %>
</article>
