<% content_for :title, "Review queue" %>

<section class="page-heading">
  <div>
    <h1>Review queue</h1>
    <p>Rows here need human judgment before they should be treated as fully normalized purchasing data.</p>
  </div>
  <div class="actions">
    <% if @pending_count.positive? %>
      <span class="badge"><%= pluralize(@pending_count, "open review") %></span>
    <% end %>
    <% if @view == "focus" && @pending_count > 1 %>
      <%= link_to "Show all", normalization_reviews_path(view: "list"), class: "button small" %>
    <% elsif @view == "list" %>
      <%= link_to "Focus mode", normalization_reviews_path, class: "button small" %>
    <% end %>
  </div>
</section>

<% if @pending_count.zero? %>
  <article class="panel empty-state">
    <strong>Nothing pending.</strong>
    <span>The queue is empty — new conflicts appear here when receipt imports can't auto-resolve a product or unit.</span>
  </article>
<% elsif @view == "focus" %>
  <section class="review-focus" aria-label="Current review">
    <%# The progress panel only earns its space with more than one review to move
        through. At a single pending review "Review 1 of 1" is inert — it repeats
        the header's "1 open review" count and implies a multi-item queue that
        isn't there, while the Skip button (already gated below) is a no-op that
        wraps back to the same card. So show the whole panel only when there's a
        real position to report; otherwise the review card sits directly under
        the heading. Skip stays gated on the same @pending_count > 1. %>
    <% if @pending_count > 1 %>
      <div class="review-focus-progress">
        <span><strong>Review <%= @position %></strong> of <%= @pending_count %></span>
        <%= button_to "Skip", skip_normalization_review_path(@current_review), method: :patch, class: "button small" %>
      </div>
    <% end %>
    <%= render "review_card", review: @current_review, products: @products, categories: @categories %>
  </section>
<% else %>
  <section class="review-list">
    <% @reviews.each do |review| %>
      <%= render "review_card", review: review, products: @products, categories: @categories %>
    <% end %>
  </section>
<% end %>
