<% content_for :title, "Reports" %>

<section class="page-heading">
  <div>
    <h1>Reports / exports</h1>
    <p>Download normalized purchasing data as CSV files for review, spreadsheets, or accounting support.</p>
  </div>
</section>

<article class="panel">
  <table class="responsive-table">
    <thead>
      <tr>
        <th>Report</th>
        <th>Description</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @reports.each do |report| %>
        <tr>
          <td data-label="Report"><%= report.humanize %> <span class="muted small">(<code><%= report %>.csv</code>)</span></td>
          <td data-label="Description"><%= report_description(report) %></td>
          <td class="numeric" data-label=""><%= link_to "Download", report_path(report), class: "button" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>
