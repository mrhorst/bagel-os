<% content_for :title, "Reports / exports" %>

<section class="page-heading">
  <div>
    <h1>Reports / exports</h1>
    <p>Download normalized purchasing data as CSV files for review, spreadsheets, or accounting support.</p>
  </div>
</section>

<article class="panel">
  <table class="responsive-table">
    <thead>
      <tr>
        <th>Report</th>
        <th>Description</th>
        <%# The action column stays visually unlabelled to match the table's clean
            header, but an empty <th> reads as a nameless column to assistive tech.
            An sr-only label names it without changing the visible layout. %>
        <th><span class="sr-only">Download</span></th>
      </tr>
    </thead>
    <tbody>
      <% @reports.each do |report| %>
        <tr>
          <td class="row-heading" data-label="Report"><strong><%= report.humanize %></strong> <code><%= report %>.csv</code></td>
          <%# No data-label here: on mobile the responsive-table card already reads
              name → filename → prose, and a single self-evident description needs
              no "DESCRIPTION" eyebrow (the same logic the .row-heading label-drop
              uses). Omitting it keeps the action cell's no-eyebrow treatment. %>
          <td><%= report_description(report) %></td>
          <%# Fetch-and-share the CSV via download_controller instead of a plain
              attachment link: a same-window nav to an attachment strands a
              chrome-less installed PWA on a page it can't render. target=_blank
              is the no-JS fallback. See download_controller.js. %>
          <%# Every row's link reads "Download" out of context; name the report in
              the accessible label so the seven exports are distinguishable to
              screen-reader users (WCAG 2.4.4). The visible word stays "Download". %>
          <td class="numeric"><%= link_to "Download", report_path(report),
                class: "button", target: "_blank", rel: "noopener",
                "aria-label": "Download #{report.humanize} CSV",
                data: { controller: "download", action: "download#save",
                        download_filename_value: "#{report}.csv" } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>
