<% content_for :title, "Reports / exports" %>

<section class="page-heading">
  <div>
    <h1>Reports / exports</h1>
    <p>Download normalized purchasing data as CSV files for review, spreadsheets, or accounting support.</p>
  </div>
</section>

<article class="panel">
  <table class="responsive-table">
    <thead>
      <tr>
        <th>Report</th>
        <th>Description</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @reports.each do |report| %>
        <tr>
          <td class="row-heading" data-label="Report"><strong><%= report.humanize %></strong> <code><%= report %>.csv</code></td>
          <td data-label="Description"><%= report_description(report) %></td>
          <%# Fetch-and-share the CSV via download_controller instead of a plain
              attachment link: a same-window nav to an attachment strands a
              chrome-less installed PWA on a page it can't render. target=_blank
              is the no-JS fallback. See download_controller.js. %>
          <td class="numeric"><%= link_to "Download", report_path(report),
                class: "button", target: "_blank", rel: "noopener",
                data: { controller: "download", action: "download#save",
                        download_filename_value: "#{report}.csv" } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>
