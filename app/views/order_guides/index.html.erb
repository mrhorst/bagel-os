<% content_for :title, "Order Guides" %>

<%
  guides_count = @order_guides.count
  memberships_count = OrderGuideMembership.active.count
  inventory_count = InventoryItem.active.count
  off_guide_count = @missing_products.size
%>

<div class="page-heading">
  <div>
    <h1>Order Guides</h1>
    <p>Named operating lists for purchasing, counted inventory, and staff ordering workflows.</p>
  </div>
  <div class="actions">
    <%= link_to "CSV example", csv_example_order_guides_path, class: "button small" %>
    <%= link_to "Inventory", inventory_path, class: "button small" %>
  </div>
</div>

<section class="metric-grid">
  <div class="metric">
    <span>Named guides</span>
    <strong><%= guides_count %></strong>
  </div>
  <div class="metric">
    <span>Guide memberships</span>
    <strong><%= memberships_count %></strong>
  </div>
  <div class="metric">
    <span>Inventory items</span>
    <strong><%= inventory_count %></strong>
  </div>
  <div class="metric">
    <span>Receipt products not on guide</span>
    <strong><%= off_guide_count %></strong>
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Named Guides</h2>
      <p class="muted">Use practical names staff recognize, like Daily, Every 2 weeks, Cleaning Supplies, or Weekend Prep.</p>
    </div>
  </div>

  <% if @order_guides.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Name</th>
          <th class="numeric">Active items</th>
          <th>Status</th>
          <th>Items</th>
          <th>Rename</th>
          <th>Archive</th>
        </tr>
      </thead>
      <tbody>
        <% @order_guides.each do |guide| %>
          <tr>
            <td class="row-heading" data-label="Name"><strong><%= guide.name %></strong></td>
            <td class="numeric" data-label="Active items"><%= guide.active_item_count %></td>
            <td data-label="Status"><span class="badge <%= guide.active? ? 'badge-ok' : '' %>"><%= guide.active? ? "Active" : "Archived" %></span></td>
            <td data-label="Items"><%= link_to "View items", order_guide_path(guide), class: "button small" %></td>
            <td data-label="Rename">
              <%= form_with model: guide, class: "inline-guide-form" do |form| %>
                <%= form.label :name, "Guide name", class: "sr-only" %>
                <%= form.text_field :name, value: guide.name, class: "compact-input" %>
                <%= form.submit "Save", class: "button small" %>
              <% end %>
            </td>
            <td data-label="Archive">
              <% if guide.active? %>
                <%= button_to "Archive", order_guide_path(guide), method: :delete, class: "button small",
                      data: { turbo_confirm: "Archive #{guide.name}? Its #{pluralize(guide.active_item_count, "item")} will be removed from the guide." } %>
              <% else %>
                <span class="muted">Archived</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No named guides yet. Create the first one below.</p>
  <% end %>
</section>

<section class="panel narrow">
  <h2>Create Guide</h2>
  <%= form_with model: OrderGuide.new, class: "stacked-form" do |form| %>
    <div class="field">
      <%= form.label :name, "Guide name" %>
      <%= form.text_field :name, placeholder: "Daily, Every 2 weeks, Weekend Prep…" %>
    </div>
    <div class="field">
      <%= form.label :notes, "Notes" %>
      <%= form.text_area :notes, rows: 3, placeholder: "Optional staff note for how this guide is used." %>
    </div>
    <%= form.submit "Create guide", class: "button primary" %>
  <% end %>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Items By Guide</h2>
      <p class="muted">Open a guide to review the full operating list, or use Inventory Items to change an item's primary guide.</p>
    </div>
    <%= link_to "Inventory items", inventory_items_path, class: "button small" %>
  </div>

  <% if @order_guides.any? %>
    <div class="grid two">
      <% @order_guides.each do |guide| %>
        <% memberships = guide.order_guide_memberships.select(&:active?).sort_by { |membership| [ membership.position, membership.inventory_item.name ] } %>
        <section class="guide-card">
          <div class="panel-heading">
            <div>
              <h3><%= link_to guide.name, order_guide_path(guide) %></h3>
              <p class="muted"><%= pluralize(memberships.size, "active item") %></p>
            </div>
            <%= link_to "Open", order_guide_path(guide), class: "button small" %>
          </div>

          <% if memberships.any? %>
            <table class="responsive-table">
              <thead>
                <tr>
                  <th>Item</th>
                  <th>Guide section</th>
                  <th>Pack / count</th>
                </tr>
              </thead>
              <tbody>
                <% memberships.first(8).each do |membership| %>
                  <% item = membership.inventory_item %>
                  <tr>
                    <td class="row-heading" data-label="Item">
                      <strong><%= item.name %></strong>
                      <% if membership.primary_guide? %>
                        <span class="badge badge-ok badge-compact">Primary</span>
                      <% end %>
                    </td>
                    <td data-label="Guide section"><%= membership.order_guide_section&.name || item.inventory_section&.name || "Unsectioned" %></td>
                    <td data-label="Pack / count"><%= item.pack_size.presence || item.count_unit.presence || "n/a" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
            <% if memberships.size > 8 %>
              <p class="field-hint"><%= link_to "View all #{memberships.size} items", order_guide_path(guide) %></p>
            <% end %>
          <% else %>
            <p class="empty-state">No inventory items assigned to this guide yet.</p>
          <% end %>
        </section>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">Create a guide, then assign inventory items from the Master Inventory page.</p>
  <% end %>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Receipt Products Not On Current Guides</h2>
      <p class="muted">This is the list to review when deciding what should become an operating inventory item or guide membership.</p>
    </div>
  </div>

  <% if @missing_products.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Review signal</th>
          <th class="numeric">Buys</th>
          <th class="numeric">Spend</th>
          <th>Last bought</th>
          <th>Add to guide</th>
        </tr>
      </thead>
      <tbody>
        <% @missing_products.each do |row| %>
          <tr>
            <td data-label="Product"><%= link_to row.product.canonical_name, product_path(row.product) %></td>
            <td data-label="Category"><%= row.product.category_name %></td>
            <td data-label="Review signal">
              <span class="badge <%= row.classification == 'review_for_guide' ? 'badge-warning' : '' %>">
                <%= row.classification.humanize %>
              </span>
              <small><%= row.reason %></small>
            </td>
            <td class="numeric" data-label="Buys"><%= row.purchase_count %></td>
            <td class="numeric" data-label="Spend"><%= number_to_currency(row.total_spend) %></td>
            <td data-label="Last bought"><%= row.last_purchased_at&.to_date || "n/a" %></td>
            <td data-label="Add to guide">
              <% if @order_guides.active.any? %>
                <%= form_with url: product_order_guide_memberships_path(row.product), scope: :membership, class: "guide-gap-form" do |form| %>
                  <%= form.collection_select :order_guide_id, @order_guides.select(&:active?), :id, :name, { prompt: "Guide" }, { class: "compact-select", required: true } %>
                  <%= form.text_field :section_name, placeholder: "Section", class: "compact-input" %>
                  <%= form.select :tracking_mode, [["Counted", "counted"], ["Order only", "order_only"]], {}, { class: "compact-select" } %>
                  <%= form.submit "Add", class: "button small" %>
                <% end %>
              <% else %>
                <%= link_to "Create guide", order_guides_path, class: "button small" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No missing receipt products found for the current guide import.</p>
  <% end %>
</section>
