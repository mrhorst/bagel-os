<% content_for :title, "Log Sections" %>

<%# On mobile the top-left chevron is the primary back affordance. Sections is
    reached only from the Log Book Settings hub (which renders it alongside
    History), so "up one level" is Settings — not Log Book, which would overshoot
    the hub the user came from and skip its sibling History card. Matches the
    app's universal one-level-up convention. %>
<% content_for :mobile_left_action do %>
  <%= link_to log_book_settings_path, class: "mobile-header-back", aria: { label: "Back to Settings" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Settings</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Log Sections</h1>
    <p>Choose what appears in the daily Log Book. Archiving hides a section from new days; old entries keep their values.</p>
  </div>
  <%# On mobile the top-left chevron (mobile_left_action above) is the primary
      "Back to Settings" affordance, so this in-heading back button is a duplicate
      there — hide it on mobile via .log-book-heading-actions (the same pattern
      Log Book settings uses) and keep it as the desktop back path. It moves in
      lockstep with the chevron: up one level to the Settings hub. "New section"
      stays visible at every width. %>
  <div class="actions">
    <%= link_to "Back to Settings", log_book_settings_path, class: "button small log-book-heading-actions" %>
    <%= link_to "New section", new_log_book_section_path, class: "button primary small" %>
  </div>
</div>

<section class="block-panel">
  <% if @sections.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Section</th>
          <th>Type</th>
          <th class="numeric">Sort</th>
          <th>Status</th>
          <th class="numeric">Used in</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @sections.each do |section| %>
          <% usage_count = section.log_book_responses.count %>
          <tr>
            <td class="row-heading" data-label="Section">
              <strong><%= section.title %></strong>
              <% if section.description.present? %>
                <small><%= section.description %></small>
              <% end %>
            </td>
            <td data-label="Type"><%= section.section_type.humanize %></td>
            <td class="numeric" data-label="Sort"><%= section.position %></td>
            <td data-label="Status"><span class="badge <%= "badge-ok" if section.active? %>"><%= section.active? ? "Active" : "Archived" %></span></td>
            <td class="numeric" data-label="Used in">
              <%= pluralize(usage_count, "entry") %>
            </td>
            <%# Action-only cell: use an empty data-label so the mobile stacked
                card suppresses the redundant "ACTIONS" eyebrow above the obvious
                Edit/Archive buttons, matching every sibling table (admin/users,
                recipes, modifier_groups) and the documented .responsive-table
                td[data-label=""] rule. %>
            <td class="row-actions" data-label="">
              <%= link_to "Edit", edit_log_book_section_path(section), class: "button small" %>
              <% if section.active? %>
                <%= button_to "Archive",
                      archive_log_book_section_path(section),
                      method: :patch,
                      class: "button small",
                      data: { turbo_confirm: archive_confirm_message(section, usage_count) } %>
              <% else %>
                <%= button_to "Reactivate", reactivate_log_book_section_path(section), method: :patch, class: "button small" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">
      <strong>No Log Sections yet.</strong>
      <span>Create sections like General Log, Maintenance, or Bagels Left.</span>
    </p>
  <% end %>
</section>
