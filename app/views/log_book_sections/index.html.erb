<% content_for :title, "Log Sections" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Shift), skipping
    Log Book — so it would overshoot the parent and contradict the "Back to Log
    Book" button below. Send it up exactly one level, to Log Book. %>
<% content_for :mobile_left_action do %>
  <%= link_to log_book_path, class: "mobile-header-back", aria: { label: "Back to Log Book" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Log Book</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Log Sections</h1>
    <p>Choose what appears in the daily Log Book. Archiving hides a section from new days; old entries keep their values.</p>
  </div>
  <%# On mobile the top-left chevron (mobile_left_action above) is the primary
      "Back to Log Book" affordance, so this in-heading back button is a duplicate
      there — hide it on mobile via .log-book-heading-actions (the same pattern
      Log Book settings uses) and keep it as the desktop back path. "New section"
      stays visible at every width. %>
  <div class="actions">
    <%= link_to "Back to Log Book", log_book_path, class: "button small log-book-heading-actions" %>
    <%= link_to "New section", new_log_book_section_path, class: "button primary small" %>
  </div>
</div>

<section class="block-panel">
  <% if @sections.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Section</th>
          <th>Type</th>
          <th class="numeric">Sort</th>
          <th>Status</th>
          <th class="numeric">Used in</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @sections.each do |section| %>
          <% usage_count = section.log_book_responses.count %>
          <tr>
            <td class="row-heading" data-label="Section">
              <strong><%= section.title %></strong>
              <% if section.description.present? %>
                <small><%= section.description %></small>
              <% end %>
            </td>
            <td data-label="Type"><%= section.section_type.humanize %></td>
            <td class="numeric" data-label="Sort"><%= section.position %></td>
            <td data-label="Status"><%= section.active? ? "Active" : "Archived" %></td>
            <td class="numeric" data-label="Used in">
              <%= pluralize(usage_count, "entry") %>
            </td>
            <td class="numeric" data-label="Actions">
              <%= link_to "Edit", edit_log_book_section_path(section), class: "button small" %>
              <% if section.active? %>
                <%= button_to "Archive",
                      archive_log_book_section_path(section),
                      method: :patch,
                      class: "button small",
                      data: { turbo_confirm: archive_confirm_message(section, usage_count) } %>
              <% else %>
                <%= button_to "Reactivate", reactivate_log_book_section_path(section), method: :patch, class: "button small" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">
      <strong>No Log Sections yet.</strong>
      <span>Create sections like General Log, Maintenance, or Bagels Left.</span>
    </p>
  <% end %>
</section>
