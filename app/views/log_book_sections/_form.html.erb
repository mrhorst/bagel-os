<%= form_with model: section, url: url, method: method,
      class: "stacked-form",
      data: { controller: "log-book-section-form" } do |form| %>
  <% if section.errors.any? %>
    <div class="form-errors" role="alert">
      <strong><%= pluralize(section.errors.count, "error") %> kept this section from saving:</strong>
      <ul>
        <% section.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title, "Section label" %>
    <%= form.text_field :title, required: true, placeholder: "Maintenance" %>
  </div>

  <div class="field">
    <%= form.label :description, "Helper text" %>
    <%= form.text_area :description, rows: 3, placeholder: "What should the manager record here?" %>
  </div>

  <div class="form-grid">
    <div class="field">
      <%= form.label :section_type, "Input type" %>
      <%= form.select :section_type, LogBookSection::SECTION_TYPES.map { |type| [ type.humanize, type ] }, {},
            required: true,
            data: { log_book_section_form_target: "sectionType",
                    action: "change->log-book-section-form#sync" } %>
    </div>
    <div class="field">
      <%= form.label :position, "Sort order" %>
      <%= form.number_field :position, step: 1 %>
    </div>
    <div class="field" data-log-book-section-form-target="numberOnly">
      <%= form.label :unit_label, "Unit label" %>
      <%= form.text_field :unit_label, placeholder: "bagels, dollars, degrees F" %>
    </div>
    <div class="field" data-log-book-section-form-target="numberOnly">
      <%= form.label :value_decimals, "Decimal places" %>
      <%= form.number_field :value_decimals, in: 0..6, step: 1 %>
      <p class="field-hint muted small">0 = whole numbers.</p>
    </div>
  </div>

  <label class="check">
    <%= form.check_box :allow_no_note %>
    <span>Allow No note today</span>
  </label>

  <label class="check">
    <%= form.check_box :allow_follow_up %>
    <span>Allow Flag for follow-up (and urgency)</span>
  </label>

  <div class="form-footer">
    <%= link_to "Cancel", log_book_sections_path, class: "button" %>
    <%= form.submit submit_label, class: "button primary" %>
  </div>
<% end %>
