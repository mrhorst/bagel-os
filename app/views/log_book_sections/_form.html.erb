<%= form_with model: section, url: url, method: method,
      class: "stacked-form",
      data: { controller: "log-book-section-form" } do |form| %>
  <% if section.errors.any? %>
    <div class="form-errors" role="alert">
      <strong><%= pluralize(section.errors.count, "error") %> kept this section from saving:</strong>
      <ul>
        <% section.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title, "Section label" %>
    <%= form.text_field :title, required: true, placeholder: "Maintenance" %>
  </div>

  <div class="field">
    <%= form.label :description, "Helper text" %>
    <%= form.text_area :description, rows: 3, placeholder: "What should the manager record here?" %>
  </div>

  <div class="form-grid">
    <div class="field">
      <%= form.label :section_type, "Input type" %>
      <%= form.select :section_type, LogBookSection::SECTION_TYPES.map { |type|
            label = (type == "multi") ? "Multi-input (grid)" : type.humanize
            [ label, type ]
          }, {},
            required: true,
            data: { log_book_section_form_target: "sectionType",
                    action: "change->log-book-section-form#sync" } %>
    </div>
    <div class="field">
      <%= form.label :position, "Sort order" %>
      <%= form.number_field :position, step: 1 %>
    </div>
    <div class="field" data-log-book-section-form-target="numberOnly">
      <%= form.label :unit_label, "Unit label" %>
      <%= form.text_field :unit_label, placeholder: "bagels, dollars, degrees F" %>
    </div>
    <div class="field" data-log-book-section-form-target="numberOnly">
      <%= form.label :value_decimals, "Decimal places" %>
      <%= form.number_field :value_decimals, in: 0..6, step: 1 %>
      <p class="field-hint muted small">0 = whole numbers.</p>
    </div>
  </div>

  <%# Multi-input sub-fields manager ─────────────────────────────────── %>
  <div class="log-book-fields-manager" data-log-book-section-form-target="multiOnly"
       data-controller="log-book-fields"
       data-log-book-fields-prefix-value="log_book_section[fields][]">
    <h3 class="log-book-fields-manager-title">Inputs</h3>
    <p class="muted small">One input per row. Drag in <code>plain</code>, <code>sesame</code>, etc.</p>
    <ol class="log-book-fields-list" data-log-book-fields-target="list">
      <%# A multi-input section needs at least one input. Seed one blank starter
          row when there are none yet — so switching the type to Multi-input (or
          re-rendering after the "must have at least one input" error) presents a
          row to fill instead of an empty list with no obvious next step. %>
      <% rows = section.fields.presence || [ { "key" => "", "label" => "", "type" => "number", "unit_label" => "", "value_decimals" => 0 } ] %>
      <% rows.each do |field| %>
        <%= render "log_book_sections/field_row", field: field %>
      <% end %>
    </ol>
    <template data-log-book-fields-target="template">
      <%= render "log_book_sections/field_row", field: { "key" => "", "label" => "", "type" => "number", "unit_label" => "", "value_decimals" => 0 } %>
    </template>
    <button type="button" class="button small" data-action="log-book-fields#add">+ Add input</button>
  </div>

  <label class="check">
    <%= form.check_box :allow_no_note %>
    <span>Allow No note today</span>
  </label>

  <label class="check">
    <%= form.check_box :allow_follow_up %>
    <span>Allow Flag for follow-up (and urgency)</span>
  </label>

  <div class="form-footer">
    <%= link_to "Cancel", log_book_sections_path, class: "button" %>
    <%= form.submit submit_label, class: "button primary" %>
  </div>
<% end %>
