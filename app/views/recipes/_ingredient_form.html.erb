<%# locals: recipe, ingredient, inventory_items, submit_label, stacked (default false)

  Shared by the inline per-row edit and the "Add ingredient" form at the bottom
  of the recipe show page. A line can link to an inventory item OR carry a
  free-text name; amount and unit are optional and never inferred. %>
<% stacked = local_assigns.fetch(:stacked, false) %>
<%# The select offers only active inventory items, but a line may already be
    linked to an item that has since been archived (e.g. an order-guide re-import
    deactivates an item with no guide types or counts — see
    Purchasing::OrderGuideImporter). If we offered only the active list, that
    archived item would silently drop out of the dropdown: the line would read as
    "No item" even though it IS linked, and saving any edit would blank the link
    and fail validation with "Name can't be blank" — a dead end on a line that
    visibly has an inventory item. Keep the line's own linked item in its options
    (labelled archived) so it stays selected and the row remains editable. %>
<% item_options = inventory_items.to_a %>
<% linked_item = ingredient.inventory_item %>
<% if linked_item && item_options.exclude?(linked_item) %>
  <% item_options += [ linked_item ] %>
<% end %>
<% item_label = ->(item) { item.active? ? item.name : "#{item.name} (archived)" } %>
<%# Every row's inline edit form and the bottom "Add ingredient" form share this
    partial, so without a per-form namespace they'd all emit the same field ids
    (recipe_ingredient_name, …). Duplicate ids are invalid HTML and break
    `<label for>`: each label resolves to the FIRST matching field, so clicking a
    label here focused row 1's input instead of the field beneath it. Namespacing
    by the record's dom_id ("recipe_ingredient_5" / "new_recipe_ingredient") keeps
    every id unique and every label wired to its own field. The namespace touches
    only ids, not the `name` attributes, so submitted params are unchanged. %>
<%= form_with model: ingredient, namespace: dom_id(ingredient),
      url: (ingredient.persisted? ? recipe_ingredient_path(recipe, ingredient) : recipe_ingredients_path(recipe)),
      class: (stacked ? "stacked-form" : "inline-ingredient-form") do |form| %>
  <% if ingredient.errors.any? %>
    <% if stacked %>
      <div class="flash flash-alert"><%= ingredient.errors.full_messages.to_sentence %></div>
    <% else %>
      <p class="inline-form-error" role="alert"><%= ingredient.errors.full_messages.to_sentence %></p>
    <% end %>
  <% end %>

  <% if stacked %>
    <div class="field">
      <%= form.label :inventory_item_id, "Inventory item" %>
      <%= form.select :inventory_item_id,
            options_for_select(item_options.map { |i| [ item_label.call(i), i.id ] }, ingredient.inventory_item_id),
            { include_blank: "Not an inventory item" }, { class: "compact-select" } %>
    </div>
    <div class="field">
      <%= form.label :name, "Or type a name" %>
      <p class="muted small">Use this for something not tracked in inventory. Required only when no inventory item is chosen.</p>
      <%= form.text_field :name, autocomplete: "off", placeholder: "Chopped scallions" %>
    </div>
    <div class="form-grid">
      <div class="field">
        <%= form.label :quantity, "Amount" %>
        <%= form.number_field :quantity, step: "0.0001", min: "0", placeholder: "Leave blank if unknown" %>
      </div>
      <div class="field">
        <%= form.label :unit %>
        <%= form.text_field :unit, autocomplete: "off", placeholder: "cup, lb, each" %>
      </div>
    </div>
    <div class="form-footer">
      <%= form.submit submit_label, class: "button primary" %>
    </div>
  <% else %>
    <%= form.label :inventory_item_id, "Inventory item", class: "sr-only" %>
    <%= form.select :inventory_item_id,
          options_for_select(item_options.map { |i| [ item_label.call(i), i.id ] }, ingredient.inventory_item_id),
          { include_blank: "No item" }, { class: "compact-select" } %>
    <%= form.label :name, "Name", class: "sr-only" %>
    <%= form.text_field :name, class: "compact-input", autocomplete: "off", placeholder: "or name" %>
    <%= form.label :quantity, "Amount", class: "sr-only" %>
    <%= form.number_field :quantity, step: "0.0001", min: "0", class: "compact-input", placeholder: "amt" %>
    <%= form.label :unit, "Unit", class: "sr-only" %>
    <%= form.text_field :unit, class: "compact-input", autocomplete: "off", placeholder: "unit" %>
    <%= form.submit submit_label, class: "button small" %>
  <% end %>
<% end %>
