<% content_for :title, @recipe.name %>

<%# Send the mobile back-chevron up one level to the recipes index, rather than
    the layout's default jump to the Stock hub. %>
<% content_for :mobile_left_action do %>
  <%= link_to recipes_path, class: "mobile-header-back", aria: { label: "Back to recipes" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Recipes</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1><%= @recipe.name %></h1>
    <p>
      <span class="badge <%= "badge-ok" if @recipe.active? %>"><%= @recipe.active? ? "Active" : "Archived" %></span>
    </p>
  </div>
  <div class="hero-actions">
    <%= link_to "All recipes", recipes_path, class: "button" %>
    <%= link_to "Edit", edit_recipe_path(@recipe), class: "button primary" %>
  </div>
</section>

<% if @recipe.description.present? %>
  <section class="panel">
    <div class="note-block">
      <strong>Recipe notes</strong>
      <%= simple_format @recipe.description %>
    </div>
  </section>
<% end %>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Ingredients</h2>
      <p class="muted">Link a line to an inventory item where you can, and record the amount and unit. Leave the amount or unit blank when it isn't known — they're never guessed. Substitutes are alternatives for a line; the cost and weight estimates use the main line, not its substitutes.</p>
    </div>
  </div>

  <% if @ingredients.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Ingredient</th>
          <th>Amount</th>
          <th>Unit</th>
          <th class="numeric">Est. cost</th>
          <th class="numeric">Weight</th>
          <th>Edit</th>
          <th>Remove</th>
        </tr>
      </thead>
      <tbody>
        <% @ingredients.each do |ingredient| %>
          <%# When an inline edit is rejected, the controller hands back the
              invalid instance so the row keeps the typed values and shows the
              error instead of reverting. %>
          <% row = (@editing_ingredient if @editing_ingredient&.id == ingredient.id) || ingredient %>
          <% line_cost = @costing.cost_for(ingredient) %>
          <% line_weight = @weight.weight_for(ingredient) %>
          <tr id="ingredient-line-<%= ingredient.id %>">
            <td class="row-heading" data-label="Ingredient">
              <%= ingredient.display_name %>
              <% if ingredient.inventory_item %><span class="badge badge-compact">Inventory</span><% end %>
              <%= render "recipes/substitutes",
                    recipe: @recipe, ingredient: ingredient, inventory_items: @inventory_items,
                    new_substitute: (@new_substitute if @substitute_errors_for == ingredient.id) %>
            </td>
            <%# A blank amount is intentional ("never guessed"), not missing data —
                show the app's "—" blank marker like the Unit cell beside it, not
                compact_decimal's "n/a", which reads as a system error. %>
            <td data-label="Amount" class="tnum"><%= ingredient.quantity.present? ? compact_decimal(ingredient.quantity) : "—" %></td>
            <td data-label="Unit"><%= ingredient.unit.presence || "—" %></td>
            <td data-label="Est. cost" class="numeric">
              <% if line_cost&.costed? %>
                <span class="tnum"><%= money(line_cost.cost) %></span>
              <% else %>
                <%# Never invent a number — say why the line can't be costed. %>
                <span class="badge">Uncertain</span>
                <p class="muted small"><%= line_cost&.reason %></p>
              <% end %>
            </td>
            <td data-label="Weight" class="numeric">
              <% if line_weight&.weighed? %>
                <span class="tnum"><%= weight_in_grams(line_weight.grams) %></span>
              <% else %>
                <%# Weight has its own reasons (a volume can't be weighed), so show them. %>
                <span class="badge">Uncertain</span>
                <p class="muted small"><%= line_weight&.reason %></p>
              <% end %>
            </td>
            <td data-label="Edit">
              <%= render "recipes/ingredient_form",
                    recipe: @recipe, ingredient: row, inventory_items: @inventory_items, submit_label: "Save" %>
            </td>
            <td data-label="Remove">
              <%= button_to "Remove", recipe_ingredient_path(@recipe, ingredient), method: :delete, class: "button small",
                    data: { turbo_confirm: "Remove #{ingredient.display_name} from #{@recipe.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No ingredients yet. Add the first line below.</p>
  <% end %>

  <%# The summary also appears for an all-choices item (no fixed lines but
      ingredient-kind guest choices) — its cost lives entirely in the choices. %>
  <% if @ingredients.any? || @modifier_costing.groups.any? %>
    <div class="recipe-cost-summary">
      <%# Total cost — complete only when every line is costed. %>
      <% if @costing.complete? %>
        <div class="recipe-cost-total">
          <span>Total estimated cost</span>
          <strong class="tnum"><%= money(@costing.total) %></strong>
        </div>
      <% elsif @costing.costed_lines.any? %>
        <div class="recipe-cost-total">
          <span>Estimated cost so far<span class="muted"> (<%= @costing.costed_lines.size %> of <%= @costing.total_lines %> lines)</span></span>
          <strong class="tnum"><%= money(@costing.subtotal) %></strong>
        </div>
      <% else %>
        <div class="recipe-cost-total">
          <span>Total estimated cost</span>
          <strong class="muted">No estimate</strong>
        </div>
      <% end %>

      <%# Total weight — same partial/complete treatment as cost. %>
      <% if @weight.complete? %>
        <div class="recipe-cost-total">
          <span>Total weight</span>
          <strong class="tnum"><%= weight_in_grams(@weight.total_grams) %></strong>
        </div>
      <% elsif @weight.weighed_lines.any? %>
        <div class="recipe-cost-total">
          <span>Weight so far<span class="muted"> (<%= @weight.weighed_lines.size %> of <%= @weight.total_lines %> lines)</span></span>
          <strong class="tnum"><%= weight_in_grams(@weight.subtotal_grams) %></strong>
        </div>
      <% else %>
        <div class="recipe-cost-total">
          <span>Total weight</span>
          <strong class="muted">No estimate</strong>
        </div>
      <% end %>

      <%# Per-serving figures appear only with a yield and a complete total. %>
      <% if @recipe.yield_described? %>
        <% serving_unit = @recipe.yield_unit.presence || "serving" %>
        <% if @costing.cost_per_serving %>
          <div class="recipe-cost-total">
            <span>Cost per <%= serving_unit %><span class="muted"> (yield <%= compact_decimal(@recipe.yield_quantity) %>)</span></span>
            <strong class="tnum"><%= money(@costing.cost_per_serving) %></strong>
          </div>
        <% end %>
        <% if @weight.weight_per_serving_grams %>
          <div class="recipe-cost-total">
            <span>Weight per <%= serving_unit %></span>
            <strong class="tnum"><%= weight_in_grams(@weight.weight_per_serving_grams) %></strong>
          </div>
        <% end %>
      <% end %>

      <%# Guest choices: per ingredient-kind choice, the standard pick's cost
          and the swing across its options. Preparation choices never appear —
          they have no cost. Same never-guess rule as the lines above: a choice
          with any uncostable option is uncertain, with the reason. %>
      <% if @modifier_costing.groups.any? %>
        <% @modifier_costing.groups.each do |group_cost| %>
          <div class="recipe-cost-total">
            <span>
              <%= group_cost.group.name %>
              <span class="muted">(<%= group_cost.group.selection_summary %><% if group_cost.group.default_option %> · standard <%= group_cost.group.default_option.display_name %><% end %>)</span>
            </span>
            <% if group_cost.costed? %>
              <strong class="tnum">
                <%= money(group_cost.standard_cost) %><% if group_cost.min_cost != group_cost.max_cost %><span class="muted"> · <%= money(group_cost.min_cost) %>–<%= money(group_cost.max_cost) %></span><% end %>
              </strong>
            <% else %>
              <strong class="muted">Uncertain</strong>
            <% end %>
          </div>
          <% unless group_cost.costed? %>
            <p class="muted small"><%= group_cost.reason %></p>
          <% end %>
        <% end %>

        <% if @modifier_costing.standard_total %>
          <div class="recipe-cost-total">
            <span>Total with standard choices</span>
            <strong class="tnum"><%= money(@modifier_costing.standard_total) %></strong>
          </div>
          <% if @modifier_costing.min_total != @modifier_costing.max_total %>
            <div class="recipe-cost-total">
              <span>Across all choices</span>
              <strong class="tnum"><%= money(@modifier_costing.min_total) %>–<%= money(@modifier_costing.max_total) %></strong>
            </div>
          <% end %>
        <% end %>
      <% end %>

      <p class="muted small">Estimates only — actual cost and weight vary with pack size, yield, and waste. Any line we can't cost or weigh is marked uncertain above with the reason.<% if @modifier_costing.groups.any? %> Choice ranges assume any option can be taken for each pick.<% end %></p>
    </div>
  <% end %>
</section>

<section class="panel" id="modifiers">
  <div class="panel-heading">
    <div>
      <h2>Guest choices</h2>
      <p class="muted">Choices a guest makes on this item — a meat, a cheese, a bread, a side. Each is a shared modifier from <%= link_to "the library", modifier_groups_path %>: edit it there and every recipe using it follows. Detaching only removes it from this recipe.</p>
    </div>
  </div>

  <% if @modifier_attachments.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Choice</th>
          <th>Type</th>
          <th>Rule</th>
          <th>Options</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @modifier_attachments.each do |attachment| %>
          <% group = attachment.modifier_group %>
          <tr id="modifier-attachment-<%= attachment.id %>">
            <td class="row-heading" data-label="Choice"><%= link_to group.name, modifier_group_path(group) %></td>
            <td data-label="Type">
              <span class="badge <%= "badge-ok" if group.ingredient? %>"><%= group.ingredient? ? "Ingredient" : "Preparation" %></span>
            </td>
            <td data-label="Rule"><%= group.selection_summary %></td>
            <td data-label="Options">
              <% if group.modifier_options.any? %>
                <% default = group.default_option %>
                <%= group.modifier_options.map { |option| option == default ? "#{option.display_name} (default)" : option.display_name }
                      .to_sentence(two_words_connector: " or ", last_word_connector: " or ") %>
              <% else %>
                <span class="muted">No options yet — add them in the library</span>
              <% end %>
            </td>
            <td class="row-actions" data-label="">
              <%= button_to "Detach", recipe_modifier_path(@recipe, attachment), method: :delete, class: "button small",
                    data: { turbo_confirm: "Detach #{group.name} from #{@recipe.name}? The modifier stays in the library." } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No guest choices on this item yet.</p>
  <% end %>

  <% if @attachable_modifier_groups.any? %>
    <%# Attach submits natively (data-turbo: false) so the #modifiers redirect
        fragment is honored, matching the ingredient forms on this page. %>
    <%= form_with model: [ @recipe, RecipeModifierGroup.new ], url: recipe_modifiers_path(@recipe),
          data: { turbo: false }, class: "inline-ingredient-form" do |form| %>
      <%= form.label :modifier_group_id, "Attach a modifier", class: "sr-only" %>
      <%= form.select :modifier_group_id,
            options_for_select(@attachable_modifier_groups.map { |g| [ g.name, g.id ] }),
            { include_blank: "Choose a modifier…" }, { class: "compact-select" } %>
      <%= form.submit "Attach", class: "button small" %>
    <% end %>
  <% elsif @modifier_attachments.any? %>
    <p class="muted small">Every modifier in the library is already attached. <%= link_to "Add another in the library", new_modifier_group_path %>.</p>
  <% else %>
    <p class="muted small"><%= link_to "Create the first modifier in the library", new_modifier_group_path %> — like a Bread or a Sides — then attach it here.</p>
  <% end %>
</section>

<section class="panel narrow" id="add-ingredient">
  <h2>Add ingredient</h2>
  <%= render "recipes/ingredient_form",
        recipe: @recipe, ingredient: @new_ingredient, inventory_items: @inventory_items, submit_label: "Add ingredient", stacked: true %>
</section>
