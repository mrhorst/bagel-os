<%= form_with model: recipe, url: (recipe.persisted? ? recipe_path(recipe) : recipes_path), class: "stacked-form" do |form| %>
  <% if recipe.errors.any? %>
    <div class="flash flash-alert">
      <strong><%= pluralize(recipe.errors.count, "error") %> kept this from saving:</strong>
      <ul><% recipe.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Recipe name" %>
    <%= form.text_field :name, required: true, autocomplete: "off", placeholder: "Plain bagel dough" %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4, placeholder: "Method, yield, or notes about this recipe." %>
  </div>

  <% if recipe.persisted? %>
    <label class="check">
      <%= form.check_box :active %>
      <span>Active</span>
    </label>
  <% end %>

  <div class="form-footer">
    <%= link_to "Cancel", (recipe.persisted? ? recipe_path(recipe) : recipes_path), class: "button" %>
    <%= form.submit (recipe.persisted? ? "Save changes" : "Create recipe"), class: "button primary" %>
  </div>
<% end %>
