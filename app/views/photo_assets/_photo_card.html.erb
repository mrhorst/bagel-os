<% selectable = local_assigns.fetch(:selectable, false) %>
<%# Carry the index's active filters into the detail link so the photo page's
    "Back to library" affordance returns the reviewer to the same filtered queue
    they opened the photo from. Defaults to none when rendered outside the
    library (e.g. a collection show page), leaving that a bare photo path. %>
<% card_params = local_assigns.fetch(:card_params, {}) %>
<li class="<%= "photo-cell" if selectable %>">
  <% if selectable %>
    <label class="photo-select-check" aria-label="Select photo <%= asset.id %>">
      <%= check_box_tag "photo_asset_ids[]", asset.id, false,
            data: { photo_select_target: "checkbox", action: "change->photo-select#refresh" } %>
    </label>
  <% end %>
  <%= link_to photo_asset_path(asset, card_params), class: "photo-card",
        data: (selectable ? { action: "photo-select#card" } : {}) do %>
    <%= photo_asset_image asset, { resize_to_fill: [ 480, 360 ] },
          alt: asset.caption.presence || "Photo ##{asset.id}", loading: "lazy" %>
    <% if asset.favorite? %>
      <span class="photo-card-fav" aria-label="Favorite" title="Favorite">★</span>
    <% end %>
    <% if asset.status == "needs_review" %>
      <span class="photo-card-status"><%= photo_status_badge(asset) %></span>
    <% end %>
    <% if asset.caption.present? || asset.confirmed_tags.any? %>
      <div class="photo-card-meta">
        <% if asset.caption.present? %>
          <span class="photo-card-caption"><%= asset.caption %></span>
        <% end %>
        <% if asset.confirmed_tags.any? %>
          <span class="pill-list">
            <% asset.confirmed_tags.sort_by(&:name).first(3).each do |tag| %>
              <%= tag_pill(tag.name) %>
            <% end %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</li>
