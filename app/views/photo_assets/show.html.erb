<% content_for :title, "Photo ##{@asset.id}" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (More), skipping
    the Photo library this page was opened from — so it would overshoot the
    parent by a level and contradict the "Back to library" button below. Send it
    up exactly one level, to the library. %>
<% content_for :mobile_left_action do %>
  <%= link_to photo_assets_path, class: "mobile-header-back", aria: { label: "Back to library" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Library</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Photo <span class="tnum">#<%= @asset.id %></span></h1>
    <p>
      <%= photo_status_badge(@asset) %>
      · added <%= @asset.created_at.strftime("%b %-d, %Y") %>
      <% if @asset.uploaded_by %>
        by <%= user_display_name(@asset.uploaded_by) %>
      <% end %>
    </p>
  </div>
  <div class="hero-actions">
    <%= link_to "Back to library", photo_assets_path, class: "button" %>
    <%= button_to toggle_favorite_photo_asset_path(@asset), method: :patch,
          class: [ "button", ("primary" if @asset.favorite?) ] do %>
      <%= @asset.favorite? ? "★ Favorited" : "☆ Favorite" %>
    <% end %>
    <%# Tapping fetches the file and offers it to the native share sheet (Save to
        Photos / Files) rather than navigating away — a same-window nav to an
        attachment strands the chrome-less standalone PWA on a page that can't
        even render it. target=_blank is the no-JS fallback. See
        download_controller.js. %>
    <%= link_to "Download original", rails_blob_path(@asset.photo, disposition: "attachment"),
          class: "button", target: "_blank", rel: "noopener",
          data: { controller: "download", action: "download#save",
                  download_filename_value: @asset.photo.filename.to_s } %>
  </div>
</section>

<div class="grid two">
  <article class="panel">
    <%= photo_asset_image @asset, { resize_to_limit: [ 1600, 1600 ] },
          alt: @asset.caption.presence || "Photo ##{@asset.id}", class: "photo-detail-img" %>

    <% if @asset.photo.variable? %>
      <div class="crop-downloads">
        <h3 class="muted small">Post-ready crops</h3>
        <p class="muted small">Centre-cropped and ready to post — no editing needed.</p>
        <div class="crop-download-row">
          <% PhotoAssetCropsController::FORMATS.each do |style, config| %>
            <%# Same share-sheet flow as "Download original" above. %>
            <%= link_to "#{config[:label]} #{config[:dimensions].join("×")}",
                  crop_photo_asset_path(@asset, style: style),
                  class: "button small", target: "_blank", rel: "noopener",
                  data: { controller: "download", action: "download#save",
                          download_filename_value: "photo-#{@asset.id}-#{style}.jpg" } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <div>
        <h2>Tags</h2>
        <p>How this photo is filed in the library. Confirm AI suggestions or add your own.</p>
      </div>
    </div>

    <% if @suggestions.any? %>
      <div class="tag-suggestions">
        <h3 class="muted small">Suggested by AI — confirm the ones that fit</h3>
        <% @suggestions.each do |tagging| %>
          <div class="suggestion-row">
            <%= tag_pill(tagging.tag.name, pending: true) %>
            <span class="suggestion-actions">
              <%= button_to "Confirm", confirm_photo_asset_tagging_path(@asset, tagging), method: :patch,
                    class: "button small primary" %>
              <%= button_to "Dismiss", photo_asset_tagging_path(@asset, tagging), method: :delete,
                    class: "button small" %>
            </span>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="tag-applied">
      <h3 class="muted small">On this photo</h3>
      <% if @applied.any? %>
        <ul class="tag-chip-list">
          <% @applied.each do |tagging| %>
            <li>
              <%= tag_pill(tagging.tag.name) %>
              <%= button_to "×", photo_asset_tagging_path(@asset, tagging), method: :delete,
                    class: "tag-remove", aria: { label: "Remove #{tagging.tag.name}" } %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="muted small">No confirmed tags yet.</p>
      <% end %>
    </div>

    <% if @available_tags.any? %>
      <%= form_with url: photo_asset_taggings_path(@asset), method: :post, class: "tag-add" do %>
        <%= select_tag :tag_id, options_from_collection_for_select(@available_tags, :id, :name),
              prompt: "Add a tag…" %>
        <%= submit_tag "Add", class: "button small" %>
      <% end %>
    <% elsif @tags_vocabulary_empty %>
      <p class="muted small">
        No tags defined yet.
        <% if Current.user.admin? %><%= link_to "Add some", admin_tags_path %>.<% end %>
      </p>
    <% end %>

    <div class="tag-applied collections-section">
      <h3 class="muted small">In collections</h3>
      <% if @memberships.any? %>
        <ul class="tag-chip-list">
          <% @memberships.each do |membership| %>
            <li>
              <%= link_to membership.collection.name, collection_path(membership.collection), class: "tag-chip" %>
              <%= button_to "×", photo_asset_collection_membership_path(@asset, membership), method: :delete,
                    class: "tag-remove", aria: { label: "Remove from #{membership.collection.name}" } %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="muted small">Not in any collection yet.</p>
      <% end %>

      <% if @available_collections.any? %>
        <%= form_with url: photo_asset_collection_memberships_path(@asset), method: :post, class: "tag-add" do %>
          <%= select_tag :collection_id, options_from_collection_for_select(@available_collections, :id, :name),
                prompt: "Add to collection…" %>
          <%= submit_tag "Add", class: "button small" %>
        <% end %>
      <% else %>
        <p class="muted small">
          <%= link_to "Create a collection", new_collection_path %> to group photos.
        </p>
      <% end %>
    </div>

    <div class="tag-applied ai-copy-section">
      <div class="ai-copy-header">
        <h3 class="muted small">AI marketing copy</h3>
        <% if PhotoAssets::AiDescriber.configured? %>
          <%= button_to(@asset.described_at ? "Regenerate" : "Generate", describe_photo_asset_path(@asset),
                method: :post, class: "button small") %>
        <% end %>
      </div>

      <% if @asset.described_at %>
        <% if @asset.suggested_caption.present? %>
          <div class="suggested-copy">
            <p class="suggested-caption"><%= @asset.suggested_caption %></p>
            <%= button_to "Use as caption", photo_asset_path(@asset), method: :patch,
                  params: { photo_asset: { caption: @asset.suggested_caption } }, class: "button small primary" %>
          </div>
        <% end %>
        <% if @asset.hashtags.present? %>
          <p class="muted small"><%= @asset.hashtags %></p>
        <% end %>
      <% elsif PhotoAssets::AiDescriber.configured? %>
        <p class="muted small">Generate a caption, hashtags, and alt text straight from the photo.</p>
      <% else %>
        <p class="muted small">AI copy isn't set up for this install.</p>
      <% end %>
    </div>

    <%= form_with url: photo_asset_path(@asset), method: :patch, class: "stack" do |form| %>
      <div class="field">
        <%= form.label :photo_asset_caption, "Caption" %>
        <%= text_field_tag "photo_asset[caption]", @asset.caption, id: "photo_asset_caption",
              placeholder: "What this shows, where it could run" %>
      </div>
      <div class="field">
        <%= form.label :photo_asset_alt_text, "Alt text" %>
        <%= text_field_tag "photo_asset[alt_text]", @asset.alt_text, id: "photo_asset_alt_text",
              placeholder: "Describe the photo for screen readers and SEO" %>
      </div>
      <div class="field">
        <%= form.label :photo_asset_hashtags, "Hashtags" %>
        <%= text_field_tag "photo_asset[hashtags]", @asset.hashtags, id: "photo_asset_hashtags",
              placeholder: "#bagel #brunch" %>
      </div>
      <div class="field">
        <%= form.label :photo_asset_notes, "Notes" %>
        <%= text_area_tag "photo_asset[notes]", @asset.notes, id: "photo_asset_notes", rows: 3,
              placeholder: "Anything worth knowing — shoot date, who's in it, usage notes" %>
      </div>
      <%= form.submit "Save details", class: "button small" %>
    <% end %>

    <dl class="details">
      <dt>File</dt>
      <dd><%= @asset.photo.filename %></dd>
      <dt>Size</dt>
      <dd class="tnum"><%= number_to_human_size(@asset.photo.byte_size) %></dd>
    </dl>

    <%= button_to "Delete photo", photo_asset_path(@asset), method: :delete,
          class: "button small", form: { data: { turbo_confirm: "Delete this photo permanently?" } } %>
  </article>
</div>
