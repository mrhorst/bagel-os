<% content_for :title, "Add photos" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (More), skipping
    the Photo library this upload page was opened from — so it would overshoot
    the parent by a level. Send it up exactly one level, to the library. %>
<% content_for :mobile_left_action do %>
  <%= link_to photo_assets_path, class: "mobile-header-back", aria: { label: "Back to library" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Library</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Add photos</h1>
    <p>Take a photo now or pick several from your library. They go straight into the shared library<%= " and get auto-tagged for review" if PhotoAssets::AiTagger.configured? %>.</p>
  </div>
</section>

<article class="panel narrow">
  <%= form_with url: photo_assets_path, multipart: true, class: "stack" do |form| %>
    <div class="field">
      <%= label_tag "photo_asset_camera_photo", "Take a photo" %>
      <%= file_field_tag "photo_asset[camera_photo]", id: "photo_asset_camera_photo",
            accept: "image/*", capture: "environment" %>
      <p class="field-hint">On a phone this opens the camera, one shot at a time.</p>
    </div>
    <div class="field">
      <%= label_tag "photo_asset_photos", "Or choose from your library" %>
      <%= file_field_tag "photo_asset[photos][]", id: "photo_asset_photos",
            accept: "image/*", multiple: true %>
      <p class="field-hint">Pick one or more images you already have. You can use both fields together.</p>
    </div>
    <%= form.submit "Add to library", class: "button primary" %>
  <% end %>
</article>
