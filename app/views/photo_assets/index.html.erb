<% content_for :title, "Photo library" %>

<section class="page-heading">
  <div>
    <h1>Photo library</h1>
    <p>One place for the team's food and product photos — upload or snap them here so anyone with marketing access can find them.</p>
  </div>
  <div class="hero-actions">
    <%= link_to "Collections", collections_path, class: "button" %>
    <% if Current.user.admin? %>
      <%= link_to "Manage tags", admin_tags_path, class: "button" %>
    <% end %>
    <%# On mobile the floating action button (bottom of this view) is the
        canonical "add" affordance, so this inline primary button is hidden
        there to avoid a duplicate "Add photos" CTA; it stays on desktop,
        which has no FAB. %>
    <%= link_to "Add photos", new_photo_asset_path, class: "button primary hide-for-fab" %>
  </div>
</section>

<nav class="segmented photo-library-filters" aria-label="Filter by tagging status">
  <% PhotoAssetsController::SCOPES.each do |scope| %>
    <%= link_to photo_assets_path(scope: scope, tag: params[:tag], q: @query.presence, favorites: params[:favorites]), class: ("active" if @scope == scope) do %>
      <%= scope == "all" ? "All" : scope.humanize %> <span class="tnum">(<%= @counts.fetch(scope, 0) %>)</span>
    <% end %>
  <% end %>
</nav>

<nav class="tag-filter pill-list" aria-label="Filter by tag and favorites">
  <%= link_to "★ Favorites", photo_assets_path(scope: @scope, tag: params[:tag], q: @query.presence, favorites: (@favorites_only ? nil : 1)),
        class: [ "tag-chip", "tag-chip-fav", ("active" if @favorites_only) ] %>
  <% if @tags.any? %>
    <%= link_to "All tags", photo_assets_path(scope: @scope, q: @query.presence, favorites: params[:favorites]),
          class: [ "tag-chip", ("active" unless @active_tag) ] %>
    <% @tags.each do |tag| %>
      <%= link_to tag.name, photo_assets_path(scope: @scope, tag: tag.slug, q: @query.presence, favorites: params[:favorites]),
            class: [ "tag-chip", ("active" if @active_tag == tag) ] %>
    <% end %>
  <% end %>
</nav>

<%= form_with url: photo_assets_path, method: :get, class: "photo-search" do %>
  <%= hidden_field_tag :scope, @scope %>
  <%= hidden_field_tag :tag, params[:tag] %>
  <%= hidden_field_tag :favorites, params[:favorites] %>
  <%= search_field_tag :q, @query, placeholder: "Search captions, notes, tags" %>
  <%= submit_tag "Search", class: "button small" %>
  <% if @query.present? %>
    <%= link_to "Clear", photo_assets_path(scope: @scope, tag: params[:tag], favorites: params[:favorites]), class: "button small" %>
  <% end %>
  <% if @assets.any? %>
    <%= link_to "Download results", photo_asset_exports_path(scope: @scope, tag: params[:tag], favorites: params[:favorites], q: @query.presence),
          class: "button small", target: "_blank", rel: "noopener",
          data: { controller: "download", action: "download#save",
                  download_filename_value: "photo-library.zip" } %>
  <% end %>
<% end %>

<% if @assets.any? %>
  <%# "download" drives the ZIP button: it fetches the selection as a blob and
      offers it to the share sheet, so the standalone PWA never navigates to the
      download. It also POSTs with the page CSRF token, sidestepping the per-form
      token that made the old formaction submit 422. %>
  <%= form_with url: bulk_actions_photo_assets_path, method: :post,
        data: { controller: "photo-select download",
                action: "turbo:submit-start->photo-select#reset",
                download_url_value: photo_asset_exports_path,
                download_method_value: "post",
                download_filename_value: "photo-selection.zip",
                download_ids_value: "input[name='photo_asset_ids[]']" } do %>
    <div class="photo-select-toolbar">
      <span class="photo-select-hint muted small">Tap a photo to select it.</span>
      <button type="button" class="button small" data-photo-select-target="toggle"
              data-action="photo-select#toggleMode" aria-pressed="false">Select</button>
    </div>
    <div class="bulk-bar" data-photo-select-target="bar" role="region" aria-label="Bulk actions">
      <span class="bulk-bar-count tnum" data-photo-select-target="count">0 selected</span>
      <div class="bulk-bar-actions">
        <button type="submit" name="bulk_action" value="favorite" class="button small">★ Favorite</button>
        <button type="submit" name="bulk_action" value="unfavorite" class="button small">Unfavorite</button>
        <% if @tags.any? %>
          <span class="bulk-bar-combo">
            <%= select_tag :tag_id, options_from_collection_for_select(@tags, :id, :name), prompt: "Tag…", "aria-label": "Tag to apply" %>
            <button type="submit" name="bulk_action" value="add_tag" class="button small">Apply</button>
          </span>
        <% end %>
        <% if @collections.any? %>
          <span class="bulk-bar-combo">
            <%= select_tag :collection_id, options_from_collection_for_select(@collections, :id, :name), prompt: "Add to…", "aria-label": "Collection to add to" %>
            <button type="submit" name="bulk_action" value="add_to_collection" class="button small">Add</button>
          </span>
        <% end %>
        <button type="button" class="button small" data-action="download#save">Download ZIP</button>
        <button type="submit" name="bulk_action" value="delete" class="button small bulk-bar-delete"
                data-turbo-confirm="Delete the selected photos permanently?">Delete</button>
        <button type="button" class="button small" data-action="photo-select#clear">Clear</button>
      </div>
    </div>

    <ul class="photo-grid" aria-label="Photo assets">
      <%= render partial: "photo_card", collection: @assets, as: :asset, locals: { selectable: true, card_params: library_filter_params } %>
    </ul>
  <% end %>
<% else %>
  <article class="panel empty-state">
    <% if @scope == "all" && @active_tag.nil? && @query.blank? && !@favorites_only %>
      <strong>No photos yet.</strong>
      <span>Add the first batch from your phone or library.</span>
      <%# Put the primary action where attention lands on the empty first-run
          screen, matching the embedded empty-state CTA used on Follow-ups,
          Tasks, and Products. hide-for-fab keeps it desktop-only (desktop has no
          FAB), so mobile still surfaces a single "Add photos" CTA via the FAB. %>
      <%= link_to "Add photos", new_photo_asset_path, class: "button primary hide-for-fab" %>
    <% else %>
      <strong>No photos match these filters.</strong>
      <span>Clear a filter or search term to see the rest of the library.</span>
    <% end %>
  </article>
<% end %>

<%= mobile_fab_button new_photo_asset_path, label: "Add photos" %>
