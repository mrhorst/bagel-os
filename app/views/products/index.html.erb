<% content_for :title, "Master products" %>

<section class="page-heading">
  <div>
    <h1>Master products</h1>
    <p>Canonical purchased products with spend, purchase frequency, latest prices, and review flags.</p>
  </div>
  <%= link_to "Review queue", normalization_reviews_path, class: "button" %>
</section>

<article class="panel">
  <%= form_with url: products_path, method: :get, class: "filters", data: { controller: "auto-submit-form", action: "submit->auto-submit-form#submit", auto_submit_form: true, async_frame: "products", auto_submit_form_async_frame_value: "products" } do |form| %>
    <div class="field">
      <%= form.label :q, "Search" %>
      <%= form.search_field :q, value: params[:q], placeholder: "Search products", data: { action: "input->auto-submit-form#queueSearch" } %>
    </div>
    <div class="field">
      <%= form.label :category_id, "Category" %>
      <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "All categories", selected: params[:category_id] }, { data: { action: "change->auto-submit-form#queueChange" } } %>
    </div>
    <div class="field">
      <%= form.label :supplier_id, "Supplier" %>
      <%= form.collection_select :supplier_id, @suppliers, :id, :name, { include_blank: "All suppliers", selected: params[:supplier_id] }, { data: { action: "change->auto-submit-form#queueChange" } } %>
    </div>
    <div class="field">
      <%= form.label :sort, "Sort by" %>
      <%= form.select :sort, [["Name", "name"], ["Total spend", "total_spend"], ["Purchase frequency", "purchase_frequency"], ["Latest purchase date", "latest_purchase_date"], ["Highest price increase", "highest_price_increase"], ["Category", "category"]], { selected: params[:sort] }, { data: { action: "change->auto-submit-form#queueChange" } } %>
    </div>
    <div class="field">
      <%= form.label :per_page, "Per page" %>
      <%= form.select :per_page, [[25, 25], [50, 50], [100, 100]], { selected: @per_page }, data: { action: "change->auto-submit-form#queueChange" } %>
    </div>
    <label class="check"><%= form.check_box :needs_review, { checked: params[:needs_review] == "1", data: { action: "change->auto-submit-form#queueChange" } }, "1", "0" %> Needs review</label>
    <label class="check"><%= form.check_box :no_standard_unit_price, { checked: params[:no_standard_unit_price] == "1", data: { action: "change->auto-submit-form#queueChange" } }, "1", "0" %> No standard unit price</label>
    <label class="check"><%= form.check_box :missing_category, { checked: params[:missing_category] == "1", data: { action: "change->auto-submit-form#queueChange" } }, "1", "0" %> Missing category</label>
    <div class="filter-actions">
      <%= form.submit "Apply", class: "button", data: { auto_submit_form_target: "submit", filter_submit: true } %>
      <% if product_filters_active?(params) %>
        <%= link_to "Clear filters", products_cleared_filters_path(request.query_parameters), class: "button", data: { filter_clear: true } %>
      <% end %>
    </div>
  <% end %>
</article>

<article class="panel" data-async-frame="products">
  <div class="panel-heading">
    <p class="muted">
      Showing <%= @products.size %> of <%= @total_products %> products
      <% if @total_pages > 1 %>
        · Page <%= @page %> of <%= @total_pages %>
      <% end %>
    </p>
    <% if @total_pages > 1 %>
      <nav class="pagination" aria-label="Products pages">
        <% pagination_params = request.query_parameters.except("page") %>
        <% if @page > 1 %>
          <%= link_to "Previous", products_path(pagination_params.merge(page: @page - 1)), class: "button small" %>
        <% else %>
          <span class="button small disabled">Previous</span>
        <% end %>
        <% page_numbers = ([ 1, @page - 1, @page, @page + 1, @total_pages ].select { |page| page.between?(1, @total_pages) }).uniq.sort %>
        <% page_numbers.each_with_index do |page_number, index| %>
          <% if index.positive? && page_number > page_numbers[index - 1] + 1 %>
            <span class="pagination-gap">...</span>
          <% end %>
          <% if page_number == @page %>
            <span class="button small active"><%= page_number %></span>
          <% else %>
            <%= link_to page_number, products_path(pagination_params.merge(page: page_number)), class: "button small" %>
          <% end %>
        <% end %>
        <% if @page < @total_pages %>
          <%= link_to "Next", products_path(pagination_params.merge(page: @page + 1)), class: "button small" %>
        <% else %>
          <span class="button small disabled">Next</span>
        <% end %>
      </nav>
    <% end %>
  </div>

  <% if @products.any? %>
  <table class="responsive-table">
    <thead>
      <tr>
        <th scope="col">Product</th>
        <th scope="col">Category</th>
        <th scope="col" class="hide-on-mobile">SKU</th>
        <th scope="col" class="numeric">Latest price</th>
        <th scope="col" class="numeric hide-on-mobile">Avg</th>
        <th scope="col" class="numeric hide-on-mobile">Low</th>
        <th scope="col" class="numeric hide-on-mobile">High</th>
        <th scope="col" class="numeric hide-on-mobile">Times</th>
        <th scope="col" class="numeric">Total spend</th>
        <th scope="col">Review</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <% stats = product.price_stats %>
        <tr>
          <td class="row-heading" data-label="Product"><%= link_to product.canonical_name, product %></td>
          <td data-label="Category"><%= product.category_name %></td>
          <td class="hide-on-mobile" data-label="SKU"><%= product.supplier_sku_summary %></td>
          <td class="numeric" data-label="Latest price"><%= money(stats[:latest_price]) %></td>
          <td class="numeric hide-on-mobile" data-label="Avg"><%= money(stats[:average_price]) %></td>
          <td class="numeric hide-on-mobile" data-label="Low"><%= money(stats[:lowest_price]) %></td>
          <td class="numeric hide-on-mobile" data-label="High"><%= money(stats[:highest_price]) %></td>
          <td class="numeric hide-on-mobile" data-label="Times"><%= stats[:total_times_purchased] %></td>
          <td class="numeric" data-label="Total spend"><%= money(stats[:total_spend]) %></td>
          <td data-label="Review"><%= review_badge(product) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% elsif product_filters_active?(params) %>
    <%= render "dashboard/empty_state",
      title: "No products match these filters",
      message: "Nothing matches the current search and filters. Clear them to see the full catalog.",
      action: link_to("Clear filters", products_cleared_filters_path(request.query_parameters), class: "button", data: { filter_clear: true }) %>
  <% else %>
    <%= render "dashboard/empty_state",
      title: "No products to show",
      message: "Import receipt CSVs to populate your product list.",
      action: (current_user&.can_access?("import_batches") ? link_to("Import receipts", new_import_batch_path, class: "button primary") : nil) %>
  <% end %>
</article>
