<% content_for :title, @product.canonical_name %>

<%= render "shared/blocks/page_header",
  eyebrow: "Product workspace",
  title: @product.canonical_name,
  subtitle: "#{@product.category_name} · #{@product.supplier.name} · SKU #{@product.supplier_sku_summary}",
  action: link_to("Edit product", edit_product_path(@product), class: "button primary"),
  class_name: "product-page-header" %>

<%= render "shared/blocks/metric_grid",
  label: "Key purchasing and pricing facts",
  columns: "eight",
  metrics: [
    { label: "Latest package", value: money(@stats[:latest_price]), detail: "Most recent receipt price", priority: true },
    { label: "Average package", value: money(@stats[:average_price]), detail: "Across matched purchases", priority: true },
    { label: "Total spend", value: money(@stats[:total_spend]), detail: "Imported line total" },
    { label: "Times purchased", value: @stats[:total_times_purchased], detail: "Matched receipt lines" },
    { label: "Lowest package", value: money(@stats[:lowest_price]), detail: "Recorded low" },
    { label: "Highest package", value: money(@stats[:highest_price]), detail: "Recorded high" },
    { label: "Latest comparable", value: money(@stats[:latest_standard_unit_price]), detail: "Per standard unit" },
    { label: "Avg comparable", value: money(@stats[:average_standard_unit_price]), detail: "Per standard unit" }
  ] %>

<section class="product-workspace-grid" aria-label="Product summary and receipt variations">
  <%= render layout: "shared/blocks/section_panel",
    locals: {
      title: "Product summary",
      subtitle: "The shared identity used across receipt lines.",
      class_name: "product-summary-panel"
    } do %>
    <div class="product-summary-facts">
      <div class="product-summary-fact product-summary-fact-status">
        <span>Status</span>
        <strong><%= review_badge(@product) %></strong>
      </div>
      <div class="product-summary-fact">
        <span>First purchased</span>
        <strong><%= @stats[:first_purchase_date]&.to_date || "n/a" %></strong>
      </div>
      <div class="product-summary-fact">
        <span>Last purchased</span>
        <strong><%= @stats[:last_purchase_date]&.to_date || "n/a" %></strong>
      </div>
    </div>

    <%= render "shared/blocks/detail_list",
      class_name: "product-unit-details",
      items: [
        { label: "Package size", value: "#{compact_decimal(@product.package_size)} #{@product.unit_of_measure}" },
        { label: "Purchase unit", value: @product.purchase_unit.presence || "n/a" },
        { label: "Standard unit", value: @product.standard_unit.presence || "n/a" }
      ] %>
    <% if @product.notes.present? %>
      <div class="product-normalization-note">
        <h3>Normalization note</h3>
        <%= simple_format(@product.notes) %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "shared/blocks/section_panel",
    locals: {
      title: "Receipt variations",
      subtitle: "Raw receipt names currently rolling up to this product.",
      class_name: "product-variations-panel"
    } do %>
    <div class="table-scroll">
      <table class="product-variations-table">
        <thead>
          <tr>
            <th>Raw receipt name</th>
            <th>SKU</th>
            <th class="numeric">Times</th>
            <th class="numeric">Latest</th>
            <th>Package</th>
            <th>Review</th>
          </tr>
        </thead>
        <tbody>
        <% @variation_summaries.each do |variation| %>
          <tr>
            <td class="product-variation-name"><%= variation[:raw_name] %></td>
            <td><%= variation[:raw_sku].presence || "n/a" %></td>
            <td class="numeric"><%= variation[:purchases_count] %></td>
            <td class="numeric"><%= money(variation[:latest_package_price]) %></td>
            <td><%= variation[:package_label] %></td>
            <td><%= variation[:needs_review] ? tag.span("Needs review", class: "badge badge-warning badge-compact") : tag.span("Reviewed", class: "badge badge-ok badge-compact") %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<%= render layout: "shared/blocks/section_panel",
  locals: {
    title: "Inventory and guides",
    subtitle: "Operating items that use this receipt-backed product for counting and ordering.",
    class_name: "product-inventory-panel"
  } do %>
  <% if @inventory_items.any? %>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Inventory item</th>
            <th>Primary guide</th>
            <th>Also on</th>
            <th>Section</th>
          </tr>
        </thead>
        <tbody>
          <% @inventory_items.each do |item| %>
            <tr>
              <td><%= item.name %></td>
              <td><%= render "inventory/primary_order_guide_form", item: item, order_guides: @order_guides %></td>
              <td><%= item.additional_order_guides.map(&:name).presence&.to_sentence || "n/a" %></td>
              <td><%= item.inventory_section&.name || "Unsectioned" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="empty-state">No operating inventory item is linked to this product yet.</p>
  <% end %>

  <div class="guide-setup-form">
    <h3>Add to operating guide</h3>
    <% if @order_guides.any? %>
      <%= form_with url: product_order_guide_memberships_path(@product), scope: :membership, class: "stacked-form" do |form| %>
        <div class="form-grid">
          <div class="field">
            <%= form.label :order_guide_id, "Guide" %>
            <%= form.collection_select :order_guide_id, @order_guides, :id, :name, { prompt: "Choose guide" } %>
          </div>
          <div class="field">
            <%= form.label :section_name, "Guide section" %>
            <%= form.text_field :section_name, placeholder: "Dry storage, freezer, front bar" %>
          </div>
          <div class="field">
            <%= form.label :item_name, "Operating item name" %>
            <%= form.text_field :item_name, value: @product.canonical_name %>
          </div>
          <div class="field">
            <%= form.label :tracking_mode, "Tracking" %>
            <%= form.select :tracking_mode, [["Counted", "counted"], ["Order only", "order_only"]] %>
          </div>
          <div class="field">
            <%= form.label :expected_usage_quantity, "Expected usage" %>
            <%= form.number_field :expected_usage_quantity, min: 0, step: "any", inputmode: "decimal" %>
          </div>
          <div class="field">
            <%= form.label :buffer_quantity, "Buffer" %>
            <%= form.number_field :buffer_quantity, min: 0, step: "any", inputmode: "decimal" %>
          </div>
          <div class="field">
            <%= form.label :count_unit, "Count unit" %>
            <%= form.text_field :count_unit, placeholder: "case, sleeve, each" %>
          </div>
          <div class="field">
            <%= form.label :pack_size, "Pack note" %>
            <%= form.text_field :pack_size, placeholder: "2/5 lb, case, box" %>
          </div>
        </div>
        <div class="field">
          <%= form.label :notes, "Guide note" %>
          <%= form.text_area :notes, rows: 2, placeholder: "Optional ordering note for staff" %>
        </div>
        <%= form.submit "Add to guide", class: "button primary" %>
      <% end %>
    <% else %>
      <p class="empty-state">Create an order guide first, then add this product to the operating workflow.</p>
      <%= link_to "Create order guide", order_guides_path, class: "button primary" %>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/blocks/section_panel",
  locals: {
    title: "Price history",
    subtitle: "Presentation price keeps purchased forms separated, but uses comparable units when reliable so different cases can be compared fairly.",
    class_name: "product-price-panel"
  } do %>
  <div class="product-chart-workspace" data-controller="chart-switcher" data-chart-switcher data-initial-chart-mode="<%= @chart_mode %>" data-chart-switcher-initial-mode-value="<%= @chart_mode %>">
    <div class="segmented product-chart-tabs" role="tablist" aria-label="Product price history mode">
      <%= safe_join(PriceChartHelper::CHART_MODES.map do |mode, label|
        fallback_path = product_path(@product, chart_mode: mode)
        link_to label, fallback_path, class: mode == @chart_mode ? "active" : nil, role: "tab", aria: { selected: mode == @chart_mode }, data: { chart_switcher_target: "control", chart_mode: mode, action: "chart-switcher#setMode" }
      end) %>
    </div>

    <% @chart_summaries.each do |mode, summary| %>
      <%= render "shared/blocks/metric_grid",
        label: "#{PriceChartHelper::CHART_MODES.fetch(mode)} summary",
        columns: "four",
        compact: true,
        metrics: [
          { label: "First to latest", value: summary[:recent_change] ? "#{summary[:recent_change]}%" : "n/a" },
          { label: "Last 30 days", value: summary[:change_30_days] ? "#{summary[:change_30_days]}%" : "n/a" },
          { label: "Last 60 days", value: summary[:change_60_days] ? "#{summary[:change_60_days]}%" : "n/a" },
          { label: "Last 90 days", value: summary[:change_90_days] ? "#{summary[:change_90_days]}%" : "n/a" }
        ],
        data: { chart_switcher_target: "summary", chart_summary: mode, chart_mode: mode },
        hidden: mode != @chart_mode %>
      <% if (insight_text = chart_insight_text(summary[:insight])).present? %>
        <p class="chart-insight" data-chart-switcher-target="insight" data-chart-insight="<%= mode %>" data-chart-mode="<%= mode %>" <%= "hidden" unless mode == @chart_mode %>><%= insight_text %></p>
      <% end %>
      <div data-chart-switcher-target="panel" data-chart-panel="<%= mode %>" data-chart-mode="<%= mode %>" <%= "hidden" unless mode == @chart_mode %>>
        <%= price_history_chart(summary[:observations], mode: mode) %>
      </div>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/blocks/section_panel",
  locals: {
    title: "Purchase history",
    subtitle: "Receipt-backed observations with raw line details and cleanup actions.",
    class_name: "product-history-panel"
  } do %>
  <div class="table-scroll">
    <table class="purchase-history-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Receipt</th>
          <th>Item</th>
          <th>Form</th>
          <th class="numeric">Package</th>
          <th class="numeric">Comparable</th>
          <th class="numeric">Total</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @observations.each do |observation| %>
          <% line = observation.receipt_line_item %>
          <% purchase_kind = observation.purchase_kind.presence || line.purchase_kind %>
          <tr id="<%= dom_id(line) %>" class="<%= [("warning-row" if observation.possible_price_spike?), ("needs-review-row" if line.needs_review?)].compact.join(" ") %>">
            <td class="date-cell">
              <time datetime="<%= observation.observed_at.to_date.iso8601 %>">
                <strong><%= observation.observed_at.strftime("%b %-d") %></strong>
                <small><%= observation.observed_at.strftime("%Y") %></small>
              </time>
            </td>
            <td><%= line.receipt.receipt_number %></td>
            <td class="purchase-item">
              <strong><%= line.raw_name %></strong>
              <small>
                <%= [
                  (line.raw_sku.present? ? "SKU #{line.raw_sku}" : nil),
                  observation.presentation_label.presence
                ].compact.join(" · ") %>
              </small>
              <details class="purchase-details">
                <summary>Details</summary>
                <dl class="details details-grid">
                  <dt>Unit qty</dt><dd><%= compact_decimal(observation.unit_quantity) %></dd>
                  <dt>Case qty</dt><dd><%= compact_decimal(observation.case_quantity) %></dd>
                  <dt>Purchase kind</dt><dd><%= observation.purchase_kind.presence || line.purchase_kind %></dd>
                  <dt>Comparable qty</dt><dd><%= observation.standard_quantity.present? ? "#{compact_decimal(observation.standard_quantity)} #{observation.standard_unit}" : "n/a" %></dd>
                  <dt>Inner qty</dt><dd><%= observation.inner_quantity.present? ? "#{compact_decimal(observation.inner_quantity)} #{observation.inner_unit_label}" : "n/a" %></dd>
                  <dt>Inner price</dt><dd><%= observation.inner_unit_price.present? ? "#{money(observation.inner_unit_price)} / #{observation.inner_unit_label}" : "n/a" %></dd>
                  <dt>Source file</dt><dd><%= observation.source_filename %></dd>
                  <dt>Line</dt><dd><%= line.line_number %></dd>
                  <dt>Line ID</dt><dd>#<%= line.id %></dd>
                  <dt>Product ID</dt><dd><%= line.product_id ? "##{line.product_id}" : "n/a" %></dd>
                  <dt>Case-pack ID</dt><dd><%= line.case_pack_id ? "##{line.case_pack_id}" : "n/a" %></dd>
                  <dt>Review issues</dt><dd><%= line.normalization_reviews.select { |review| review.status == "pending" }.map(&:issue_type).presence&.to_sentence || "None" %></dd>
                </dl>
              </details>
            </td>
            <td class="presentation-cell">
              <span class="presentation-badge presentation-badge-<%= purchase_kind.parameterize %>"><%= purchase_kind.titleize %></span>
              <small><%= line.display_quantity %></small>
              <% if line.needs_review? %>
                <span class="review-note">Needs review</span>
              <% end %>
            </td>
            <td class="numeric"><%= money(observation.package_price) %></td>
            <td class="numeric">
              <% if observation.standard_unit_price.present? %>
                <%= money(observation.standard_unit_price) %> / <%= observation.standard_unit %>
              <% else %>
                <span class="muted">n/a</span>
              <% end %>
            </td>
            <td class="numeric"><%= money(observation.line_total) %></td>
            <td>
              <div class="button-row purchase-actions">
                <%= link_to "View", import_batch_path(line.import_batch, anchor: dom_id(line)), class: "button small" %>
                <%= link_to line.needs_review? ? "Review" : "Edit", edit_receipt_line_item_path(line), class: "button small #{'primary' if line.needs_review?}" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
