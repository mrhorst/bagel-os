<% content_for :title, "Edit #{@product.canonical_name}" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Stock), skipping
    both the product and the catalog — so it would overshoot by two levels and
    contradict the "Back to product" button below. Send it up exactly one level,
    to the product. %>
<% content_for :mobile_left_action do %>
  <%= link_to @product, class: "mobile-header-back", aria: { label: "Back to product" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Product</span>
  <% end %>
<% end %>

<section class="page-heading product-edit-heading">
  <div>
    <h1>Edit product</h1>
    <p><%= @product.canonical_name %> · <%= @product.supplier.name %></p>
  </div>
  <%= link_to "Back to product", @product, class: "button" %>
</section>

<section class="product-edit-page">
  <section class="review-summary-band" aria-label="Product review summary">
    <article>
      <span>Product status</span>
      <strong><%= @product.needs_review? ? "Needs review" : "Reviewed" %></strong>
      <small>Name, category, and default units</small>
    </article>
    <article>
      <span>Line review</span>
      <strong><%= pluralize(@pending_line_review_count, "pending line") %></strong>
      <small>Specific receipt rows handled from purchase history</small>
    </article>
    <article>
      <span>Receipt names</span>
      <strong><%= @alias_count %></strong>
      <small><%= pluralize(@receipt_line_count, "receipt line") %> linked here</small>
    </article>
  </section>

  <% if @pending_line_review_count.positive? %>
    <div class="review-callout product-edit-callout">
      <strong>Product review and line review are separate.</strong>
      <p>You can mark this product reviewed after the name/category look right. The remaining receipt-line issue still needs to be handled from purchase history.</p>
    </div>
  <% end %>

  <%= form_with model: @product, class: "stack product-edit-form" do |form| %>
    <article class="panel product-edit-panel">
      <% if @product.errors.any? %>
        <div class="flash flash-alert"><%= @product.errors.full_messages.to_sentence %></div>
      <% end %>

      <section class="form-section">
        <div class="section-heading">
          <h2>Identity</h2>
          <p>What this product should be called and grouped as.</p>
        </div>
        <div>
          <%= form.label :canonical_name, "Product name" %>
          <%= form.text_field :canonical_name, required: true, autocomplete: "off" %>
        </div>
        <div>
          <%= form.label :product_category_id, "Category" %>
          <%= form.collection_select :product_category_id, @categories, :id, :name, include_blank: "Missing category" %>
        </div>
      </section>

      <section class="form-section">
        <div class="section-heading">
          <h2>Default units</h2>
          <p>Only fill these when they are true for the product overall. Case-pack details belong on receipt lines.</p>
        </div>
        <div class="form-grid">
          <div>
            <%= form.label :purchase_unit, "Default purchase form" %>
            <%= form.text_field :purchase_unit, placeholder: "unit, case, bag" %>
          </div>
          <div>
            <%= form.label :package_size %>
            <%= form.number_field :package_size, step: "0.0001", placeholder: "5" %>
          </div>
          <div>
            <%= form.label :unit_of_measure, "Package unit" %>
            <%= form.text_field :unit_of_measure, placeholder: "lb, gal, oz" %>
          </div>
          <div>
            <%= form.label :standard_unit, "Comparable unit" %>
            <%= form.text_field :standard_unit, placeholder: "lb, gal, each" %>
          </div>
        </div>
      </section>

      <section class="form-section">
        <div class="section-heading">
          <h2>How it's used</h2>
          <p>Whether this product is used by count, weight, or volume. Recipes use this to roll up cost and weight. Leave blank when it isn't clear.</p>
        </div>
        <div>
          <%= form.label :unit_basis, "Used by" %>
          <%= form.select :unit_basis,
                Product::UNIT_BASES.map { |basis| [basis.titleize, basis] },
                include_blank: "Not set yet" %>
        </div>
        <div class="form-grid">
          <div>
            <%= form.label :each_weight_value, "Average weight per unit" %>
            <p class="muted small">Optional. For a counted product, the typical weight of one — lets recipes weigh it and cost it against a per-weight price.</p>
            <%= form.number_field :each_weight_value, step: "0.0001", min: "0", placeholder: "50" %>
          </div>
          <div>
            <%= form.label :each_weight_unit, "Weight unit" %>
            <%= form.text_field :each_weight_unit, placeholder: "g, oz, lb" %>
          </div>
        </div>
      </section>

      <section class="form-section">
        <div class="section-heading">
          <h2>Notes</h2>
          <p>Internal reasoning, aliases, or cleanup context.</p>
        </div>
        <%= form.label :notes, "Internal notes" %>
        <%= form.text_area :notes, rows: 6 %>
      </section>

      <section class="form-section">
        <div class="section-heading">
          <h2>Review decision</h2>
          <p>Use product review for shared identity. Use line review for individual receipt rows.</p>
        </div>
        <div class="check-card-grid">
          <label class="check-card">
            <%= form.check_box :active %>
            <span>
              <strong>Visible in purchase catalog</strong>
              <small>Keep this receipt-backed product visible in purchasing and price history.</small>
            </span>
          </label>
          <label class="check-card">
            <%= form.check_box :needs_review %>
            <span>
              <strong>Needs product review</strong>
              <small>Name, category, or default units still need a human decision.</small>
            </span>
          </label>
        </div>
      </section>

      <% if @product.product_aliases.any? %>
        <section class="form-section">
          <div class="section-heading">
            <h2>Receipt names</h2>
            <p>Raw names currently linked to this product.</p>
          </div>
          <ul class="alias-chip-list">
            <% @product.product_aliases.order(:raw_name).limit(10).each do |product_alias| %>
              <li><%= product_alias.raw_name %></li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <div class="actions product-edit-actions">
        <%= form.submit "Save product", class: "button primary" %>
        <%= form.submit "Save and mark reviewed", name: "mark_reviewed", class: "button" %>
        <%= link_to "Cancel", @product, class: "button" %>
      </div>
    </article>
  <% end %>
</section>
