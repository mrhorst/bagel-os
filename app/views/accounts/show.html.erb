<% content_for :title, "Account" %>

<section class="page-heading">
  <div>
    <h1>Account</h1>
    <p>Signed in as <%= @user.email_address %>.</p>
  </div>
</section>

<% if current_user.admin? %>
  <section class="panel narrow">
    <h2>Admin</h2>
    <p class="muted small">Manage users and module permissions for the whole workspace.</p>
    <%= link_to "Manage users", admin_users_path, class: "button" %>
  </section>
<% end %>

<section class="panel narrow">
  <h2>Profile</h2>
  <%= form_with model: @user, url: account_path, method: :patch, class: "stacked-form" do |form| %>
    <% if @user.errors.any? && (@user.errors[:name].any? || @user.errors[:email_address].any?) %>
      <div class="flash flash-alert">
        <ul>
          <% @user.errors.full_messages_for(:name).each { |m| %><li><%= m %></li><% } %>
          <% @user.errors.full_messages_for(:email_address).each { |m| %><li><%= m %></li><% } %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= form.label :name %>
      <%= form.text_field :name, autocomplete: "name" %>
    </div>

    <div class="field">
      <%= form.label :email_address, "Email" %>
      <%= form.email_field :email_address, required: true, autocomplete: "email" %>
    </div>

    <div>
      <%= form.submit "Save profile", class: "button primary" %>
    </div>
  <% end %>
</section>

<% if WebPushConfig.configured? %>
  <section class="panel narrow"
           data-controller="push-subscriptions"
           data-push-subscriptions-public-key-value="<%= WebPushConfig.public_key %>">
    <h2>Notifications</h2>
    <p class="muted small">Get push alerts on this device when tasks run late, a follow-up is assigned to you, or imported lines need review. Turn them off any time — this only affects the device you're using now.</p>
    <button type="button"
            class="button"
            data-push-subscriptions-target="button"
            data-action="push-subscriptions#toggle">Enable notifications</button>
  </section>
<% end %>

<section class="panel narrow">
  <h2>Change password</h2>
  <p class="muted small">Changing your password signs out all other devices.</p>
  <%= form_with model: @user, url: account_password_path, method: :patch, class: "stacked-form" do |form| %>
    <% if @user.errors.any? && (@user.errors[:current_password].any? || @user.errors[:password].any? || @user.errors[:password_confirmation].any?) %>
      <div class="flash flash-alert">
        <ul>
          <% @user.errors.full_messages_for(:current_password).each { |m| %><li><%= m %></li><% } %>
          <% @user.errors.full_messages_for(:password).each { |m| %><li><%= m %></li><% } %>
          <% @user.errors.full_messages_for(:password_confirmation).each { |m| %><li><%= m %></li><% } %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= form.label :current_password, "Current password" %>
      <%= form.password_field :current_password, required: true, autocomplete: "current-password", maxlength: 72 %>
    </div>

    <div class="field">
      <%= form.label :password, "New password" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
    </div>

    <div class="field">
      <%= form.label :password_confirmation, "Confirm new password" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
    </div>

    <div>
      <%= form.submit "Update password", class: "button primary" %>
    </div>
  <% end %>
</section>

<section class="panel narrow">
  <h2>Sign out</h2>
  <p>End this session on this device. You'll need to sign in again to come back.</p>
  <%= button_to "Sign out", session_path, method: :delete, class: "button" %>
</section>
