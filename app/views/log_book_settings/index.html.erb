<% content_for :title, "Log Book settings" %>

<div class="page-heading">
  <div>
    <h1>Log Book settings</h1>
    <p class="muted">Configure how the daily log book behaves.</p>
  </div>
  <div class="actions">
    <%= link_to "Back to Log Book", log_book_path, class: "button small" %>
  </div>
</div>

<section class="settings-hub">
  <%= link_to log_book_sections_path, class: "settings-card" do %>
    <div class="settings-card-icon">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <rect x="3" y="4" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <rect x="3" y="9" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <rect x="3" y="14" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
      </svg>
    </div>
    <div>
      <h2>Sections</h2>
      <p class="muted small">The questions managers fill in each day — General notes, Maintenance, counts, yes/no checks.</p>
      <p class="settings-card-count tnum">
        <%= pluralize(@section_count, "active section") %><% if @archived_count.positive? %> · <%= @archived_count %> archived<% end %>
      </p>
    </div>
  <% end %>

  <%= link_to log_book_history_path, class: "settings-card settings-card-secondary" do %>
    <div class="settings-card-icon">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <path d="M10 6v4l2.5 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div>
      <h2>History</h2>
      <p class="muted small">Past entries and open follow-ups, day by day.</p>
    </div>
  <% end %>
</section>
