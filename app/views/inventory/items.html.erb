<% content_for :title, "Master Inventory" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Stock),
    overshooting the Inventory index this page is opened from (its "Master
    inventory" card). Send it up exactly one level, to Inventory. %>
<% content_for :mobile_left_action do %>
  <%= link_to inventory_path, class: "mobile-header-back", aria: { label: "Back to Inventory" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Inventory</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Master Inventory</h1>
    <p>Operational inventory items staff count and order against.</p>
  </div>
  <div class="actions">
    <%= link_to "New count", new_inventory_count_path, class: "button primary" %>
    <%= link_to "Order guides", order_guides_path, class: "button" %>
    <%# Desktop-only back control: a wide-screen user has no header chevron and
        shouldn't have to click the already-active "Inventory" sidebar item to get
        back — matching "Back to Inventory" on the sibling Buy List / Counts pages.
        Hidden on mobile (`hide-on-mobile`), where the header's "‹ Inventory"
        chevron already returns here, so this doesn't become a third full-width
        button pushing the list below the fold. %>
    <%= link_to "Back to Inventory", inventory_path, class: "button hide-on-mobile" %>
  </div>
</div>

<% if @items_needing_review.any? %>
  <section class="panel">
    <h2>Items Needing Receipt Link Review</h2>
    <p class="muted">These are on the guide but were not confidently matched to a receipt product.</p>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>Guide item</th>
          <th>Section</th>
          <th>Pack / count note</th>
        </tr>
      </thead>
      <tbody>
        <% @items_needing_review.first(20).each do |item| %>
          <tr>
            <td class="row-heading" data-label="Guide item"><%= item.name %></td>
            <td data-label="Section"><%= item.inventory_section&.name || "Unsectioned" %></td>
            <td data-label="Pack / count note"><%= item.pack_size.presence || item.count_unit.presence || "n/a" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

<% @sections.each do |section| %>
  <% items = section.inventory_items.select(&:active?) %>
  <% next if items.empty? %>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2><%= section.name %></h2>
        <p class="muted"><%= pluralize(items.size, "active item") %></p>
      </div>
    </div>
    <table class="responsive-table inventory-section-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Guide</th>
          <th>Receipt product</th>
          <th>Pack / count note</th>
          <th class="numeric">Latest price</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% items.sort_by { |item| [item.position, item.name] }.each do |item| %>
          <tr>
            <td class="row-heading" data-label="Item"><%= item.name %></td>
            <td data-label="Guide">
              <%= render "inventory/primary_order_guide_form", item: item, order_guides: @order_guides %>
              <% if item.additional_order_guides.any? %>
                <small class="muted">Also: <%= item.additional_order_guides.map(&:name).to_sentence %></small>
              <% end %>
            </td>
            <td data-label="Receipt product">
              <% if item.product.present? %>
                <%= link_to item.product.canonical_name, product_path(item.product) %>
              <% else %>
                <span class="muted">Unlinked</span>
              <% end %>
            </td>
            <td data-label="Pack / count note"><%= item.pack_size.presence || item.count_unit.presence || "n/a" %></td>
            <td class="numeric" data-label="Latest price"><%= money_cell(item.latest_price) %></td>
            <td data-label="Status">
              <% if item.needs_review? %>
                <span class="badge badge-warning">Review</span>
              <% else %>
                <span class="badge badge-ok">Linked</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

<% if @unsectioned_items.any? %>
  <section class="panel">
    <h2>Unsectioned Items</h2>
    <table class="responsive-table">
      <tbody>
        <% @unsectioned_items.each do |item| %>
          <tr>
            <td class="row-heading" data-label="Item"><%= item.name %></td>
            <td data-label="Receipt product"><%= item.linked_product_name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>
