<% content_for :title, "Inventory Counts" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Stock),
    overshooting the Inventory index this list was opened from (its "Count
    history" card). Send it up exactly one level, to Inventory. %>
<% content_for :mobile_left_action do %>
  <%= link_to inventory_path, class: "mobile-header-back", aria: { label: "Back to Inventory" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Inventory</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Inventory Counts</h1>
    <p>Manual count history for traceability.</p>
  </div>
  <div class="actions">
    <%= link_to "New count", new_inventory_count_path, class: "button primary" %>
    <%# The mobile chevron returns to Inventory; mirror it with a desktop-visible
        control so a wide-screen user isn't left clicking the already-active
        "Inventory" sidebar item to get back — matching "All guides"/"All imports"
        on the sibling Order Guides / Imports detail pages. %>
    <%= link_to "Back to Inventory", inventory_path, class: "button" %>
  </div>
</div>

<section class="panel">
  <% if @counts.any? %>
    <table>
      <thead>
        <tr>
          <th>Counted at</th>
          <th>Guide</th>
          <th>Status</th>
          <th class="numeric">Lines</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% @counts.each do |count| %>
          <tr>
            <td><%= link_to count.counted_at.to_fs(:long), inventory_count_path(count) %></td>
            <td>
              <% if count.order_guide.present? %>
                <%= link_to count.order_guide.name, order_guide_path(count.order_guide) %>
              <% else %>
                <span class="muted">Legacy count</span>
              <% end %>
            </td>
            <td><span class="badge"><%= count.status.humanize %></span></td>
            <td class="numeric"><%= count.inventory_count_lines.size %></td>
            <td><%= count.notes.presence || "n/a" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">
      <strong>No inventory counts saved yet.</strong>
      <span>Start one with the New count button and it will show up here with its guide, line count, and status.</span>
      <%# Put the primary action at the locus of attention, matching the sibling
          empty states (Follow-ups, Tasks manage, Products). hide-for-fab keeps
          it to desktop only — on mobile the full-width "New count" header button
          already sits directly above this card, so an in-card copy would
          duplicate it. %>
      <%= link_to "New count", new_inventory_count_path, class: "button primary hide-for-fab" %>
    </p>
  <% end %>
</section>
