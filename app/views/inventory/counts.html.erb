<% content_for :title, "Inventory Counts" %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Stock),
    overshooting the Inventory index this list was opened from (its "Count
    history" card). Send it up exactly one level, to Inventory. %>
<% content_for :mobile_left_action do %>
  <%= link_to inventory_path, class: "mobile-header-back", aria: { label: "Back to Inventory" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Inventory</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1>Inventory Counts</h1>
    <p>Manual count history for traceability.</p>
  </div>
  <div class="actions">
    <%= link_to "New count", new_inventory_count_path, class: "button primary" %>
    <%# Desktop-only back control: a wide-screen user has no header chevron and
        shouldn't have to click the already-active "Inventory" sidebar item to get
        back — matching "Back to Inventory" on the sibling Items / Buy List pages.
        Hidden on mobile (`hide-on-mobile`), where the header's "‹ Inventory"
        chevron already returns here, so this doesn't become a redundant third
        full-width button pushing the content below the fold. %>
    <%= link_to "Back to Inventory", inventory_path, class: "button hide-on-mobile" %>
  </div>
</div>

<section class="panel">
  <% if @counts.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th scope="col">Counted at</th>
          <th scope="col">Guide</th>
          <th scope="col">Status</th>
          <th scope="col" class="numeric">Lines</th>
          <th scope="col">Notes</th>
        </tr>
      </thead>
      <tbody>
        <% @counts.each do |count| %>
          <tr>
            <td class="row-heading" data-label="Counted at"><%= link_to count.counted_at.to_fs(:long), inventory_count_path(count) %></td>
            <td data-label="Guide">
              <% if count.order_guide.present? %>
                <%= link_to count.order_guide.name, order_guide_path(count.order_guide) %>
              <% else %>
                <span class="muted">Legacy count</span>
              <% end %>
            </td>
            <td data-label="Status"><span class="badge"><%= count.status.humanize %></span></td>
            <td class="numeric" data-label="Lines"><%= count.inventory_count_lines.size %></td>
            <td data-label="Notes"><%= count.notes.presence || "n/a" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%# Text-only empty state — the sole "New count" primary lives in the page
        header (visible in both empty and populated states, and on both
        breakpoints). An in-card copy would duplicate that primary on desktop,
        giving the view two competing orange CTAs; the copy below already names
        the header button. Matches the sibling Imports index empty state. %>
    <p class="empty-state">
      <strong>No inventory counts saved yet.</strong>
      <span>Start one with the New count button and it will show up here with its guide, line count, and status.</span>
    </p>
  <% end %>
</section>
