<% content_for :title, "Inventory" %>

<section class="hero-panel">
  <div>
    <p class="eyebrow">Inventory + purchasing</p>
    <h1>Order-guide intelligence</h1>
    <p>
      Current guide items, receipt-backed products, and manual counts now live together.
      Anything uncertain stays visible for review instead of being guessed into place.
    </p>
  </div>
  <div class="hero-actions">
    <%= link_to "New count", new_inventory_count_path, class: "button primary" %>
    <%= link_to "Guide gaps", order_guides_path, class: "button" %>
  </div>
</section>

<section class="metric-grid">
  <div class="metric">
    <span>Inventory items</span>
    <strong><%= @inventory_item_count %></strong>
  </div>
  <div class="metric">
    <span>Linked to receipt products</span>
    <strong><%= @linked_inventory_item_count %></strong>
  </div>
  <div class="metric">
    <span>Active guide rows</span>
    <strong><%= @guide_item_count %></strong>
  </div>
  <div class="metric">
    <span>Guide rows needing review</span>
    <strong><%= @guide_items_needing_review %></strong>
  </div>
</section>

<section class="grid two">
  <div class="panel">
    <div class="panel-heading">
      <div>
        <h2>Guide workflows</h2>
        <p class="muted">Start with the guide you are counting or ordering from.</p>
      </div>
      <%= link_to "All guides", order_guides_path, class: "button" %>
    </div>

    <% if @order_guides.any? %>
      <div class="action-grid">
        <% @order_guides.each do |guide| %>
          <section class="action-card guide-workflow-card">
            <strong><%= guide.name %></strong>
            <span><%= pluralize(guide.active_item_count, "active row") %></span>
            <div class="button-row">
              <%= link_to "Count", new_inventory_count_path(order_guide_id: guide.id), class: "button small" %>
              <%= link_to "Buy list", inventory_shopping_list_path(order_guide_id: guide.id), class: "button small" %>
              <%= link_to "Setup", order_guide_path(guide), class: "button small" %>
            </div>
          </section>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">Create an order guide before starting counts or buy lists.</p>
      <%= link_to "Create order guide", order_guides_path, class: "button primary" %>
    <% end %>
  </div>

  <div class="panel">
    <div class="panel-heading">
      <div>
        <h2>Receipt products not on guide</h2>
        <p class="muted">Top items to review against the current daily and weekly guides.</p>
      </div>
      <%= link_to "Review", order_guides_path, class: "button" %>
    </div>

    <% if @missing_products.any? %>
      <table>
        <thead>
          <tr>
            <th>Product</th>
            <th>Signal</th>
            <th class="numeric">Spend</th>
          </tr>
        </thead>
        <tbody>
          <% @missing_products.each do |row| %>
            <tr>
              <td><%= link_to row.product.canonical_name, product_path(row.product) %></td>
              <td>
                <span class="badge <%= row.classification == 'review_for_guide' ? 'badge-warning' : '' %>">
                  <%= row.classification.humanize %>
                </span>
                <small><%= row.purchase_count %> buys</small>
              </td>
              <td class="numeric"><%= number_to_currency(row.total_spend) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-state">No receipt-backed gaps found after the latest guide import.</p>
    <% end %>
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h2>Inventory workflow</h2>
      <p class="muted">Simple operating screens pulled into this purchasing app.</p>
    </div>
  </div>
  <div class="action-grid">
    <%= link_to inventory_items_path, class: "action-card" do %>
      <strong>Master inventory</strong>
      <span>Guide rows, receipt links, pack notes, and review status.</span>
    <% end %>
    <%= link_to new_inventory_count_path, class: "action-card" do %>
      <strong>Manual count</strong>
      <span>Fast count sheet grouped by order-guide section.</span>
    <% end %>
    <%= link_to inventory_counts_path, class: "action-card" do %>
      <strong>Count history</strong>
      <span>Past manual counts for traceability.</span>
    <% end %>
    <%= link_to order_guides_path, class: "action-card" do %>
      <strong>Guide cross-check</strong>
      <span>See guide items and products missing from the guide.</span>
    <% end %>
  </div>
</section>
