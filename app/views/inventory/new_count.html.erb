<% content_for :title, @order_guide ? "Count #{@order_guide.name}" : "New Inventory Count" %>

<%# The slim mobile top bar centers a 1.5rem/700 title in a single grid column
    between the back link and the right slot. "New Inventory Count" overflows that
    column and ellipsizes to "New Inventory Co…", clipping the screen's own name.
    Show a short title in the compact bar via the layout's :mobile_title hook (the
    desktop h1 keeps the full label). Only needed in the guide-chooser state — once
    a guide is picked the title is the already-short "Count <name>". %>
<% content_for :mobile_title, "New Count" if @order_guide.blank? %>

<%# On mobile the top-left chevron is the primary back affordance. Without this
    override the layout's auto-chevron points at the module hub (Stock),
    overshooting the Inventory Counts list this page was opened from and
    contradicting the in-body "Back to Counts" button. Send it up exactly one
    level, to the counts list. %>
<% content_for :mobile_left_action do %>
  <%= link_to inventory_counts_path, class: "mobile-header-back", aria: { label: "Back to Inventory Counts" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Counts</span>
  <% end %>
<% end %>

<div class="page-heading">
  <div>
    <h1><%= @order_guide ? "Count #{@order_guide.name}" : "New Inventory Count" %></h1>
    <%# Describe the count flow rather than repeat the pick instruction: the
        "Choose guide" panel heading below already owns "choose a guide" in the
        chooser state (matching the sibling Buy List, whose subtitle likewise
        describes the feature and lets that heading give the instruction). A
        static "Choose a guide, then…" also mis-described the count-form state,
        where a guide is already picked — "Walk each section…" reads correctly in
        both states. %>
    <p>Walk each section and enter only what you counted.</p>
  </div>
  <%# Desktop-only path to the counts list: a wide-screen user has no header
      chevron, so this is their only in-page way back to Counts. Hidden on mobile
      (`hide-on-mobile`), where the header's "‹ Counts" chevron already returns to
      inventory_counts_path — the exact same destination — so this doesn't become
      a redundant full-width button pushing the guide chooser below the fold.
      Labelled "Back to Counts" to match the sibling Inventory items / Buy List /
      Counts screens' "Back to <destination>" control and this screen's own mobile
      "‹ Counts" chevron (which both return here) — rather than inventing a third
      name ("Count history") for a page titled "Inventory Counts". %>
  <%= link_to "Back to Counts", inventory_counts_path, class: "button hide-on-mobile" %>
</div>

<% if @order_guide.blank? %>
  <% if @order_guides.any? %>
    <section class="panel">
      <h2>Choose guide</h2>
      <div class="action-grid">
        <% @order_guides.each do |guide| %>
          <%= link_to new_inventory_count_path(order_guide_id: guide.id), class: "action-card" do %>
            <strong><%= guide.name %></strong>
            <span><%= pluralize(guide.order_guide_memberships.active.counted.count, "item") %> to count</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% else %>
    <%# Empty state owns the single primary CTA. Use the app-wide embedded
        empty-state pattern (article.panel.empty-state with the button as a
        descendant) so the CTA inherits the centered layout and the
        `.empty-state .button` top gap — a bare sibling button matches neither. %>
    <article class="panel empty-state">
      <strong>No order guides yet.</strong>
      <span>Create an order guide first, then start a count from it.</span>
      <%= link_to "Create order guide", order_guides_path, class: "button primary" %>
    </article>
  <% end %>
<% else %>
  <%= form_with url: inventory_counts_path, method: :post, class: "count-form" do %>
    <%= hidden_field_tag :order_guide_id, @order_guide.id %>

    <% if @count_error.present? %>
      <div class="form-errors" role="alert">
        <strong><%= @count_error %></strong>
      </div>
    <% end %>

    <section class="panel">
      <label for="notes"><strong>Count notes</strong></label>
      <%= text_area_tag :notes, params[:notes], rows: 2, placeholder: "Optional notes about this count" %>
    </section>

    <% grouped_memberships = @memberships.group_by(&:order_guide_section) %>
    <% @order_guide.active_sections.each do |section| %>
      <% memberships = grouped_memberships.delete(section) || [] %>
      <% next if memberships.empty? %>

      <section class="panel">
        <h2><%= section.name %></h2>
        <div class="count-grid">
          <% memberships.each do |membership| %>
            <% item = membership.inventory_item %>
            <label class="count-row">
              <span>
                <strong><%= item.name %></strong>
                <small><%= item.pack_size.presence || item.count_unit.presence || item.linked_product_name %></small>
              </span>
              <%= inventory_count_field(membership) %>
            </label>
          <% end %>
        </div>
      </section>
    <% end %>

    <% unsectioned_memberships = grouped_memberships.values.flatten %>
    <% if unsectioned_memberships.any? %>
      <section class="panel">
        <h2>Unsectioned</h2>
        <div class="count-grid">
          <% unsectioned_memberships.each do |membership| %>
            <% item = membership.inventory_item %>
            <label class="count-row">
              <span>
                <strong><%= item.name %></strong>
                <small><%= item.pack_size.presence || item.count_unit.presence || item.linked_product_name %></small>
              </span>
              <%= inventory_count_field(membership) %>
            </label>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @memberships.empty? %>
      <article class="panel empty-state">
        <strong>No counted rows in this guide yet.</strong>
        <span>Add counted items on the guide setup page, then come back to start the count.</span>
        <%= link_to "Open guide setup", order_guide_path(@order_guide), class: "button primary" %>
      </article>
    <% else %>
      <div class="sticky-actions">
        <%= submit_tag "Save count", class: "primary" %>
      </div>
    <% end %>
  <% end %>
<% end %>
