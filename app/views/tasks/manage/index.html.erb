<% content_for :title, "Tasks" %>

<%
  has_lists = @task_lists.any?
  add_action = if has_lists
    link_to("Add task", setup_tasks_manage_tasks_path(origin: "manage"), class: "button primary")
  else
    link_to("Create a list first", tasks_manage_lists_path, class: "button")
  end
%>

<%=
  render "tasks/subpage_header",
    title: "Tasks",
    subtitle: "Recurring staff work. Archive instead of deleting — history is preserved.",
    back_path: tasks_manage_path,
    back_label: "Settings",
    actions: add_action
%>

<% active_tasks, archived_tasks = @tasks.partition(&:active?) %>

<% if active_tasks.any? %>
  <section class="manage-stack">
    <% active_tasks.group_by(&:task_list).each do |task_list, tasks| %>
      <header class="manage-stack-group-header">
        <h2><%= task_list.name %></h2>
        <span class="muted small tnum"><%= pluralize(tasks.size, "task") %></span>
      </header>
      <% tasks.each do |task| %>
        <%= render "manage_row", task: task, show_list: false %>
      <% end %>
    <% end %>
  </section>
<% elsif has_lists %>
  <section class="panel panel-compact">
    <p class="empty-state">
      <strong>No active tasks yet.</strong>
      <span>Add daily, weekly, or monthly work for any of your lists.</span>
    </p>
    <div class="form-footer">
      <%= link_to "Add your first task", setup_tasks_manage_tasks_path(origin: "manage"), class: "button primary" %>
    </div>
  </section>
<% else %>
  <section class="panel panel-compact">
    <p class="empty-state">
      <strong>You need a list before you can add tasks.</strong>
      <span>Lists group tasks (e.g. Prep, Cleaning) and control when they appear on the dashboard.</span>
    </p>
    <div class="form-footer">
      <%= link_to "Go to task lists", tasks_manage_lists_path, class: "button primary" %>
    </div>
  </section>
<% end %>

<% if archived_tasks.any? %>
  <details class="manage-archive">
    <summary><%= pluralize(archived_tasks.size, "archived task") %></summary>
    <section class="manage-stack">
      <% archived_tasks.each do |task| %>
        <%= render "manage_row", task: task %>
      <% end %>
    </section>
  </details>
<% end %>
