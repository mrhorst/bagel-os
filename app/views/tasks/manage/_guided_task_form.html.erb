<% task_list_options = (@task_lists.to_a + [task.task_list]).compact.uniq.sort_by { |task_list| [task_list.position, task_list.name] } %>

<%
  # Which wizard panel each field lives on, so a failed save can reopen the step
  # that actually holds the error instead of resetting to step 1.
  wizard_field_steps = {
    0 => %i[task_list_id],
    1 => %i[title],
    2 => %i[recurrence_type due_time one_time_on starts_on ends_on weekdays],
    3 => %i[instructions],
    4 => %i[requires_photo_evidence position]
  }
  errored_attrs = task.errors.attribute_names
  error_step = wizard_field_steps.select { |_step, fields| (fields & errored_attrs).any? }.keys.min || -1
%>

<%= form_with model: task,
      url: url,
      method: method,
      class: "task-wizard stacked-form",
      data: { controller: "task-wizard task-schedule-form", action: "submit->task-wizard#submit", task_wizard_error_step_value: error_step } do |form| %>
  <%= hidden_field_tag :return_to, params[:return_to].presence || "dashboard" %>
  <%= form.hidden_field :starts_on %>
  <%= form.hidden_field :ends_on %>

  <% if task.errors.any? %>
    <div class="form-errors" role="alert">
      <strong><%= pluralize(task.errors.count, "error") %> kept this task from saving:</strong>
      <ul>
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <nav class="task-wizard-steps" aria-label="Task setup progress">
    <% [ "List", "Task", "Timing", "Instructions", "Review" ].each_with_index do |label, index| %>
      <button type="button"
              class="task-wizard-step"
              data-task-wizard-target="step"
              data-action="task-wizard#goTo"
              data-task-wizard-index-param="<%= index %>">
        <span><%= index + 1 %></span>
        <%= label %>
      </button>
    <% end %>
  </nav>

  <section class="task-wizard-panel" data-task-wizard-target="panel">
    <p class="task-wizard-kicker">Step 1 of 5</p>
    <h2>Choose the list</h2>
    <p class="muted">Lists keep the dashboard scannable for staff. Pick the work area this task belongs to.</p>
    <div class="field">
      <%= form.label :task_list_id, "Task list" %>
      <%= form.select :task_list_id, options_from_collection_for_select(task_list_options, :id, :name, task.task_list_id), { include_blank: "Choose list" }, required: true %>
    </div>
    <div class="task-wizard-inline-action">
      <%# Preserve the wizard's origin so creating a list mid-flow returns the
          user to where this wizard itself returns (Manage tasks vs dashboard). %>
      <%= link_to "Create a different list", new_tasks_manage_list_path(continue_to_task: "1", origin: ("manage" if params[:return_to] == "manage")), class: "button" %>
    </div>
  </section>

  <section class="task-wizard-panel" data-task-wizard-target="panel" hidden>
    <p class="task-wizard-kicker">Step 2 of 5</p>
    <h2>Name the work</h2>
    <p class="muted">Use the same words staff would search for during a busy shift.</p>
    <div class="field">
      <%= form.label :title, "Task name" %>
      <%= form.text_field :title, required: true, placeholder: "Clean espresso machine" %>
    </div>
  </section>

  <section class="task-wizard-panel" data-task-wizard-target="panel" hidden>
    <p class="task-wizard-kicker">Step 3 of 5</p>
    <h2>Set the timing</h2>
    <p class="muted">Lists control when work appears on the dashboard. Tasks only need their repeat pattern and deadline.</p>
    <div class="form-grid">
      <div class="field">
        <%= form.label :recurrence_type, "Repeats" %>
        <%= form.select :recurrence_type, Task::RECURRENCE_TYPES.map { |value| [ value.humanize, value ] }, {}, required: true, data: { task_schedule_form_target: "recurrence", action: "task-schedule-form#sync" } %>
      </div>
      <div class="field" data-task-schedule-form-target="dueTime">
        <%= form.label :due_time, "Due time" %>
        <%= form.time_field :due_time, value: task.due_time&.strftime("%H:%M") %>
      </div>
      <div class="field" data-task-schedule-form-target="oneTime">
        <%= form.label :one_time_on, "Date" %>
        <%= form.date_field :one_time_on %>
      </div>
    </div>

    <div class="field" data-task-schedule-form-target="weekly">
      <label>Weekly days</label>
      <%= hidden_field_tag "task[weekdays][]", "" %>
      <div class="day-toggle-grid">
        <% Date::ABBR_DAYNAMES.each_with_index do |day_name, weekday| %>
          <label class="day-toggle" for="<%= "#{dom_id(task)}_guided_weekday_#{weekday}" %>">
            <%= check_box_tag "task[weekdays][]", weekday, task.weekday_values.include?(weekday), id: "#{dom_id(task)}_guided_weekday_#{weekday}" %>
            <span><%= day_name %></span>
          </label>
        <% end %>
      </div>
    </div>
  </section>

  <section class="task-wizard-panel" data-task-wizard-target="panel" hidden>
    <p class="task-wizard-kicker">Step 4 of 5</p>
    <h2>Add staff instructions</h2>
    <p class="muted">Keep it short, plain, and useful on the task card.</p>
    <div class="field">
      <%= form.label :instructions, "Instructions" %>
      <%= form.text_area :instructions, rows: 5, placeholder: "Plain text steps the team will see on the task card." %>
    </div>
  </section>

  <section class="task-wizard-panel" data-task-wizard-target="panel" hidden>
    <p class="task-wizard-kicker">Step 5 of 5</p>
    <h2>Final options</h2>
    <p class="muted">Only turn on proof or sort order when the task really needs it.</p>
    <label class="check">
      <%= form.check_box :requires_photo_evidence %>
      <span>Require one completion photo</span>
    </label>
    <div class="field">
      <%= form.label :position, "Sort order" %>
      <%= form.number_field :position, step: 1 %>
      <p class="field-hint">Lower numbers appear first inside the list.</p>
    </div>
  </section>

  <%# Cancel honors the same origin the Back arrow and the post-create redirect
      (Tasks::ManageController#after_create_path) already honor — return to the
      Manage tasks list when the form was reached from there, not the dashboard. %>
  <% cancel_path = params[:return_to] == "manage" ? tasks_manage_tasks_path : tasks_root_path %>
  <div class="task-wizard-actions">
    <%= link_to "Cancel", cancel_path, class: "button" %>
    <button type="button" class="button" data-task-wizard-target="back" data-action="task-wizard#back">Back</button>
    <button type="button" class="button primary" data-task-wizard-target="next" data-action="task-wizard#next">Next</button>
    <%= form.submit submit_label, class: "button primary", data: { task_wizard_target: "submit" } %>
  </div>
<% end %>
