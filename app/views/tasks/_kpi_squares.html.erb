<%# locals: metrics: {late_today:, open_today:, completed_today:, missed_today:}, dom_id: "task_list_kpis", past: false

  Three at-a-glance counters for the current scope (a list, the dashboard,
  whatever). Rendered with a stable id so the completions controller can
  swap it in place via Turbo Stream when a row changes status.

  On a past day, "Late" is meaningless — the window already closed — so we
  swap it for "Missed".
%>
<% past = local_assigns.fetch(:past, false) %>
<section id="<%= local_assigns.fetch(:dom_id, "task_list_kpis") %>"
         class="tasks-kpi-squares"
         aria-label="Task metrics">
  <% if past %>
    <article class="tasks-kpi <%= "tasks-kpi-danger" if metrics[:missed_today].to_i.positive? %>">
      <span>Missed</span>
      <strong class="tnum"><%= metrics[:missed_today].to_i %></strong>
    </article>
  <% else %>
    <article class="tasks-kpi <%= "tasks-kpi-danger" if metrics[:late_today].to_i.positive? %>">
      <span>Late</span>
      <strong class="tnum"><%= metrics[:late_today] %></strong>
    </article>
  <% end %>
  <article class="tasks-kpi <%= "tasks-kpi-accent" if !past && metrics[:open_today].to_i.positive? %>">
    <span>Open</span>
    <strong class="tnum"><%= metrics[:open_today] %></strong>
  </article>
  <article class="tasks-kpi tasks-kpi-ok">
    <span>Done</span>
    <strong class="tnum"><%= metrics[:completed_today] %></strong>
  </article>
</section>
