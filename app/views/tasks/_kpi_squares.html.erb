<%# locals: metrics: {late_today:, open_today:, completed_today:, missed_today:}, dom_id: "task_list_kpis", past: false

  Three at-a-glance counters for the current scope (a list, the dashboard,
  whatever). Rendered with a stable id so the completions controller can
  swap it in place via Turbo Stream when a row changes status.

  On a past day, "Late" is meaningless — the window already closed — so we
  swap it for "Missed".

  A permanent "Late 0" is needlessly anxiety-inducing, so on the current day
  the Late tile only appears when something is actually late. With it hidden
  the row drops to a balanced 2-up grid (.tasks-kpi-squares-2up). The Turbo
  Stream replace from the completions controller re-renders this partial, so
  the tile appears/disappears as the late count crosses zero.
%>
<% past = local_assigns.fetch(:past, false) %>
<% show_first_tile = past || metrics[:late_today].to_i.positive? %>
<section id="<%= local_assigns.fetch(:dom_id, "task_list_kpis") %>"
         class="tasks-kpi-squares<%= " tasks-kpi-squares-2up" unless show_first_tile %>"
         aria-label="Task metrics">
  <% if past %>
    <article class="tasks-kpi <%= "tasks-kpi-danger" if metrics[:missed_today].to_i.positive? %>">
      <span>Missed</span>
      <strong class="tnum"><%= metrics[:missed_today].to_i %></strong>
    </article>
  <% elsif show_first_tile %>
    <article class="tasks-kpi tasks-kpi-danger">
      <span>Late</span>
      <strong class="tnum"><%= metrics[:late_today] %></strong>
    </article>
  <% end %>
  <article class="tasks-kpi">
    <span>Open</span>
    <strong class="tnum"><%= metrics[:open_today] %></strong>
  </article>
  <article class="tasks-kpi <%= "tasks-kpi-ok" if metrics[:completed_today].to_i.positive? %>">
    <span>Done</span>
    <strong class="tnum"><%= metrics[:completed_today] %></strong>
  </article>
</section>
