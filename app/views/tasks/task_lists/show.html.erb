<% content_for :title, @task_list.name %>
<%= turbo_stream_from Tasks::LiveUpdates::STREAM %>

<%# The focused list view shows live completion state. Don't let Turbo
    Drive show a cached preview from a previous visit — it's confusing
    when a row appears "open" momentarily before being replaced. %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
  <%# Make Tasks::LiveUpdates page-refresh broadcasts morph the DOM in place
      instead of full-replacing it, so completing a task relocates rows without
      a flash and preserves scroll + the Completed disclosure's open state. %>
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
<% end %>

<%=
  render "tasks/subpage_header",
    title: @task_list.name,
    subtitle: task_list_display_window_label(@task_list),
    actions: link_to("Edit list", edit_tasks_manage_list_path(@task_list, origin: "list"), class: "button small")
%>

<%= render "tasks/kpi_squares", metrics: @metrics, dom_id: "task_list_kpis_#{@task_list.id}" %>

<section class="tasks-now-panel">
  <% if @today_occurrences.any? %>
    <% if @open_occurrences.any? %>
      <div class="task-row-list">
        <% @open_occurrences.each do |occurrence| %>
          <%= render "tasks/dashboard/task_row", occurrence: occurrence %>
        <% end %>
      </div>
    <% else %>
      <%# Don't claim the whole list is complete when open monthly tasks still
          sit in the "This month" section below — scope the message to today's
          daily/weekly work so the page doesn't contradict itself. %>
      <p class="empty-state">
        <strong>All done for today.</strong>
        <span>
          <%= @monthly_occurrences.any? ?
                "Daily and weekly tasks are complete — monthly tasks are below." :
                "Every task on this list is complete." %>
        </span>
      </p>
    <% end %>

    <%# Completed tasks live in a collapsed disclosure so the focus stays on
        what's left. Native <details> keeps it accessible with no JS. %>
    <% if @completed_occurrences.any? %>
      <details class="tasks-completed-disclosure"
               data-controller="persisted-disclosure"
               data-action="toggle->persisted-disclosure#save"
               data-persisted-disclosure-key-value="tasks:completed-disclosure:<%= @task_list.id %>">
        <summary>
          <span class="tasks-completed-disclosure-label">Completed</span>
          <span class="tasks-completed-disclosure-count tnum"><%= @completed_occurrences.size %></span>
        </summary>
        <div class="task-row-list">
          <% @completed_occurrences.each do |occurrence| %>
            <%= render "tasks/dashboard/task_row", occurrence: occurrence %>
          <% end %>
        </div>
      </details>
    <% end %>
  <% else %>
    <%# No daily/weekly tasks are due today. If the list still has monthly tasks
        (rendered in the "This month" section below), say so instead of the
        absolute "Nothing on this list today" — which would contradict the
        tasks shown right beneath this message. %>
    <% if @monthly_occurrences.any? %>
      <p class="empty-state">
        <strong>No daily or weekly tasks due today.</strong>
        <span>This list's monthly tasks are below.</span>
      </p>
    <% else %>
      <p class="empty-state">
        <strong>Nothing on this list today.</strong>
        <span>Daily and weekly tasks for this list will appear here when they're due.</span>
      </p>
    <% end %>
  <% end %>
</section>

<% if @monthly_occurrences.any? %>
  <section class="tasks-month-panel">
    <header class="task-list-cluster-header">
      <div>
        <h2>This month</h2>
        <p>Monthly tasks can be completed any time this month.</p>
      </div>
    </header>
    <div class="task-row-list">
      <% @monthly_occurrences.each do |occurrence| %>
        <%= render "tasks/dashboard/task_row", occurrence: occurrence, monthly: true %>
      <% end %>
    </div>
  </section>
<% end %>
