<%# locals: task_list:, url:, method:, submit_label: %>
<%= form_with model: task_list, url: url, method: method, class: "stacked-form" do |form| %>
  <%= hidden_field_tag :continue_to_task, "1" if local_assigns[:continue_to_task] %>
  <%# Carry the origin (Manage tasks vs dashboard) through creation so the
      continue-to-task redirect returns the user to where they started. %>
  <%= hidden_field_tag :origin, local_assigns[:origin] if local_assigns[:origin].present? %>

  <% if task_list.errors.any? %>
    <div class="form-errors" role="alert">
      <strong><%= pluralize(task_list.errors.count, "error") %> kept this list from saving:</strong>
      <ul>
        <% task_list.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "List name" %>
    <%= form.text_field :name, required: true, placeholder: "Prep, Cleaning, Closing…" %>
  </div>

  <div class="form-grid">
    <div class="field">
      <%= form.label :position, "Sort order" %>
      <%= form.number_field :position, step: 1 %>
      <p class="field-hint">Lower numbers come first on the dashboard.</p>
    </div>
    <div class="field">
      <%= form.label :display_start_time, "Show from" %>
      <%= form.time_field :display_start_time, value: task_list.display_start_time&.strftime("%H:%M") %>
    </div>
    <div class="field">
      <%= form.label :display_end_time, "Show until" %>
      <%= form.time_field :display_end_time, value: task_list.display_end_time&.strftime("%H:%M") %>
    </div>
  </div>
  <p class="field-hint">Leave display times blank to show this list all day.</p>

  <div class="field">
    <%= form.label :notes, "Notes" %>
    <%= form.text_area :notes, rows: 3, placeholder: "Optional context for staff — not shown on tasks." %>
  </div>

  <div class="form-footer">
    <%= link_to "Cancel", local_assigns[:cancel_path] || tasks_manage_lists_path, class: "button" %>
    <%= form.submit submit_label, class: "button primary" %>
  </div>
<% end %>
