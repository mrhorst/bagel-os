<% content_for :title, "Task lists" %>

<%=
  render "tasks/subpage_header",
    title: "Task lists",
    subtitle: "Groups like Prep, Cleaning, or Closing. Each can have its own display window.",
    back_path: tasks_manage_path,
    back_label: "Settings",
    actions: link_to("Add list", new_tasks_manage_list_path, class: "button primary")
%>

<% active_lists, archived_lists = @task_lists.partition(&:active?) %>

<% if active_lists.any? %>
  <section class="manage-stack">
    <% active_lists.each do |list| %>
      <%= render "manage_row", task_list: list, task_count: @task_counts[list.id].to_i %>
    <% end %>
  </section>
<% else %>
  <section class="panel panel-compact">
    <p class="empty-state">
      <strong>No task lists yet.</strong>
      <span>Start with one — for example, "Prep" or "Closing".</span>
    </p>
    <div class="form-footer">
      <%= link_to "Add your first list", new_tasks_manage_list_path, class: "button primary" %>
    </div>
  </section>
<% end %>

<% if archived_lists.any? %>
  <details class="manage-archive">
    <summary><%= pluralize(archived_lists.size, "archived list") %></summary>
    <section class="manage-stack">
      <% archived_lists.each do |list| %>
        <%= render "manage_row", task_list: list, task_count: @task_counts[list.id].to_i %>
      <% end %>
    </section>
  </details>
<% end %>
