<%# locals: title:, back_path: tasks_root_path, back_label: "Tasks", subtitle: nil, actions: nil

  Standard header for every sub-page under /tasks. The back arrow goes to the
  actual previous page when possible (same-origin browser history), falling
  back to the provided back_path when there is none — e.g. on a fresh tab.
%>
<%
  back_path  = local_assigns.fetch(:back_path, tasks_root_path)
  back_label = local_assigns.fetch(:back_label, "Tasks")
  subtitle   = local_assigns[:subtitle]
  actions    = local_assigns[:actions]
%>

<% content_for :mobile_left_action do %>
  <%= link_to back_path, class: "mobile-header-action mobile-header-back",
              data: { controller: "back", action: "click->back#go" },
              aria: { label: "Back" } do %>
    <svg width="20" height="20" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  <% end %>
<% end %>

<section class="subpage-header">
  <%= link_to back_path, class: "subpage-back",
              data: { controller: "back", action: "click->back#go" },
              aria: { label: "Back to #{back_label}" } do %>
    <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span><%= back_label %></span>
  <% end %>

  <div class="subpage-header-titles">
    <h1><%= title %></h1>
    <% if subtitle.present? %>
      <p class="muted small"><%= subtitle %></p>
    <% end %>
  </div>

  <% if actions.present? %>
    <div class="subpage-header-actions"><%= actions %></div>
  <% end %>
</section>
