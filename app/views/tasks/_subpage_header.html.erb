<%# locals: title:, back_path: tasks_root_path, back_label: "Tasks", subtitle: nil, actions: nil

  Standard header for every sub-page under /tasks. The back arrow navigates to
  back_path — the destination its label names. Callers that want "back" to mean
  "where you came from" resolve that server-side and pass a back_path/back_label
  pair that agree (see Tasks::OccurrencesController#resolve_back_target), so the
  arrow always lands where it says it will. It must never silently history.back()
  to a different page than its label promises (e.g. on a PWA cold start, a deep
  link, or the redirect after saving a form, where the referrer is set).
%>
<%
  back_path  = local_assigns.fetch(:back_path, tasks_root_path)
  back_label = local_assigns.fetch(:back_label, "Tasks")
  subtitle   = local_assigns[:subtitle]
  actions    = local_assigns[:actions]
%>

<% content_for :mobile_left_action do %>
  <%# Name the destination — "Back to <X>" — so the mobile chevron matches its own
      desktop subpage-back twin below and every other module's back chevron
      ("Back to Products", "Back to Log Book", the layout's "Back to <hub>"). A bare
      "Back" left screen-reader / voice-control users on the app's primary (mobile)
      viewport with no idea where the one back affordance leads. %>
  <%= link_to back_path, class: "mobile-header-action mobile-header-back",
              aria: { label: "Back to #{back_label}" } do %>
    <svg width="20" height="20" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  <% end %>
<% end %>

<section class="subpage-header">
  <%= link_to back_path, class: "subpage-back",
              aria: { label: "Back to #{back_label}" } do %>
    <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span><%= back_label %></span>
  <% end %>

  <div class="subpage-header-titles">
    <h1><%= title %></h1>
    <% if subtitle.present? %>
      <p class="muted small"><%= subtitle %></p>
    <% end %>
  </div>

  <% if actions.present? %>
    <div class="subpage-header-actions"><%= actions %></div>
  <% end %>
</section>
