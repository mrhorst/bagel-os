<% content_for :title, "Task Staff" %>

<%=
  render "tasks/subpage_header",
    title: "Staff",
    subtitle: "Names used to attribute task completions. Not logins.",
    back_path: tasks_manage_path,
    back_label: "Settings"
%>

<section class="grid two">
  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Add Staff Member</h2>
        <p class="muted">This does not create a login.</p>
      </div>
    </div>

    <%= form_with model: StaffMember.new, url: tasks_manage_staff_index_path, class: "stacked-form" do |form| %>
      <div class="field">
        <%= form.label :display_name, "Display name" %>
        <%= form.text_field :display_name, required: true, placeholder: "Maria" %>
      </div>
      <div class="field">
        <%= form.label :notes, "Notes" %>
        <%= form.text_area :notes, rows: 3 %>
      </div>
      <%= form.submit "Add staff member", class: "button primary" %>
    <% end %>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Staff Members</h2>
        <p class="muted"><%= pluralize(@staff_members.size, "person") %></p>
      </div>
    </div>

    <% if @staff_members.any? %>
      <div class="task-card-list">
        <% @staff_members.each do |staff_member| %>
          <article class="guide-card">
            <div class="panel-heading">
              <div>
                <h3><%= staff_member.display_name %></h3>
                <% if staff_member.active? %>
                  <span class="badge badge-ok">Active</span>
                <% else %>
                  <span class="badge">Inactive</span>
                <% end %>
              </div>
            </div>

            <%= form_with model: staff_member, url: tasks_manage_staff_path(staff_member), method: :patch, class: "stacked-form" do |form| %>
              <div class="field">
                <%= form.label :display_name, "Display name" %>
                <%= form.text_field :display_name, required: true %>
              </div>
              <div class="field">
                <%= form.label :notes, "Notes" %>
                <%= form.text_area :notes, rows: 2 %>
              </div>
              <%= form.submit "Save staff member", class: "button small" %>
            <% end %>

            <div class="button-row">
              <% if staff_member.active? %>
                <%= button_to "Deactivate", deactivate_tasks_manage_staff_path(staff_member), method: :patch, class: "button small" %>
              <% else %>
                <%= button_to "Reactivate", reactivate_tasks_manage_staff_path(staff_member), method: :patch, class: "button small" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">No task staff members yet.</p>
    <% end %>
  </section>
</section>
