<% content_for :title, "Task settings" %>

<%= render "tasks/subpage_header", title: "Task settings", subtitle: "Configure tasks and lists." %>

<section class="settings-hub">
  <%= link_to tasks_manage_tasks_path, class: "settings-card" do %>
    <div class="settings-card-icon">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M5 6h10M5 10h10M5 14h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div>
      <h2>Tasks</h2>
      <p class="muted small">Create the recurring work — daily prep, weekly cleaning, monthly resets.</p>
      <p class="settings-card-count tnum">
        <%= pluralize(@task_count, "active task") %><% if @inactive_tasks.positive? %> · <%= @inactive_tasks %> archived<% end %>
      </p>
    </div>
  <% end %>

  <%= link_to tasks_manage_lists_path, class: "settings-card" do %>
    <div class="settings-card-icon">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <rect x="3" y="4" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <rect x="3" y="9" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <rect x="3" y="14" width="14" height="3.2" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/>
      </svg>
    </div>
    <div>
      <h2>Task lists</h2>
      <p class="muted small">Group tasks (Prep, Cleaning…) and set when each list appears on the dashboard.</p>
      <p class="settings-card-count tnum">
        <%= pluralize(@list_count, "active list") %><% if @inactive_lists.positive? %> · <%= @inactive_lists %> archived<% end %>
      </p>
    </div>
  <% end %>

  <%= link_to tasks_history_path, class: "settings-card settings-card-secondary" do %>
    <div class="settings-card-icon">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <path d="M10 6v4l2.5 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div>
      <h2>History</h2>
      <p class="muted small">Everything that's been done — and undone — across every list.</p>
    </div>
  <% end %>
</section>
