<% content_for :title, "Tasks" %>

<%= render "shared/blocks/page_header",
  title: "Tasks",
  subtitle: "Current shift work, grouped by the lists staff can actually see right now.",
  class_name: "tasks-page-header",
  action: capture {
    concat link_to("History", tasks_history_path, class: "button")
    concat link_to("Manage tasks", tasks_manage_path, class: "button")
    concat link_to("Refresh", tasks_root_path, class: "button")
  } %>

<div class="tasks-metrics">
  <%= render "shared/blocks/metric_grid",
    compact: true,
    columns: "balanced",
    label: "Task dashboard metrics",
    metrics: [
      { label: "Open today", value: @metrics.fetch(:open_today), detail: "Needs attention this shift", priority: @metrics.fetch(:open_today).positive? },
      { label: "Late today", value: @metrics.fetch(:late_today), detail: "Past due time", tone: (@metrics.fetch(:late_today).positive? ? "warning" : nil) },
      { label: "Completed today", value: @metrics.fetch(:completed_today), detail: "Closed on this device", tone: "success" },
      { label: "Open this month", value: @metrics.fetch(:open_this_month), detail: "Monthly work still open" },
      { label: "Hidden by window", value: @metrics.fetch(:hidden_today), detail: "Appears at list time" }
    ] %>
</div>

<div class="tasks-workspace">
  <div class="tasks-staff-column">
    <%= render layout: "shared/blocks/section_panel",
      locals: {
        title: "Completing as",
        subtitle: "Staff attribution for this device. This is not a login.",
        class_name: "tasks-staff-panel",
        action: link_to("Staff setup", tasks_staff_index_path, class: "button small")
      } do %>
      <div class="task-staff-command">
        <div class="task-staff-current">
          <span>Current staff member</span>
          <strong><%= @current_staff_member&.display_name || "Not selected" %></strong>
        </div>
        <% if @current_staff_member.blank? %>
          <p class="task-staff-warning">Select a staff member before completing tasks.</p>
        <% end %>
        <%= form_with url: tasks_completing_as_path, method: :patch, class: "task-staff-form" do |form| %>
          <%= form.label :staff_member_id, "Staff member", class: "sr-only" %>
          <%= form.select :staff_member_id, options_from_collection_for_select(@staff_members, :id, :display_name, @current_staff_member&.id), { include_blank: "Select staff member" }, class: "compact-select" %>
          <%= form.submit "Use staff member", class: "button primary" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="tasks-now-column">
  <%= render layout: "shared/blocks/section_panel",
    locals: {
      title: "Now",
      subtitle: "Visible task lists only. Late work appears first."
    } do %>

  <% if @grouped_today_occurrences.any? %>
    <div class="task-list-stack">
      <% @grouped_today_occurrences.each do |task_list, occurrences| %>
        <section class="task-list-cluster">
          <div class="task-list-cluster-header">
            <div>
              <h3><%= task_list.name %></h3>
              <p><%= pluralize(occurrences.size, "task") %> ready now</p>
            </div>
            <span><%= task_list_display_window_label(task_list) %></span>
          </div>

          <div class="task-row-list">
            <% occurrences.each do |occurrence| %>
              <article class="task-row task-row-<%= occurrence.status %>">
                <div class="task-row-check">
                  <span class="task-circle task-circle-<%= occurrence.completed? ? "completed" : (occurrence.requires_photo_evidence? ? "photo" : "open") %>" aria-hidden="true"></span>
                </div>

                <div class="task-card-main">
                  <div class="task-card-title">
                    <strong><%= occurrence.snapshot_title %></strong>
                    <span><%= task_due_label(occurrence) %></span>
                  </div>
                  <div class="task-row-meta">
                    <%= task_status_badge(occurrence) %>
                    <% if occurrence.requires_photo_evidence? %>
                      <span class="badge badge-compact">Photo required</span>
                    <% end %>
                    <% if occurrence.active_completion.present? %>
                      <span><%= task_completion_summary(occurrence.active_completion) %></span>
                    <% end %>
                  </div>
                  <% if occurrence.snapshot_instructions.present? %>
                    <details class="task-details">
                      <summary>Instructions</summary>
                      <p><%= occurrence.snapshot_instructions %></p>
                    </details>
                  <% end %>
                </div>

                <div class="task-card-actions">
                  <% if occurrence.completed? %>
                    <% if occurrence.undoable? %>
                      <%= form_with url: tasks_occurrence_completion_path(occurrence), method: :delete do |form| %>
                        <%= hidden_field_tag :confirm_undo, "1" %>
                        <%= form.submit "Undo", class: "button small" %>
                      <% end %>
                    <% else %>
                      <span class="task-action-note">Undo closed</span>
                    <% end %>
                  <% elsif occurrence.requires_photo_evidence? %>
                    <%= link_to "Add photo", tasks_occurrence_path(occurrence), class: "button primary button-success" %>
                  <% else %>
                    <%= form_with url: tasks_occurrence_completion_path(occurrence) do |form| %>
                      <%= form.submit "Complete", class: "button primary button-success" %>
                    <% end %>
                  <% end %>
                  <%= link_to "Details", tasks_occurrence_path(occurrence), class: "button small" %>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No task lists are active right now.</p>
  <% end %>

  <% if @hidden_today_occurrences.any? %>
    <section class="later-tasks-panel">
      <strong><%= pluralize(@hidden_today_occurrences.size, "task") %> hidden by task-list display windows</strong>
      <p class="field-hint">Those lists appear automatically during their configured start and end times.</p>
    </section>
  <% end %>
  <% end %>
  </div>

  <div class="tasks-month-column">
  <%= render layout: "shared/blocks/section_panel",
    locals: {
      title: "This month",
      subtitle: "Monthly tasks can be completed any time this month.",
      class_name: "tasks-month-panel"
    } do %>

  <% if @grouped_monthly_occurrences.any? %>
    <div class="task-list-stack">
      <% @grouped_monthly_occurrences.each do |task_list, occurrences| %>
        <section class="task-list-cluster task-list-cluster-compact">
          <div class="task-list-cluster-header">
            <div>
              <h3><%= task_list.name %></h3>
              <p><%= pluralize(occurrences.size, "monthly task") %></p>
            </div>
          </div>

          <div class="task-row-list">
            <% occurrences.each do |occurrence| %>
              <article class="task-row task-row-monthly">
                <div class="task-row-check">
                  <span class="task-circle task-circle-<%= occurrence.requires_photo_evidence? ? "photo" : "open" %>" aria-hidden="true"></span>
                </div>
                <div class="task-card-main">
                  <div class="task-card-title">
                    <strong><%= occurrence.snapshot_title %></strong>
                    <span>This month</span>
                  </div>
                  <div class="task-row-meta">
                    <%= task_status_badge(occurrence) %>
                    <% if occurrence.requires_photo_evidence? %>
                      <span class="badge badge-compact">Photo required</span>
                    <% end %>
                  </div>
                  <% if occurrence.snapshot_instructions.present? %>
                    <details class="task-details">
                      <summary>Instructions</summary>
                      <p><%= occurrence.snapshot_instructions %></p>
                    </details>
                  <% end %>
                </div>

                <div class="task-card-actions">
                  <% if occurrence.requires_photo_evidence? %>
                    <%= link_to "Add photo", tasks_occurrence_path(occurrence), class: "button primary button-success" %>
                  <% else %>
                    <%= form_with url: tasks_occurrence_completion_path(occurrence) do |form| %>
                      <%= form.submit "Complete", class: "button primary button-success" %>
                    <% end %>
                  <% end %>
                  <%= link_to "Details", tasks_occurrence_path(occurrence), class: "button small" %>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No monthly tasks are open.</p>
  <% end %>
  <% end %>
  </div>
</div>
