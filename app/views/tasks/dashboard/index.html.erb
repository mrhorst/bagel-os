<% content_for :title, "Tasks" %>

<%
  # Context line: day of week + active list name (or "All lists" for the
  # combined view). Keeps the user oriented without a verbose subtitle.
  context_parts = [ Time.zone.now.strftime("%a") ]
  context_parts << case @selected_task_list
                    when :all then "All lists"
                    when TaskList then @selected_task_list.name
                    end
  context_line = context_parts.compact.join(" · ")

  staff_chip_class = [ "tasks-staff-chip", ("tasks-staff-chip-empty" if @current_staff_member.blank?) ].compact
%>

<%# ── Page header: title + context, overflow menu, staff chip ─────────── %>
<section class="tasks-page-header-v2">
  <div class="tasks-page-header-titles">
    <h1>Tasks</h1>
    <p class="muted small"><%= context_line %></p>
  </div>

  <div class="tasks-page-header-tools" data-controller="popover">
    <%# Staff chip — opens the popover to switch %>
    <button type="button"
            class="<%= staff_chip_class.join(' ') %>"
            data-action="popover#toggle"
            data-popover-target="trigger"
            aria-haspopup="true"
            aria-expanded="false">
      <span class="tasks-staff-chip-dot" aria-hidden="true"></span>
      <span class="tasks-staff-chip-label">
        <%= @current_staff_member&.display_name || "Pick staff" %>
      </span>
      <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
        <path d="m3 4.5 3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </button>

    <%= form_with url: tasks_completing_as_path, method: :patch,
          class: "popover-panel popover-panel-staff",
          html: { hidden: true, "data-popover-target": "panel" } do |form| %>
      <h3 class="popover-heading">Completing as</h3>
      <p class="muted small">Staff attribution for this device — not a login.</p>
      <%= form.label :staff_member_id, "Staff member", class: "sr-only" %>
      <%= form.select :staff_member_id,
            options_from_collection_for_select(@staff_members, :id, :display_name, @current_staff_member&.id),
            { include_blank: "Select staff member" }, class: "compact-select" %>
      <div class="popover-actions">
        <%= link_to "Staff setup", tasks_staff_index_path, class: "button small" %>
        <%= form.submit "Use staff", class: "button small primary" %>
      </div>
    <% end %>
  </div>

  <%# Overflow menu — History / Manage / pick another list %>
  <div class="tasks-page-header-overflow" data-controller="popover">
    <button type="button"
            class="icon-button"
            data-action="popover#toggle"
            data-popover-target="trigger"
            aria-label="Tasks menu"
            aria-haspopup="true"
            aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="4" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="10" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="16" cy="10" r="1.6" fill="currentColor"/>
      </svg>
    </button>
    <div class="popover-panel popover-panel-menu" hidden data-popover-target="panel" role="menu">
      <%= link_to "Switch list", tasks_root_path(list: nil), role: "menuitem", class: "popover-item" %>
      <%= link_to "History", tasks_history_path, role: "menuitem", class: "popover-item" %>
      <%= link_to "Manage tasks", tasks_manage_path, role: "menuitem", class: "popover-item" %>
      <%= link_to "Staff setup", tasks_staff_index_path, role: "menuitem", class: "popover-item" %>
    </div>
  </div>
</section>

<%# ── Decision branch: pick a list, or work the active one ───────────── %>
<% if @show_list_picker %>
  <%= render "tasks/dashboard/list_picker" %>
<% else %>
  <%# Compact KPI squares — only the 3 that matter for "what do I do now" %>
  <section class="tasks-kpi-squares" aria-label="Task dashboard metrics">
    <article class="tasks-kpi <%= "tasks-kpi-danger" if @metrics[:late_today].to_i.positive? %>">
      <span>Late</span>
      <strong class="tnum"><%= @metrics[:late_today] %></strong>
    </article>
    <article class="tasks-kpi <%= "tasks-kpi-accent" if @metrics[:open_today].to_i.positive? %>">
      <span>Open</span>
      <strong class="tnum"><%= @metrics[:open_today] %></strong>
    </article>
    <article class="tasks-kpi tasks-kpi-ok">
      <span>Done</span>
      <strong class="tnum"><%= @metrics[:completed_today] %></strong>
    </article>
  </section>

  <% if @metrics[:open_this_month].to_i.positive? || @metrics[:hidden_today].to_i.positive? %>
    <details class="tasks-more-stats">
      <summary>More stats</summary>
      <dl>
        <div><dt>Open this month</dt><dd class="tnum"><%= @metrics[:open_this_month] %></dd></div>
        <div><dt>Hidden by display window</dt><dd class="tnum"><%= @metrics[:hidden_today] %></dd></div>
      </dl>
    </details>
  <% end %>

  <%# ── Now ──────────────────────────────────────────────────────────── %>
  <section class="tasks-now-panel">
    <% if @grouped_today_occurrences.any? %>
      <div class="task-list-stack">
        <% @grouped_today_occurrences.each do |task_list, occurrences| %>
          <section class="task-list-cluster">
            <div class="task-list-cluster-header">
              <div>
                <h3><%= task_list.name %></h3>
                <p><%= pluralize(occurrences.size, "task") %> ready now</p>
              </div>
              <span><%= task_list_display_window_label(task_list) %></span>
            </div>

            <div class="task-row-list">
              <% occurrences.each do |occurrence| %>
                <%= render "tasks/dashboard/task_row", occurrence: occurrence %>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">
        <strong>Nothing to do right now.</strong>
        <span>Tasks appear here during their list's display window.</span>
      </p>
    <% end %>

    <% if @hidden_today_occurrences.any? && @selected_task_list != :all %>
      <section class="later-tasks-panel">
        <strong><%= pluralize(@hidden_today_occurrences.size, "task") %> hidden by task-list display windows</strong>
        <p class="field-hint">Those lists appear automatically during their configured start and end times.</p>
      </section>
    <% end %>
  </section>

  <%# ── This month ───────────────────────────────────────────────────── %>
  <% if @grouped_monthly_occurrences.any? %>
    <section class="tasks-month-panel">
      <header class="task-list-cluster-header">
        <div>
          <h2>This month</h2>
          <p>Monthly tasks can be completed any time this month.</p>
        </div>
      </header>
      <div class="task-list-stack">
        <% @grouped_monthly_occurrences.each do |task_list, occurrences| %>
          <section class="task-list-cluster task-list-cluster-compact">
            <div class="task-list-cluster-header">
              <div>
                <h3><%= task_list.name %></h3>
                <p><%= pluralize(occurrences.size, "monthly task") %></p>
              </div>
            </div>
            <div class="task-row-list">
              <% occurrences.each do |occurrence| %>
                <%= render "tasks/dashboard/task_row", occurrence: occurrence, monthly: true %>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>
