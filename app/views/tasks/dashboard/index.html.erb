<% content_for :title, "Tasks" %>
<% content_for :mobile_fab do %>
  <%= mobile_fab_button new_tasks_manage_task_path, label: "New task" %>
<% end %>

<%
  staff_chip_class = [ "tasks-staff-chip", ("tasks-staff-chip-empty" if @current_staff_member.blank?) ].compact
%>

<%# ── Page header: title + context, overflow menu, staff chip ─────────── %>
<section class="tasks-page-header-v2">
  <div class="tasks-page-header-titles">
    <h1>Tasks</h1>
    <p class="tasks-today-date"><%= Time.zone.now.strftime("%A, %b %-d") %></p>
  </div>

  <div class="tasks-page-header-tools" data-controller="popover">
    <button type="button"
            class="<%= staff_chip_class.join(' ') %>"
            data-action="popover#toggle"
            data-popover-target="trigger"
            aria-haspopup="true"
            aria-expanded="false">
      <span class="tasks-staff-chip-dot" aria-hidden="true"></span>
      <span class="tasks-staff-chip-label">
        <%= @current_staff_member&.display_name || "Pick staff" %>
      </span>
      <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
        <path d="m3 4.5 3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </button>

    <%= form_with url: tasks_completing_as_path, method: :patch,
          class: "popover-panel popover-panel-staff",
          html: { hidden: true, "data-popover-target": "panel" } do |form| %>
      <h3 class="popover-heading">Completing as</h3>
      <p class="muted small">Staff attribution for this device — not a login.</p>
      <%= form.label :staff_member_id, "Staff member", class: "sr-only" %>
      <%= form.select :staff_member_id,
            options_from_collection_for_select(@staff_members, :id, :display_name, @current_staff_member&.id),
            { include_blank: "Select staff member" }, class: "compact-select" %>
      <div class="popover-actions">
        <%= link_to "Manage staff", tasks_manage_staff_index_path, class: "button small" %>
        <%= form.submit "Use staff", class: "button small primary" %>
      </div>
    <% end %>
  </div>

  <div class="tasks-page-header-overflow" data-controller="popover">
    <button type="button"
            class="icon-button"
            data-action="popover#toggle"
            data-popover-target="trigger"
            aria-label="Tasks menu"
            aria-haspopup="true"
            aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="4" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="10" cy="10" r="1.6" fill="currentColor"/>
        <circle cx="16" cy="10" r="1.6" fill="currentColor"/>
      </svg>
    </button>
    <div class="popover-panel popover-panel-menu" hidden data-popover-target="panel" role="menu">
      <%= link_to "History",  tasks_history_path, role: "menuitem", class: "popover-item" %>
      <%= link_to "Settings", tasks_manage_path,  role: "menuitem", class: "popover-item" %>
    </div>
  </div>
</section>

<%# Totals across every list — quick "what's the day look like" %>
<%= render "tasks/kpi_squares", metrics: @metrics, dom_id: "tasks_dashboard_kpis" %>

<%# ── One card per list. Tap a card to work it. ─────────────────────── %>
<section class="tasks-list-picker" aria-label="Task lists">
  <% if @list_summaries.any? %>
    <% @list_summaries.each do |summary| %>
      <% list = summary[:list] %>
      <%= link_to tasks_list_path(list), class: "tasks-list-picker-card #{'tasks-list-picker-card-quiet' unless summary[:visible_now]}" do %>
        <div class="tasks-list-picker-card-main">
          <h2><%= list.name %></h2>
          <p class="muted small"><%= task_list_display_window_label(list) %></p>
        </div>

        <div class="tasks-list-picker-card-counts">
          <% if summary[:late].positive? %>
            <span class="badge badge-warn tnum"><%= summary[:late] %> late</span>
          <% end %>
          <% if summary[:open].positive? %>
            <span class="badge tnum"><%= summary[:open] %> open</span>
          <% elsif summary[:late].zero? && summary[:completed].positive? %>
            <span class="badge badge-ok tnum">All done</span>
          <% end %>
          <% if summary[:monthly_open].positive? %>
            <span class="badge badge-compact tnum"><%= summary[:monthly_open] %> monthly</span>
          <% end %>
        </div>

        <svg class="tasks-list-picker-card-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <path d="m6 3 5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      <% end %>
    <% end %>
  <% else %>
    <p class="empty-state">
      <strong>No active task lists.</strong>
      <span>Create a list and some tasks under <%= link_to "Settings", tasks_manage_path %>.</span>
    </p>
  <% end %>
</section>
