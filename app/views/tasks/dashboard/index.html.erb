<% content_for :title, "Tasks" %>

<div class="page-heading">
  <div>
    <h1>Tasks</h1>
    <p>Current shift work only.</p>
  </div>
  <div class="button-row">
    <%= link_to "History", tasks_history_path, class: "button" %>
    <%= link_to "Manage tasks", tasks_manage_path, class: "button" %>
    <%= link_to "Refresh", tasks_root_path, class: "button" %>
  </div>
</div>

<section class="metric-grid compact tasks-dashboard-metrics">
  <div class="metric">
    <span>Open today</span>
    <strong><%= @metrics.fetch(:open_today) %></strong>
  </div>
  <div class="metric">
    <span>Late today</span>
    <strong><%= @metrics.fetch(:late_today) %></strong>
  </div>
  <div class="metric">
    <span>Completed today</span>
    <strong><%= @metrics.fetch(:completed_today) %></strong>
  </div>
  <div class="metric">
    <span>Open this month</span>
    <strong><%= @metrics.fetch(:open_this_month) %></strong>
  </div>
  <div class="metric">
    <span>Hidden by window</span>
    <strong><%= @metrics.fetch(:hidden_today) %></strong>
  </div>
</section>

<section class="panel staff-strip">
  <div class="panel-heading">
    <div>
      <h2>Completing As</h2>
      <p class="muted">This is staff attribution for this device, not a login.</p>
    </div>
    <%= link_to "Staff setup", tasks_staff_index_path, class: "button small" %>
  </div>
  <%= form_with url: tasks_completing_as_path, method: :patch, class: "inline-guide-form" do |form| %>
    <%= form.label :staff_member_id, "Staff member", class: "sr-only" %>
    <%= form.select :staff_member_id, options_from_collection_for_select(@staff_members, :id, :display_name, @current_staff_member&.id), { include_blank: "Select staff member" }, class: "compact-select" %>
    <%= form.submit "Use staff member", class: "button small" %>
  <% end %>
</section>

<section class="tasks-board">
  <div class="section-heading">
    <h2>Now</h2>
    <p>Only visible task lists show here.</p>
  </div>

  <% if @grouped_today_occurrences.any? %>
    <% @grouped_today_occurrences.each do |task_list, occurrences| %>
      <section class="panel task-list-panel">
        <div class="panel-heading">
          <div>
            <h2><%= task_list.name %></h2>
            <p class="muted"><%= pluralize(occurrences.size, "task") %></p>
          </div>
        </div>

        <div class="task-row-list">
          <% occurrences.each do |occurrence| %>
            <article class="task-row task-row-<%= occurrence.status %>">
              <div class="task-row-check">
                <% if occurrence.completed? %>
                  <span class="task-circle task-circle-completed" aria-label="Completed"></span>
                <% elsif occurrence.requires_photo_evidence? %>
                  <%= link_to tasks_occurrence_path(occurrence), class: "task-circle task-circle-photo", aria: { label: "Add photo evidence for #{occurrence.snapshot_title}" } do %>
                    <span class="sr-only">Add photo evidence</span>
                  <% end %>
                <% else %>
                  <%= form_with url: tasks_occurrence_completion_path(occurrence), class: "circle-form" do |form| %>
                    <%= form.submit "", class: "task-circle task-circle-open", aria: { label: "Complete #{occurrence.snapshot_title}" } %>
                  <% end %>
                <% end %>
              </div>

              <div class="task-card-main">
                <div class="task-card-title">
                  <%= task_status_badge(occurrence) %>
                  <% if occurrence.requires_photo_evidence? %>
                    <span class="badge badge-compact">Photo required</span>
                  <% end %>
                  <strong><%= occurrence.snapshot_title %></strong>
                  <span><%= task_due_label(occurrence) %></span>
                </div>
                <% if occurrence.snapshot_instructions.present? %>
                  <details class="task-details">
                    <summary>Details</summary>
                    <p><%= occurrence.snapshot_instructions %></p>
                  </details>
                <% end %>
                <% if occurrence.active_completion.present? %>
                  <p class="field-hint"><%= task_completion_summary(occurrence.active_completion) %></p>
                <% end %>
              </div>

              <div class="task-card-actions">
                <%= link_to "Details", tasks_occurrence_path(occurrence), class: "button small" %>
                <% if occurrence.completed? %>
                  <% if occurrence.undoable? %>
                    <%= form_with url: tasks_occurrence_completion_path(occurrence), method: :delete, class: "circle-form" do |form| %>
                      <%= hidden_field_tag :confirm_undo, "1" %>
                      <%= form.submit "", class: "task-circle task-circle-undo", aria: { label: "Undo #{occurrence.snapshot_title}" } %>
                    <% end %>
                  <% else %>
                    <span class="muted">Undo closed</span>
                  <% end %>
                <% else %>
                  <% if occurrence.requires_photo_evidence? %>
                    <span class="field-hint">Open details to attach photo.</span>
                  <% end %>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <section class="panel">
      <p class="empty-state">No task lists are active right now.</p>
    </section>
  <% end %>

  <% if @hidden_today_occurrences.any? %>
    <section class="panel later-tasks-panel">
      <strong><%= pluralize(@hidden_today_occurrences.size, "task") %> hidden by task-list display windows</strong>
      <p class="field-hint">Those lists appear automatically during their configured start and end times.</p>
    </section>
  <% end %>
</section>

<section class="tasks-board">
  <div class="section-heading">
    <h2>This Month</h2>
    <p>Monthly tasks can be completed any time this month.</p>
  </div>

  <% if @grouped_monthly_occurrences.any? %>
    <% @grouped_monthly_occurrences.each do |task_list, occurrences| %>
      <section class="panel task-list-panel">
        <div class="panel-heading">
          <div>
            <h2><%= task_list.name %></h2>
            <p class="muted"><%= pluralize(occurrences.size, "monthly task") %></p>
          </div>
        </div>

        <div class="task-row-list">
          <% occurrences.each do |occurrence| %>
            <article class="task-row">
              <div class="task-row-check">
                <%= link_to tasks_occurrence_path(occurrence), class: "task-circle task-circle-open", aria: { label: "Open #{occurrence.snapshot_title}" } do %>
                  <span class="sr-only">Open task details</span>
                <% end %>
              </div>
              <div class="task-card-main">
                <div class="task-card-title">
                  <%= task_status_badge(occurrence) %>
                  <% if occurrence.requires_photo_evidence? %>
                    <span class="badge badge-compact">Photo required</span>
                  <% end %>
                  <strong><%= occurrence.snapshot_title %></strong>
                  <span>This month</span>
                </div>
                <% if occurrence.snapshot_instructions.present? %>
                  <details class="task-details">
                    <summary>Details</summary>
                    <p><%= occurrence.snapshot_instructions %></p>
                  </details>
                <% end %>
              </div>

              <div class="task-card-actions">
                <%= link_to "Details", tasks_occurrence_path(occurrence), class: "button small" %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <section class="panel">
      <p class="empty-state">No monthly tasks are open.</p>
    </section>
  <% end %>
</section>
