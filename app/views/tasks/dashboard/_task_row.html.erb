<%# locals: occurrence, monthly (default: false)

  Row layout: title (tap → details) on the left, completion circle on the
  right. The circle is the action target — submit for open, link for
  photo-required, undo form for undoable completed, static badge otherwise.
%>
<% monthly = local_assigns.fetch(:monthly, false) %>
<article id="<%= dom_id(occurrence) %>"
         class="task-row <%= monthly ? 'task-row-monthly' : "task-row-#{occurrence.status}" %>"
         data-monthly="<%= monthly %>">
  <%= link_to tasks_occurrence_path(occurrence), class: "task-card-main task-card-link" do %>
    <div class="task-card-title">
      <strong><%= occurrence.snapshot_title %></strong>
      <span><%= monthly ? "This month" : task_due_label(occurrence) %></span>
    </div>
    <div class="task-row-meta">
      <%= task_status_badge(occurrence) %>
      <% if occurrence.requires_photo_evidence? %>
        <span class="badge badge-compact">Photo required</span>
      <% end %>
      <% if !monthly && occurrence.active_completion.present? %>
        <span><%= task_completion_summary(occurrence.active_completion) %></span>
      <% end %>
    </div>
  <% end %>

  <div class="task-checkbox-cell">
    <% if !monthly && occurrence.completed? %>
      <% if occurrence.undoable? %>
        <%= form_with url: tasks_occurrence_completion_path(occurrence), method: :delete, class: "task-checkbox-form" do |form| %>
          <%= hidden_field_tag :confirm_undo, "1" %>
          <%= form.button type: "submit",
                class: "task-checkbox task-checkbox-completed",
                aria: { label: "Undo completion" },
                title: "Undo" do %><% end %>
        <% end %>
      <% else %>
        <span class="task-checkbox task-checkbox-completed" aria-label="Completed" role="img"></span>
      <% end %>
    <% elsif occurrence.requires_photo_evidence? %>
      <%# Hidden file input behind the circle. The `capture` attribute opens
          the rear camera directly on mobile; on desktop it falls back to a
          file picker. Selecting a file auto-submits the form. %>
      <%= form_with url: tasks_occurrence_completion_path(occurrence),
            multipart: true,
            class: "task-checkbox-form",
            data: { controller: "auto-submit" } do |form| %>
        <label class="task-checkbox task-checkbox-photo"
               aria-label="Take photo to complete"
               title="Take photo"
               tabindex="0">
          <%= form.file_field :photo,
                accept: "image/*",
                capture: "environment",
                class: "sr-only",
                data: { action: "change->auto-submit#submit" } %>
        </label>
      <% end %>
    <% else %>
      <%= form_with url: tasks_occurrence_completion_path(occurrence), class: "task-checkbox-form" do |form| %>
        <%= form.button type: "submit",
              class: "task-checkbox task-checkbox-open",
              aria: { label: "Mark complete" },
              title: "Mark complete" do %><% end %>
      <% end %>
    <% end %>
  </div>
</article>
