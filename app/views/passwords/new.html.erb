<% content_for :title, "Reset password" %>

<section class="panel narrow">
  <h1>Reset password</h1>
  <p class="muted">Enter your email and we'll send a reset link.</p>

  <%= form_with url: passwords_path, class: "stacked-form" do |form| %>
    <div class="field">
      <%= form.label :email_address, "Email" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
    </div>

    <div class="actions">
      <%= form.submit "Send reset link", class: "button primary" %>
      <%= link_to "Back to sign in", new_session_path, class: "muted" %>
    </div>
  <% end %>
</section>
