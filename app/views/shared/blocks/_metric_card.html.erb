<article class="block-stat-card <%= "block-stat-card-#{local_assigns[:tone]}" if local_assigns[:tone].present? %> <%= "block-stat-card-priority" if local_assigns[:priority] %>">
  <span><%= label %></span>
  <strong><%= value %></strong>
  <% if local_assigns[:detail].present? %>
    <small><%= detail %></small>
  <% end %>
</article>
