<% content_for :title, "Imports" %>

<section class="page-heading">
  <div>
    <h1>Imports</h1>
    <p>Every upload/import batch is tracked with filename, checksum, status, and validation counts.</p>
  </div>
  <%= link_to "Upload CSV", new_import_batch_path, class: "button primary" %>
</section>

<article class="panel">
  <% if @import_batches.any? %>
    <table class="responsive-table">
      <thead>
        <tr>
          <th>File</th>
          <th>Supplier</th>
          <th>Status</th>
          <th class="numeric">Rows</th>
          <th class="numeric">Imported</th>
          <th class="numeric">Failed</th>
          <th class="numeric">Needs review</th>
          <th>Imported at</th>
        </tr>
      </thead>
      <tbody>
        <% @import_batches.each do |batch| %>
          <tr>
            <td data-label="File"><%= link_to batch.source_filename, batch %></td>
            <td data-label="Supplier"><%= batch.supplier.name %></td>
            <td data-label="Status"><span class="badge"><%= batch.status %></span></td>
            <td class="numeric" data-label="Rows"><%= batch.rows_processed %></td>
            <td class="numeric" data-label="Imported"><%= batch.rows_imported %></td>
            <td class="numeric" data-label="Failed"><%= batch.rows_failed %></td>
            <td class="numeric" data-label="Needs review">
              <% review_count = @review_counts.fetch(batch.id, 0) %>
              <% if review_count.positive? %>
                <span class="badge badge-warning tnum"><%= review_count %></span>
              <% else %>
                <span class="tnum">0</span>
              <% end %>
            </td>
            <td data-label="Imported at"><%= batch.imported_at&.strftime("%Y-%m-%d %I:%M %p") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">
      <strong>No imports yet.</strong>
      <span>Upload a supplier CSV to track its rows, imported and failed counts, and status here.</span>
    </p>
  <% end %>
</article>
