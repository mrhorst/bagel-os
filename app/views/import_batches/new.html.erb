<% content_for :title, "Upload CSV" %>

<% content_for :mobile_left_action do %>
  <%= link_to import_batches_path, class: "mobile-header-back", aria: { label: "Back to Imports" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Imports</span>
  <% end %>
<% end %>

<section class="page-heading">
  <div>
    <h1>Upload receipt CSV</h1>
    <p>Upload one vendor receipt export. Duplicate checks use file checksum and receipt number.</p>
  </div>
  <%= link_to "CSV example", csv_example_import_batches_path, class: "button small" %>
</section>

<article class="panel narrow">
  <%= form_with url: import_batches_path, multipart: true, class: "stack" do |form| %>
    <div>
      <%= form.label :csv_file, "CSV file" %>
      <%= form.file_field :csv_file, accept: ".csv,text/csv", required: true %>
      <p class="field-hint">Not sure of the format? <%= link_to "Download a CSV example", csv_example_import_batches_path %> to see the expected columns.</p>
    </div>
    <%= form.submit "Import receipt", class: "button primary" %>
  <% end %>
</article>
