<% content_for :title, "Upload receipt CSV" %>

<% content_for :mobile_left_action do %>
  <%= link_to import_batches_path, class: "mobile-header-back", aria: { label: "Back to Imports" } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
      <path d="M11 3 5 9l6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Imports</span>
  <% end %>
<% end %>

<%# One affordance for the CSV example, not two: the contextual "Download a CSV
    example" link below sits right at the file field and explains what it is, so
    the redundant top-right button (same destination) is dropped — it only
    competed with the form's real primary action. %>
<section class="page-heading">
  <div>
    <h1>Upload receipt CSV</h1>
    <p>Upload one vendor receipt export. Duplicate checks use file checksum and receipt number.</p>
  </div>
</section>

<article class="panel narrow">
  <%= form_with url: import_batches_path, multipart: true, class: "stack" do |form| %>
    <div>
      <%= form.label :csv_file, "CSV file" %>
      <%= form.file_field :csv_file, accept: ".csv,text/csv", required: true %>
      <%# Fetch-and-share via download_controller so a same-window attachment nav
          can't strand an installed PWA on a chrome-less page. target=_blank is
          the no-JS fallback. See download_controller.js. %>
      <p class="field-hint">Not sure of the format? <%= link_to "Download a CSV example", csv_example_import_batches_path,
            target: "_blank", rel: "noopener",
            data: { controller: "download", action: "download#save",
                    download_filename_value: "receipt-import-example.csv" } %> to see the expected columns.</p>
    </div>
    <%# Cancel mirrors the mobile chevron's destination so the page has a
        desktop-visible way back to Imports too — the mobile-screen-header
        chevron is display:none on desktop, and every sibling create/edit
        screen (collections, products, admin tags, log book sections) offers an
        in-content back or Cancel. Without this, Upload receipt CSV was a create
        form a desktop user couldn't back out of from the page itself. %>
    <div class="form-footer">
      <%= link_to "Cancel", import_batches_path, class: "button" %>
      <%= form.submit "Import receipt", class: "button primary" %>
    </div>
  <% end %>
</article>
