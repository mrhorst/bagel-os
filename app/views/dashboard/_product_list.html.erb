<% products = Array(products) %>

<% if products.any? %>
  <table class="dashboard-table dashboard-table-compact">
    <thead>
      <tr>
        <th>Product</th>
        <th>Category</th>
        <th class="numeric">Buys</th>
        <th class="numeric">Spend</th>
      </tr>
    </thead>
    <tbody>
      <% products.each do |product| %>
        <% stats = product.price_stats %>
        <tr>
          <td><%= link_to product.canonical_name, product %></td>
          <td><%= product.category_name %></td>
          <td class="numeric"><%= dashboard_count(stats[:total_times_purchased]) %></td>
          <td class="numeric"><%= money(stats[:total_spend]) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "dashboard/empty_state",
    title: local_assigns.fetch(:empty_title, "Nothing to show"),
    message: local_assigns.fetch(:empty_message, "This block will fill in after more receipt data is imported.") %>
<% end %>
