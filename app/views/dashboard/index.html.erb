<% content_for :title, "Dashboard" %>
<%= turbo_stream_from Tasks::LiveUpdates::STREAM if current_user&.can_access?("tasks") %>

<% content_for :mobile_right_action do %>
  <%= link_to account_path, class: "mobile-header-action", aria: { label: "Account" } do %>
    <span class="mobile-header-avatar" aria-hidden="true"><%= user_display_name(current_user).first.upcase %></span>
  <% end %>
<% end %>

<%
  tasks_upcoming_suffix = @tasks_upcoming_today.positive? ? " · #{@tasks_upcoming_today} upcoming" : ""
  surfaces = [
    {
      label: "Tasks",
      module_name: "tasks",
      path: tasks_root_path,
      count: @tasks_open_today,
      tone: @tasks_late_today.positive? ? "urgent" : (@tasks_open_today.positive? ? "active" : "ok"),
      summary:
        if @tasks_late_today.positive?
          "#{@tasks_late_today} late, #{@tasks_open_today} open today#{tasks_upcoming_suffix}"
        elsif @tasks_open_today.positive?
          "#{@tasks_open_today} open today#{tasks_upcoming_suffix}"
        elsif @tasks_upcoming_today.positive?
          "All clear now · #{@tasks_upcoming_today} upcoming"
        else
          "All clear today"
        end,
      description: "Daily and monthly checklists for the team."
    },
    {
      label: "Log Book",
      module_name: "log_book",
      path: log_book_path,
      count: @log_book_follow_up_count,
      tone: @log_book_follow_up_count.positive? ? "urgent" : "ok",
      summary: @log_book_follow_up_count.positive? ? pluralize(@log_book_follow_up_count, "follow-up") + " open" : "No open follow-ups",
      description: "Daily manager notes and handoffs."
    },
    {
      label: "Review queue",
      module_name: "normalization_reviews",
      path: normalization_reviews_path,
      count: @pending_review_count,
      tone: @pending_review_count.positive? ? "urgent" : "ok",
      summary: @pending_review_count.positive? ? pluralize(@pending_review_count, "receipt") + " to review" : "Nothing pending",
      description: "Confirm imported receipts before they hit reports."
    },
    {
      label: "Order guides",
      module_name: "order_guides",
      path: order_guides_path,
      count: @guide_items_needing_review_count,
      tone: @guide_items_needing_review_count.positive? ? "active" : "ok",
      summary: @guide_items_needing_review_count.positive? ? "#{pluralize(@guide_items_needing_review_count, "link")} to verify" : "Guides look clean",
      description: "What you order, organized by supplier."
    },
    {
      label: "Inventory",
      module_name: "inventory",
      path: inventory_path,
      count: @inventory_items_needing_review_count,
      tone: @inventory_items_needing_review_count.positive? ? "active" : "ok",
      summary: @inventory_items_needing_review_count.positive? ? "#{pluralize(@inventory_items_needing_review_count, "item")} to clean up" : "On-hand looks tidy",
      description: "Counts, units, and on-hand stock."
    },
    {
      label: "Products",
      module_name: "products",
      path: products_path,
      count: @products_needing_review_count,
      tone: @products_needing_review_count.positive? ? "active" : "ok",
      summary: @products_needing_review_count.positive? ? "#{pluralize(@products_needing_review_count, "record")} to clean up" : "Records look complete",
      description: "The master catalog of everything purchased."
    },
    {
      label: "Marketing",
      module_name: "marketing",
      path: photo_assets_path,
      count: @marketing_unreviewed_count,
      tone: @marketing_unreviewed_count.positive? ? "active" : "ok",
      summary: @marketing_unreviewed_count.positive? ? "#{pluralize(@marketing_unreviewed_count, "photo")} to review" : "Library is reviewed",
      description: "Photo library for menus, social, and the site."
    }
  ].select { |surface| current_user&.can_access?(surface[:module_name]) }
%>

<section class="home-hero">
  <h1><%= dashboard_greeting %></h1>
  <p><%= dashboard_today_headline %> · Pick an area to jump in.</p>
</section>

<section class="home-surface-grid" aria-label="App areas">
  <% surfaces.each do |surface| %>
    <%= link_to surface[:path], class: "home-surface-card home-surface-card-#{surface[:tone]}" do %>
      <div class="home-surface-card-head">
        <span class="home-surface-card-label"><%= surface[:label] %></span>
        <% if surface[:count].to_i.positive? %>
          <span class="home-surface-card-count"><%= dashboard_count(surface[:count]) %></span>
        <% end %>
      </div>
      <strong class="home-surface-card-summary"><%= surface[:summary] %></strong>
      <span class="home-surface-card-description"><%= surface[:description] %></span>
    <% end %>
  <% end %>
</section>
