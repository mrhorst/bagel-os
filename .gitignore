/.bundle
/.ruby-lsp
/.worktrees/
/.yardoc
/coverage
/log/*
/storage/*.sqlite3
/storage/*.sqlite3_*
/storage/*.sqlite3-*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep
/config/master.key
/public/assets
/vendor/bundle/

# Private install data stays local or in a separate private repo.
/.private/

# Real vendor exports and order guides must not be committed.
/data/receipts/
/data/order_guides/

# Keep sample fixtures sanitized. Do not commit real receipts, PDFs, or vendor exports.

# Design artifacts captured from a live (branded) dev environment stay private.
# Move screenshots etc. into .private/ to share locally without leaking branding.
/docs/design/screenshots*/
/docs/design/**/*.png
/docs/design/**/*.jpg

/app/assets/builds/*
!/app/assets/builds/.keep
.DS_Store
