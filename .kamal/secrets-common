# Secrets shared by EVERY destination (production + staging).
#
# Kamal reads this file plus the per-destination file (.kamal/secrets for the
# default/production target, .kamal/secrets.staging for staging). Values use
# dotenv syntax and resolve from your shell, GitHub Actions, or a command —
# never commit literal secret values here.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
TASK_BRIEFING_AGENT_GATEWAY_TOKEN=$TASK_BRIEFING_AGENT_GATEWAY_TOKEN

# RAILS_MASTER_KEY decrypts the same credentials.yml.enc in both environments.
# Locally, read it from config/master.key (present in a dev checkout). In CI the
# key is absent from the checkout, so fall back to the RAILS_MASTER_KEY env var.
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || printf %s "$RAILS_MASTER_KEY")
