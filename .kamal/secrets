# Values are read by Kamal using dotenv syntax. The right-hand side can come
# from your shell or a command; do not put literal secret values in this file.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$(cat config/master.key)
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
TASK_BRIEFING_AGENT_GATEWAY_TOKEN=$TASK_BRIEFING_AGENT_GATEWAY_TOKEN

# Optional SMTP/password reset support. Add these to config/deploy.yml's
# env.secret list only when email is ready to be enabled.
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD
