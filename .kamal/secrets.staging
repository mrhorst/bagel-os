# Staging destination secrets. Combined with .kamal/secrets-common.
# Values use dotenv syntax; do not put literal secret values in this file.
#
# Staging MUST use a DIFFERENT database password than production — it runs its
# own Postgres container on the same host. Set STAGING_POSTGRES_PASSWORD in your
# shell (local) or as a GitHub Actions secret (CI).
POSTGRES_PASSWORD=$STAGING_POSTGRES_PASSWORD
